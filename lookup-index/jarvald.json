  "hashesWithUnresolvedText": {
    "aa13e19651bb1cbea53c9461bf7281e62f419d316bd9bbb88e0ba0692c5d267c": {
      "text": "Greetings, [Fremennik name]!",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "f5783cedb6d32b7def643b17025cab0e31d45c090a64800f071c141b5df01fa3": {
      "text": "You have not heard, [Fremennik name]? I am leading an expedition to Waterbirth Island!",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "62f6df2201cf34b5db9bd4c6ad1e9d09eae5d7ad8fce296ca0c973833676a102": {
      "text": "You have not ever travelled to Waterbirth Island, [Fremennik name]? I am surprised, it is a place of outstanding natural beauty.",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "696a5966b003c5966e7dfd36fcfb9c864a225b4b82dead1e358ef5ee9f78517f": {
      "text": "You wound us with your questioning, [Fremennik name]!",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "4ba39d23ec7a794173f5c569c4f168eda162fcdc7af209b1db6918c251918288": {
      "text": "Of course, [Fremennik name]! Your presence is more than welcome on this cull! You wish to leave now?",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "6fad2bf3c21f8d7633b58b246ab1bba4c5e65fd56cc46f1eb0242504a05ce08f": {
      "text": "Aye, that it is [Fremennik name]! Skulgrimen fashioned it for me from the carcass of one of the monsters on Waterbirth Island after our last hunt!",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "84cc2f691580fab0f95c854a44ce850b2d08e066ad852f8379f0378f605cf694": {
      "text": "Ah, it is always a pleasure [Fremennik name]! Now did you want something more from me?",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "722e31c194c234179aadce64222a4563ef31d590c58ce9c9a39801f1ce2f9907": {
      "text": "Ah, [Fremennik name]! Such glorious battle makes you feel glad of life, does it not?",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "5d092557aa0ad7aeea9888b26983ffea2e47424adf4cf00f9327eda38eab8380": {
      "text": "Quickly [Fremennik name]. Once you arrive, leave my ship and make sure you're not spotted!",
      "placeholders": [
        "[Fremennik name]"
      ]
    }
  }
}