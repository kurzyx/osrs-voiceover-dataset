{
  "ref": "gummy",
  "categoryRef": "npc",
  "title": "'Gummy'",
  "sections": [
    {
      "title": "Standard dialogue before Tower of Life",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "What are you up to?"
            },
            {
              "speaker": "'Gummy'",
              "text": "Rock, Paper, Scissors. Can't you tell?"
            },
            {
              "speaker": "Player",
              "text": "It was more of a rhetorical question."
            },
            {
              "speaker": "'Gummy'",
              "text": "Rhetora-what?"
            },
            {
              "speaker": "Player",
              "text": "Shouldn't you be working?"
            },
            {
              "speaker": "'Gummy'",
              "text": "We are. It's team building."
            }
          ]
        }
      ]
    },
    {
      "title": "Standard dialogue after Tower of Life",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "You winning?"
            },
            {
              "speaker": "'Gummy'",
              "text": "It's a draw at the moment. First it was best of three, then it was best of five."
            },
            {
              "speaker": "Player",
              "text": "And now?"
            },
            {
              "speaker": "'Gummy'",
              "text": "Best of a hundred and one."
            }
          ]
        }
      ]
    }
  ]
}