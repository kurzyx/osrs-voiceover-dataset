  "textByHash": {
    "0b5627f288a7adb2c18a8cfa723cfe0ef42bb40580279318b65f0bbe4f17cb89": "Yeah! You can't kill us all!",
    "339cd9040a4795ca63d1d08a82ee9c615be77c255a396048e74ea86fa182ddfc": "The Council is corrupt!",
    "34e5a0c883c262d302dc017f3ecd41f9a05d6b8e8e13ca644b39d4e53da82f6f": "We want answers!",
    "385290d601473ea9dab3516f5a5fb109ac8c19d18bc18c3873bbf6c478ce733e": "Laws set by your false Council! If you really served Kourend, you wouldn't be here defending those monsters!",
    "4d580ab67f13cd2b119041d4c8dd2c7900b21cff457e91d6089f2417aa85815f": "We won't be denied!",
    "5694f0be910931e74c3f9a8e10667bf21b1863dbde7d383997949afdea059309": "That's right, hold the line! Show everyone who you really serve!",
    "681de3224fe1e343ab6a7a38c5613cb29d159391e7824b34a2dcb5bf913ca6de": "Down with the Council!",
    "71c55e74c19c11f1461f714ad88c36c2a4c34b847322d6cb8ca5498641ad0105": "Or what? You'll kill me? Go on! I dare you to do it! See what happens!",
    "8ce38c94d7a4778cc263a0f1dbf83dcd058393e7a41b80d36b846fa9913fba94": "Democracy is a lie!",
    "9501b27261d95100724cbe0a00ab06735aa3c98b5b1668432672ceeafbe72d53": "The Council must answer us!",
    "9546b7cd7eecf6a8c218e1564ce6f3997d99dc30d92b77d178da87dd6b3336ee": "We want a King!",
    "e0819d641b740810d5f6beebb2effd045a6c4b4971e74b4f3d3ab05c061ae715": "Power for the people!",
    "f60a792f0faf6dfa4a62bdc25c4e044b45438f044410523913bf5cf46f0bd4ac": "A King for Kourend!",
    "f67c2fab78eb48d9e6d192fe44bb0cc14152ced2855b26e6f83f29595a2386a6": "It's time for a King!"
  }
}