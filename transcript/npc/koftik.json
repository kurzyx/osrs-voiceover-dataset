          "title": "After Underground Pass, inside Iban's temple",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello Koftik."
                },
                {
                  "speaker": "Koftik",
                  "text": "Hello [player name], how's things?"
                },
                {
                  "speaker": "Player",
                  "text": "These traps don't get any easier. But I'm alright, thanks."
                },
                {
                  "speaker": "Koftik",
                  "text": "Good to hear."
