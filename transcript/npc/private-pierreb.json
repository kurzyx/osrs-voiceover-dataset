        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello. So you're just a private?"
            },
            {
              "speaker": "Private Pierreb",
              "text": "Show some respect! It's more than you'll achieve."
            },
            {
              "speaker": "Player",
              "text": "I beg to differ. I'm in perfect shape!"
            },
            {
              "speaker": "Private Pierreb",
              "text": "Prove it!"
            },
            {
              "speaker": "Player",
              "text": "How?"
            },
            {
              "speaker": "Private Pierreb",
              "text": "Give me five star-jumps!"
            },
            {
              "speaker": "Private Pierreb",
              "text": "Five sit-ups."
            },
            {
              "speaker": "Private Pierreb",
              "text": "Run on the spot!"
            },
            {
              "speaker": "Private Pierreb",
              "text": "Okay. Maybe you have what it takes. Best you speak with the captain."
            }
          ]
        }
      ]
    }
  ]
