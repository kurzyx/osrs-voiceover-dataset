{
  "ref": "klank",
  "categoryRef": "npc",
  "title": "Klank",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "After completing Underground Pass",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello Klank."
                },
                {
                  "speaker": "Klank",
                  "text": "Hello again adventurer, so you're still around?"
                },
                {
                  "speaker": "Player",
                  "text": "Still here!"
                },
                {
                  "speaker": "Player",
                  "text": "Have you any more gauntlets?"
                },
                {
                  "speaker": "Klank",
                  "text": "Well..yes, but they're not cheap to make. I'll have to sell you a pair..."
                },
                {
                  "speaker": "Player",
                  "text": "How much?"
                },
                {
                  "speaker": "Klank",
                  "text": "5,000 coins."
                },
                {
                  "speaker": "Player",
                  "text": "5,000, you must be joking!"
                },
                {
                  "speaker": "Klank",
                  "text": "We don't joke down here friend..."
                },
                {
                  "speaker": "Player",
                  "text": "Okay then, I'll take a pair."
                },
                {
                  "speaker": "Klank",
                  "text": "There you go... I hope they help."
                },
                {
                  "speaker": "Player",
                  "text": "I'll see you around Klank."
                },
                {
                  "speaker": "Player",
                  "text": "Oh dear, I haven't got enough money..."
                },
                {
                  "speaker": "Klank",
                  "text": "Sorry, I can't sell them any cheaper than that."
                },
                {
                  "speaker": "Player",
                  "text": "Take care Klank."
                },
                {
                  "speaker": "Klank",
                  "text": "You too adventurer..."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
}