            {
              "speaker": "Hendor",
              "text": "Hello there! If you have any ores to trade I'm always buying."
            },
            {
              "speaker": "Player",
              "text": "Why don't you ever restock your shop?"
            },
            {
              "speaker": "Hendor",
              "text": "The only ores I sell are the ones that are sold to me."
            },
            {
              "speaker": "Hendor",
              "text": "Anything else?"
            },
            {
              "speaker": "Player",
              "text": "See you later."
            },
            {
              "speaker": "Hendor",
              "text": "Until next time."
            }
          ]
        }
      ]
    }
  ]
