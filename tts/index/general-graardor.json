  "textByHash": {
    "080274aa62abd0e834bbd3a6c690d919c4202b8a74512e0791920dc267d9cd72": "For the glory of the Big High War God!",
    "240ee85f9de80695f13aa86e1e8421694ba29cb0b923f0245c36a3ea3a3e329f": "We feast on the bones of our enemies tonight!",
    "27061a30918da4482179ab2d4ee2cd0bacc813fe851b4fc98b0164befb2133ee": "Split their skulls!",
    "58ad59f26fc228ad7868a8b65d0190ed3ba3a895d47feef7c4cad7b05cceb6d4": "CHAAARGE!",
    "64e1b5e1db200345821af1eb75707ce6e6027269f4da8c55f261a4a3fc75c133": "GRRRAAAAAR!",
    "99038c919a90cd819b8252cf9eab2626c9e68a95c88ad15456edf1168b1a48dd": "All glory to Bandos!",
    "b217dbda325e09ef11e8a2953871f00ae58111f38cafece55ee62eabeab4c20f": "Break their bones!",
    "cbb6ee30604dac6a9d91d659010c0a143585ca0cc367cd735dc71842962de971": "Death to our enemies!",
    "f28f15b12184576bb76bddd40ff0e14a1a861c0b22cb40b200c2c270d02f7cc0": "Crush them underfoot!",
    "f349f0b9f6bb0cb7cbeb0ab49c864221e64565d2313a00bd4ddd4df455948d65": "Brargh!"
  }
}