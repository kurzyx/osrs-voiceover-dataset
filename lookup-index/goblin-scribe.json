  "hashesWithUnresolvedText": {
    "8d9cfc23f284d0fd1f630a397cb2f73ee119dabaa290adfae2f5b5df021ccffe": {
      "text": "Ah, hello Zanik, hello [player name]. How is the dig going?",
      "placeholders": [
        "[player name]"
      ]
    },
    "13f2ba1a5fe5a8687a33ff231837aeb7e2c80d1fe0550ccde70e71f395c8054b": {
      "text": "Wait a moment. [player name], didn't you say you talked to some surface goblins when you were trying to find your way through our mines?",
      "placeholders": [
        "[player name]"
      ]
    },
    "35c14b3ecfde20784b0a97f49335eea0f752cae4c8f7684d5fc6cd64cb9d4de5": {
      "text": "[player name]? What a terrible, fear-inducing name!",
      "placeholders": [
        "[player name]"
      ]
    },
    "1d46577787887cf6668996fea2f8c95b76111315a318b13398bf815fe0598e33": {
      "text": "Before Dorgesh-Kaan, the Dorgeshuun lived on the surface with many other goblin tribes. All goblins were ruled over by an evil god called [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "3b24ca8fbed74509119f9874b16ff2bbd945ce0a5e7982728938854a16b0e729": {
      "text": "However, a human named [player name] found his way through the caves and made contact with the miners.",
      "placeholders": [
        "[player name]"
      ]
    },
    "1dbcc3409c75747858e73f473fa0b9690f0dd9779c9c2e2bd534725f2a7fd12e": {
      "text": "However, a human named [player name] found her way through the caves and made contact with the miners.",
      "placeholders": [
        "[player name]"
      ]
    },
    "f659bcbfb68ff0e333f52c87d86d018b33ed30773e1c72caa07abd7a32640d29": {
      "text": "However, a human named [player name] found their way through the caves and made contact with the miners.",
      "placeholders": [
        "[player name]"
      ]
    },
    "ffb148d9de9861e76c95ce3ac1bf6a4031a6316bac30a16f1329147025d9339d": {
      "text": "The Council sent Zanik to explore the surface to see if the H.A.M. group was plotting anything. With [player name]'s help, Zanik defeated a H.A.M. plot to flood Dorgesh-Kaan.",
      "placeholders": [
        "[player name]"
      ]
    },
    "85efeda6228f3de13b395cfa76c13590f902784f6aa0212de673cb3579587c80": {
      "text": "The Council sent Zanik to explore the surface to see if the B.A.C.O.N. group was plotting anything. With [player name]'s help, Zanik defeated a B.A.C.O.N. plot to flood Dorgesh-Kaan.",
      "placeholders": [
        "[player name]"
      ]
    },
    "cff896e211537c9e280228cc94fdaab0a95acb0c883534c65d519b49d5d4315d": {
      "text": "The Council sent Zanik to explore the surface to see if the P.O.R.K. group was plotting anything. With [player name]'s help, Zanik defeated a P.O.R.K. plot to flood Dorgesh-Kaan.",
      "placeholders": [
        "[player name]"
      ]
    },
    "97bb8f528aba8c30956d084acd15f440fa81e1d8e7a2452ded5d16dc4d8c491f": {
      "text": "The Council sent Zanik to explore the surface to see if the B.E.E.F. group was plotting anything. With [player name]'s help, Zanik defeated a B.E.E.F. plot to flood Dorgesh-Kaan.",
      "placeholders": [
