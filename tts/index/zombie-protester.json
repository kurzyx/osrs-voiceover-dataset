{
  "ref": "zombie-protester",
  "speakerRefs": [
    "zombie-protester"
  ],
  "textByHash": {
    "0409bec50845520e2c0104d4a782915b08eaed1a59b7e66dbd127742beeed03b": "Arrrrrrrrrr!!!",
    "05d6aac5b87f929bb9e19c81a3cddbcf7ac8e89b3622b4c91bb329450e8449cb": "Yer rum or yer brains!",
    "1b0902696b8f66db7e4a7063bb6c0ab52247641d027ceb739b33e2a7181affcc": "Rum! Rum! Rum!",
    "23f355262bc5af9827ae4e8f86e3859574b24baa8acc25b0c9f31a15d5c050e7": "Ye'll never beat us all!",
    "29b88f1242dbb2ec3ce7d65874419d9402c855a7adc2a04a12832d7b015a24db": "Whadda we want? Rum!",
    "5740676cbb8984798d3ed3594b023dbcc81030c5e700e2f9b11f2c44ce816be0": "Drink!",
    "58c52c85241e9d275406c1c6737be75151666385a93ce1de6a36d3b924a2b100": "Rum, rum, we want rum!",
    "5f055c137cf7457be671366e81e1a64d8f8059811db1a6a915b9af6967e83128": "Good huntin'!",
    "625285751c3c1c3af588c74ebcebf728f62bdb252168bfb7dc1f6e7d763c8b39": "Give us yer rum, ye scurvy dog!",
    "64c23d1dc9b7f65a8181f2384fdf9aa8ee0eba42319faa3d001dd6ed685ac388": "ARRR!",
    "6f75f717fce314430fe659ea7819831ab93320ea4cbd7ace0edfcc9349a9fc93": "Where d'ye think yer goin?",
    "9ae3891da18b0b7cebdb7789553646fe36a99efbbfb874bf82fdd9f33b83b4bb": "Give us rum or give us death!",
    "bbd7592c0435a1ace30a592ab610f9d73b370c63a710c5576e08709f2986ec7c": "Arrrr! Tis yerself! Have a drink!",
    "be3670535df80381774cdd9f83654fdb5bac30d0ab1277947d47751543a66dbb": "When do we want it? Now!",
    "c044436e0a1217a1a46e2800d2591a52d0bf8d3f845e0325320af64df1b724d2": "Spare us a drop, you scurvy dogs!",
    "de30a1b370116e27fa07d2e5e0df44371eb521b803c64ef62140e47d030b8fd5": "Arr! Come back here!",
    "eb2a8372fcdf0d80e7e3f46b3f94efce6322b3ee6b03abda3cce5e684f0318b4": "Ye'll never get away!",
    "ef627505177e541698b004196d985cb1a346af86099becf2e8b5e85ee3441dca": "Arr!",
    "fe80ba8fa0fb60d19c15b3b36bfad8a9b49013e9db39aaeac824671b64411c1b": "United we stagger!"
  }
}