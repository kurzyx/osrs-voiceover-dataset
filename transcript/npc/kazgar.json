  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Kazgar",
              "text": "Hello, surface-dweller."
            },
            {
              "speaker": "Player",
              "text": "Who are you?"
            },
            {
              "speaker": "Kazgar",
              "text": "Mistag posted me here when surface-dwellers started visiting the mine. If you have business in the Dorgeshuun mines I will guide you through the tunnels."
            },
            {
              "speaker": "Player",
              "text": "Can you show me the way to the mines?"
            },
            {
              "speaker": "Kazgar",
              "text": "All right. Follow me."
            },
            {
              "speaker": "Player",
              "text": "Can you show me the way to the water mill cellar?"
            },
            {
              "speaker": "Kazgar",
              "text": "Of course!"
            },
            {
              "speaker": "Player",
              "text": "Maybe some other time."
            },
            {
              "speaker": "Player",
              "text": "Good bye, cave-dweller."
            }
          ]
        }
      ]
    }
  ]
}