    {
      "title": "Using a Forthos tome on Logosia",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Logosia",
              "text": "I have not seen this before. Your donation to the library is appreciated."
            },
            {
              "speaker": "Player",
              "text": "You can have this tome which I discovered aswell."
            },
            {
              "speaker": "Player",
              "text": "You can have these tomes which I discovered aswell."
            },
            {
              "speaker": "Logosia",
              "text": "Again, your donation to the library is appreciated"
            },
            {
              "speaker": "Logosia",
              "text": "Your contributions to the library have been noticed. We would like to reward you for your assistance."
            },
            {
              "speaker": "Logosia",
              "text": "If you find any spare pages for these books I would be willing to give you 1,000 gold for each one. Duplicate sources of information are always useful."
            },
            {
              "speaker": "Player",
              "text": "I'll keep an eye out."
            },
            {
              "speaker": "Logosia",
              "text": "Enough talk now, Shhhh!"
