      ]
    },
    "a8099a36f619059fcbe80113dfedda30a2e79d31719c1fef0498a128dc1244fb": {
      "text": "No? That's unusual for you, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "6af3bc3d50130056f883ec050756eb37d3fd7acd035a4810e6dc8f922afc1c63": {
      "text": "Blasidar does not command the [company name].",
      "placeholders": [
        "[company name]"
      ]
    },
    "e63f33be4feb90eadc1fbc89d6e565fab325b46562668926fd716f3fe465718b": {
      "text": "That is not a request that I can grant you yet, [player name], even though I am impressed with you so far.",
      "placeholders": [
        "[player name]"
      ]
    },
    "c412e12d8e07d7835d5993731826e5db9e56377cfcac1888660827964109017b": {
      "text": "The [company name] appreciates what you have done so far, [player name], but the director will only speak to the most loyal of followers.",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    },
    "5daa5c7193738fd3195ecb0ebf4d86626bd5eb518ce640e204fc8d721c0b0d53": {
      "text": "Keep up what you're doing, [player name]! The more you help us out, the more we appreciate you!",
      "placeholders": [
        "[player name]"
      ]
    },
    "7e07efc31b162a19e8eb786b3869040e31b792b216df9c8ecb3ec57aa3cd2116": {
      "text": "Why, naturally [player name]! The director is standing right over there!",
