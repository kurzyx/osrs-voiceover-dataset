  "title": "Bartender (Dragon Inn)",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Bartender",
              "text": "What can I get you?"
            },
            {
              "speaker": "Player",
              "text": "What's on the menu?"
            },
            {
              "speaker": "Bartender",
              "text": "Dragon Bitter and Greenman's Ale, oh and some cheap beer."
            },
            {
              "speaker": "Player",
              "text": "I'll give it a miss I think."
            },
            {
              "speaker": "Bartender",
              "text": "Come back when you're a little thirstier."
            },
            {
              "speaker": "Player",
              "text": "I'll try the Dragon Bitter."
            },
            {
              "speaker": "Bartender",
              "text": "Ok, that'll be two coins."
            },
            {
              "speaker": "Player",
              "text": "Oh dear. I don't seem to have enough money."
            },
            {
              "speaker": "Player",
              "text": "Can I have some Greenman's Ale?"
            },
            {
              "speaker": "Bartender",
              "text": "Ok, that'll be ten coins."
            },
            {
              "speaker": "Player",
              "text": "Oh dear. I don't seem to have enough money."
            },
            {
              "speaker": "Player",
              "text": "One cheap beer please!"
            },
            {
              "speaker": "Bartender",
              "text": "That'll be 2 gold coins please!"
            },
            {
              "speaker": "Bartender",
              "text": "Have a super day!"
            },
            {
              "speaker": "Player",
              "text": "Oh dear. I don't seem to have enough money."
            }
          ]
        }
      ]
    }
  ]
