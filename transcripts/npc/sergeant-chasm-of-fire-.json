{
  "ref": "sergeant-chasm-of-fire-",
  "categoryRef": "npc",
  "title": "Sergeant (Chasm of Fire)",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "Before being given advice",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Sergeant",
                  "text": "Hello."
                },
                {
                  "speaker": "Player",
                  "text": "What are you doing here?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "Not a lot."
                },
                {
                  "speaker": "Player",
                  "text": "That's a big chasm you're standing by."
                },
                {
                  "speaker": "Sergeant",
                  "text": "Yep."
                },
                {
                  "speaker": "Player",
                  "text": "What did you think of the coronation?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "Pretty good."
                },
                {
                  "speaker": "Player",
                  "text": "That's a nice looking axe. Is it heavy?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "Thanks. Not really."
                },
                {
                  "speaker": "Player",
                  "text": "Interested in doing any trading?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "I've got everything I need."
                },
                {
                  "speaker": "Player",
                  "text": "I have vital information pertaining to the cult of Yama."
                },
                {
                  "speaker": "Sergeant",
                  "text": "You should speak to the lieutenant."
                },
                {
                  "speaker": "Player",
                  "text": "That's it!"
                },
                {
                  "speaker": "Sergeant",
                  "text": "What?"
                },
                {
                  "speaker": "Player",
                  "text": "Why don't you want to talk to me!"
                },
                {
                  "speaker": "Sergeant",
                  "text": "I'm confused."
                },
                {
                  "speaker": "Player",
                  "text": "I've been trying to make conversation with you and I feel like I'm getting nowhere."
                },
                {
                  "speaker": "Sergeant",
                  "text": "I'm sorry. I didn't mean to make you feel that way. I'm not a very chatty person."
                },
                {
                  "speaker": "Sergeant",
                  "text": "Your feelings are valid, and you deserve to be heard. That said, it might be good to examine your reaction."
                },
                {
                  "speaker": "Player",
                  "text": "Thank you. What do you mean?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "Would you agree that people aren't under any obligation to talk to anyone else?"
                },
                {
                  "speaker": "Player",
                  "text": "I suppose so."
                },
                {
                  "speaker": "Sergeant",
                  "text": "With us, it was just a misunderstanding. With somebody else, you might have been pushing a boundary."
                },
                {
                  "speaker": "Sergeant",
                  "text": "It risks coming off as having a bit of a 'main character' complex."
                },
                {
                  "speaker": "Player",
                  "text": "That's a fair point. Thank you for explaining it in that way."
                },
                {
                  "speaker": "Sergeant",
                  "text": "No problem. Have a good day, friend."
                },
                {
                  "speaker": "Player",
                  "text": "Goodbye."
                },
                {
                  "speaker": "Sergeant",
                  "text": "Goodbye."
                }
              ]
            }
          ]
        },
        {
          "title": "After being given advice",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello. Everything well?"
                },
                {
                  "speaker": "Sergeant",
                  "text": "Hello. Yes, thank you."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
}