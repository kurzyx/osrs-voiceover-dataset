  "hashesWithUnresolvedText": {
    "fecd9e70e41939c2f21be26edb3e993c5827d4ef366782fd175974223784e300": {
      "text": "Pleased to meet you, [player name]. I'm Anne, and this is Will.",
      "placeholders": [
        "[player name]"
      ]
    },
    "bb1e5dc1627c2149b62d5de8bdd15f49e9f6ee9c317a34a9d54d5c3c13008a41": {
      "text": "Ah, there you are, [player name]. Are you ready to hop aboard our ship?",
      "placeholders": [
        "[player name]"
      ]
    },
    "7b9228c0fe20e16da2197a74c2836e3e7645a24988fa4bde7f0c74af74898ca9": {
      "text": "Well, good news, [player name], because that's where you come in! You're our new helm!",
      "placeholders": [
        "[player name]"
      ]
    },
    "7270b187736151b24a471d059791a8b046df31b16643f1c72cb8609317d15493": {
      "text": "Over to you, [player name]! Take the helm when ready.",
      "placeholders": [
        "[player name]"
      ]
    },
    "2d58cf9ddf4befa90180c01d0cf6195b65b1f2ba09d511501edac0007148ae68": {
      "text": "This is your bit, [player name]! Take the helm when ready.",
      "placeholders": [
        "[player name]"
      ]
    },
    "28b8bffa0a6d86223916117a995e3017022e99a0e4e78fc5a573e0766b1fe5d0": {
      "text": "This isn't the can-do attitude we need, [player name], but fine, we'll go back...",
      "placeholders": [
        "[player name]"
      ]
    },
    "0f383158dd0bd30ad4ef08c874d235e0ea701f09685e79922311f4284908c066": {
      "text": "Hello there, [player name]. Shall we hop back aboard our ship?",
      "placeholders": [
        "[player name]"
      ]
    },
    "940fb76a56e543d33c82f039365920005819ab99540ca22fb783ddbe68f0a5bf": {
      "text": "You need to trim the sails, [player name]! We need to catch that wind!",
      "placeholders": [
        "[player name]"
      ]
    },
    "564ea245b7f13528e2bfda9eade2300c860fd04ab96860d1c2b24075e978315a": {
      "text": "[player name]! The sails need trimming! Don't miss out on that wind!",
      "placeholders": [
        "[player name]"
      ]
    },
    "34b1f29588a6dd21c53e9efbad68cc6c5b8fde2ce1272cb08df0c2876d8c8b81": {
      "text": "When you're ready, [player name], just lower the salvaging hook and let's see what we can find!",
      "placeholders": [
        "[player name]"
      ]
    },
    "d080d76679baff721d1b5d319e905320705db0ecbce942d29ebd72970d80e675": {
      "text": "Time for some salvaging, [player name]! When you're ready, just lower the salvaging hook and let's see what we can find!",
      "placeholders": [
        "[player name]"
      ]
    },
    "b59ca74593e6fd90a5532351ed650ae5fe8c01753552794c57ec5a9a00205265": {
      "text": "Sorry, [player name]. If it's any consolation, you did a great job! Unfortunately, we just have to let you go.",
      "placeholders": [
        "[player name]"
      ]
    }
  }
