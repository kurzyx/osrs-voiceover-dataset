              ]
            }
          ]
        },
        {
          "title": "Other frog 2",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Frog",
                  "text": "Don't talk to me! Speak to the frog [prince/princess]!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Other player's frog",
      "sections": [
        {
          "title": "Other frog 1",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Frog",
                  "text": "The frogs do not need your help right now."
                }
              ]
            }
          ]
        },
        {
          "title": "Other frog 2",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Frog",
                  "text": "Don't look at me, I'm just a frog. Ribbit! Ribbit!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Overhead dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Frog",
              "text": "Greetings from the [prince/princess], [player name]!"
            },
            {
              "speaker": "Frog",
              "text": "Talk to the frog [prince/princess], [player name]!"
            },
            {
              "speaker": "Frog",
              "text": "The frog [prince/princess] needs your help, [player name]!"
            },
            {
              "speaker": "Frog",
              "text": "Please respond to the frog [prince/princess], [player name]!"
            },
            {
              "speaker": "Frog",
              "text": "Maybe later."
            }
          ]
        }
      ]
    },
    {
      "title": "Frogland",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Frog",
              "text": "Are you ready to leave now?"
            },
            {
              "speaker": "Player",
              "text": "Yes, I'd like to leave now."
            },
            {
              "speaker": "Player",
              "text": "No, I'd rather stay."
            }
          ]
        }
      ]
