    },
    {
      "title": "After the Fremennik Trials",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Yrsa",
              "text": "Hi. You wanted to buy some clothes? Or did you want to makeover your shoes?"
            },
            {
              "speaker": "Yrsa",
              "text": "It's free to change your shoes here. You can choose a colour as well as a style, since I'm also stocking boots imported from the elven lands."
            },
            {
              "speaker": "Yrsa",
              "text": "Just select the model you would like from this catalogue."
            },
            {
              "speaker": "Yrsa",
              "text": "Hey! They look great!"
            },
            {
              "speaker": "Player",
              "text": "Thanks!"
            },
            {
              "speaker": "Yrsa",
              "text": "Nice choice!"
            },
            {
              "speaker": "Player",
              "text": "Thanks!"
            },
            {
              "speaker": "Yrsa",
              "text": "Good call!"
            },
            {
              "speaker": "Player",
              "text": "Thanks!"
            },
            {
              "speaker": "Yrsa",
              "text": "I think they suit you!"
            },
            {
              "speaker": "Player",
              "text": "Thanks!"
            },
            {
              "speaker": "Player",
              "text": "Neither thanks."
            },
            {
              "speaker": "Yrsa",
              "text": "As you wish."
            }
          ]
        }
      ]
    }
