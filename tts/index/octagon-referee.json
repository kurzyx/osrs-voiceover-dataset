    "0cc228c9559211d7526db94cabeb865cb01f1af482fe74104cc4103678f135de": "Stay inside your triangle!",
    "14934ebe68f727abeaad1e1a8af45c302e03077b0b9fd66fbed62f88b718b41d": "Go again please.",
    "154e8091b94f753085b719b732bc9b9d8d8dc3e4e0c16161b6a62ec76d5ecfb9": "Keep it civil!",
    "15f891b25f4e06d4eee0b48694e2f39ca5ad203b2f431db503016cd72ec06ebb": "Come on, come on!",
    "16c04d9acb1ac679f4c6de6ddebeb5c378477d1be50433729fc6ac7508d1aae1": "Next bid please!",
    "21bc432c21d585955f9b832aa13be4b9eebf6dac38f1f52f818f4f0fd5cf5d6f": "I can't help you!",
    "2545ad644acbd370130d131571c363ace416b2c4f22644183190d1892e7ef980": "Clear out!",
    "63656ef68e8e0257dba99b9ff5e719e57e8c6641687cb8242f1dcf6dd3bcddcc": "Objection overruled!",
    "888dc42ca06415259cb0bef6b32d52ce9d7c1376b3db5ae43f6fa6ceeee101e0": "Need an offer, now!",
    "a083b73dec5a4c6b0826a7bd4e5ede7f51b7cfc0b9fd13075b7dd8f4ff4d8812": "Who's next?",
    "ac71236926b976fea3a3fc21614f78e503c605b7fa800f25d03c2423d079ef4a": "Stay out of the octagon center!",
    "cb7dc8574f886dae15090253d6bf77711eb21f7f8740caebb6cb1d65470f3b17": "Hold on there!",
    "f77977d05cb2b04e94db5e5182807157ccac5c83a0cf11fb54d19c4fbe5ff17b": "Talk to the secretaries, not to me!"
  }
