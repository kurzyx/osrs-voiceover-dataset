        }
      ]
    },
    {
      "title": "When disguised",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "What are you doing?"
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "Minding my own business. You should do the same."
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "Yes?"
            },
            {
              "speaker": "Player",
              "text": "..."
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "..."
            },
            {
              "speaker": "Player",
              "text": "..."
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "Did you want something?"
            },
            {
              "speaker": "Player",
              "text": "Nope."
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "Then why don't you get lost?"
            },
            {
              "speaker": "Mordan Nikazsi",
              "text": "What do you want?"
            },
            {
              "speaker": "Player",
              "text": "Nothing."
            },
            {
