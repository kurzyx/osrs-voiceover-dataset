          "lines": [
            {
              "speaker": "Roy",
              "text": "Good day sir. Could I interest you in one of our finest Bloody Bracers? It's a local speciality."
            },
            {
              "speaker": "Player",
              "text": "One Bloody Bracer please."
            },
            {
              "speaker": "Roy",
              "text": "That will be 99 coins."
            },
            {
              "speaker": "Player",
              "text": "I don't have that much."
            },
            {
              "speaker": "Roy",
              "text": "Then for now, our business is at an end."
            },
            {
              "speaker": "Roy",
              "text": "That will be 99 coins."
            },
            {
              "speaker": "Player",
              "text": "Here you go."
            },
            {
