{
  "ref": "commander-zilyana",
  "speakerRefs": [
    "commander-zilyana"
  ],
  "textByHash": {
    "b04716c44c4e4e338747508771277f8afcffc5677e5c03176ed17fd81d13fb63": "All praise Saradomin!",
    "a7eba7062ae049e5534a8b38608c525637620d841961ff54baaf568d11e2c89b": "Slay the evil ones!",
    "35c36b7f464c0f9d3a8a34b0361de273f242e2f673ec4a3fae3af541958ab396": "Death to the enemies of the light!",
    "12b0ce6c6e6747d26487696854595344c5c8504096e401b1d11c6cbc8f8d8cf1": "Saradomin lend me strength!",
    "39f503039c5d843d2f4a821348af8e9653701e7323ae85b68a78e86639689f81": "Saradomin is with us!",
    "93b7a2e3601a9a55a26a65f6d7e563b9dc23dfe23cc9b2f6de9ec0f7d3a218bd": "Forward! Our allies are with us!",
    "4d847fc837ef719502d45af0dc746a608b47aafe85f0b791732772160e6390ea": "Good will always triumph!",
    "cf17bac138eacd0e3c57517f1e174651be8de261ace0714439d48b1454adee22": "May Saradomin be my sword!",
    "5008950115205fb6c754a676e5ae6e82787d66eae7659bce0c7427100fca2694": "In the name of Saradomin!",
    "7421dee7972c109b423337251b1daa45fd0b3c597571c5c08ca4e72114f180e4": "Attack! Find the Godsword!"
  }
}