{
  "ref": "lector-gura",
  "categoryRef": "npc",
  "title": "Lector Gura",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Lector Gura",
              "text": "May the chaos rot your soul."
            },
            {
              "speaker": "Player",
              "text": "Who are you?"
            },
            {
              "speaker": "Lector Gura",
              "text": "My name is Gura."
            },
            {
              "speaker": "Player",
              "text": "Nice to meet you Gura, my name is [player name]."
            },
            {
              "speaker": "Lector Gura",
              "text": "Did you want something?"
            },
            {
              "speaker": "Player",
              "text": "What have you got?"
            },
            {
              "speaker": "Lector Gura",
              "text": "No, I mean... Nevermind."
            },
            {
              "speaker": "Player",
              "text": "What do you do here?"
            },
            {
              "speaker": "Lector Gura",
              "text": "I speak the teachings of Zamorak."
            },
            {
              "speaker": "Player",
              "text": "So, fire and brimstone?"
            },
            {
              "speaker": "Lector Gura",
              "text": "Amongst other things."
            },
            {
              "speaker": "Player",
              "text": "Like?"
            },
            {
              "speaker": "Lector Gura",
              "text": "Well, traveller, if you hadn't already noticed, a foul plague has beset this town. Not only that, but there is talk of a great evil stirring below..."
            },
            {
              "speaker": "Player",
              "text": "I see... So is the plague contagious? Because I could be elsewhere, now you mention it."
            },
            {
              "speaker": "Lector Gura",
              "text": "Well, we're taking precautions, but you should be fine. Providing you don't stick your nose where it doesn't belong, that is."
            },
            {
              "speaker": "Player",
              "text": "Keep my nose to myself, gotcha!"
            },
            {
              "speaker": "Player",
              "text": "Bye!"
            },
            {
              "speaker": "Lector Gura",
              "text": "May the flames guide you."
            },
            {
              "speaker": "Player",
              "text": "I'm... sure they will."
            }
          ]
        }
      ]
    }
  ]
}