              "lines": [
                {
                  "speaker": "Antonia",
                  "text": "Hello there. Interested in sailing to the island of Aldarin? It's 20 coins for the journey."
                },
                {
                  "speaker": "Player",
                  "text": "Yes please."
                },
                {
                  "speaker": "Antonia",
                  "text": "Come back when you've got 20 coins for me."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                },
                {
                  "speaker": "Antonia",
                  "text": "Fair enough."
                },
                {
                  "speaker": "Player",
                  "text": "How about I pay you nothing at all..."
                },
                {
                  "speaker": "Antonia",
                  "text": "Sounds good to me. Hop aboard!"
                }
              ]
