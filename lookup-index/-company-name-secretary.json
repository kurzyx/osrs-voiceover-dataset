    "44223a6a5b20cafe22fc12f699c7aee550f0e5d4560e45d3088115434ccacfe9": {
      "text": "I'm afraid I have no more work to offer you, [player name], please speak to the director.",
      "placeholders": [
        "[player name]"
      ]
    },
    "c02c4fff5e884a2202b53ad41542f34f7e6d940fddaff856c847da3aaf1defef": {
      "text": "Yes, the [company name] always has work to do!",
      "placeholders": [
        "[company name]"
      ]
    },
    "9490d93e1f2199c6235165fc6b284f7c4e9b87ad0e9caaecb57612aecea4e61d": {
      "text": "Oh yes, as you know the [company name] always has work!",
      "placeholders": [
        "[company name]"
      ]
    },
    "41d997fd89073d8783eb8fe6eb482644fb189d01a3379f051139c659b2ebbec9": {
      "text": "Of course, we reserve our best tasks just for you, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "38074737e0c5804468d997f8239ef1380bf9f55a9b0bf02c3be15ba348ca991f": {
      "text": "The [company name] is pleased to offer more work to an eager worker such as yourself, [player name]!",
