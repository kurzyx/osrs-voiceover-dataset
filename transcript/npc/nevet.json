            {
              "speaker": "Nevet",
              "text": "Hello! Looking to buy?"
            },
            {
              "speaker": "Player",
              "text": "What are you selling?"
            },
            {
              "speaker": "Nevet",
              "text": "A selection of items for those who partake in variety! That said, be aware that I have little interest in coins..."
            },
            {
              "speaker": "Player",
              "text": "Right..."
            },
            {
              "speaker": "Nevet",
              "text": "So, looking to buy?"
            },
            {
              "speaker": "Player",
              "text": "Yes please."
            },
            {
              "speaker": "Player",
              "text": "I'll pass."
            },
            {
              "speaker": "Nevet",
              "text": "Fair enough."
            }
          ]
        }
      ]
