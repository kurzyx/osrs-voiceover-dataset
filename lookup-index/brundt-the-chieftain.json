  "hashesWithUnresolvedText": {
    "7d94e2ac8799d658c220abeb4362c960f9324c2ceee9cc1aa6d91d94860d201e": {
      "text": "Greetings, [fremennik name]. How are things?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "a005d1a9f9ea953351292d04c9994c72aedfd7fe824378dbe9e517e97323f951": {
      "text": "Well ask away, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "b64c87ebd38e8221005a4e80a979194861a690d43785ef9f3dd7e3d59bdc5645": {
      "text": "Do you intend to slay this beast for yourself, [fremennik name]?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "859d1e0a17f53575f7d65b44e41965139400d5f89f73ee6f7e8e1fc1c2a759d5": {
      "text": "This is no easy task, [fremennik name], but glory awaits you if you succeed.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "6c44bb88192cc304cc1ec325279365862d2464a779587c9a550ee4051110ec6c": {
      "text": "Go see Torfinn on the docks. He can take you to Ungael. Good luck, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "c3992a35c297ccb8ff1b37e97d05a32d681bf1d7da3f3448de886f90c24c457e": {
      "text": "Greetings, [fremennik name]. Have you destroyed that beast yet?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "3a62f8247bf418868229612d824c1b0720017479c9396d5a2020e57ddfb3b9f1": {
      "text": "Well if you speak to Torfinn on the docks he will take you to Ungael. Good luck, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "3b47a0cb0b51d5eae5c75dbc4ea47545aab014d1903dc906962b28e14873a9a9": {
      "text": "Greetings, [fremennik name]. Have you seen those beasts flying towards Ungael? Might be best to stay clear of that place for a while.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "d8ddff19d0568daa29d9c9af30fedec36cf3712d12377d03c66a27d4d90ebeaa": {
      "text": "You are a true warrior, [fremennik name], though I fear this may be too much even for you. You are heavily outnumbered.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "49d3ca492f809b441a15b93b07023a7784c8ff9d36fedc7ecea2a6ae83078fbf": {
      "text": "Fight alongside outerlanders? That is not typically our way, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "22f3847b256a8405bbba033d954b81a7e27bc3b01f053942f4036581791b4c7f": {
      "text": "I shall be heading there soon, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "2a9012b689ef9be42b8540304b6e45f53644ccc2a21c1250223d4ebcabb7cec9": {
      "text": "You should join us for this fight, [fremennik name]. Torfinn will take you to the fleet when you are ready.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "8c8fbe741dae48d0f7f248c4a60162b2db4855bcedcaad02efa9d38bf8bc188d": {
      "text": "Great work, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "253871be2274447a59c04fd55eaab772de06e32c56fde884294cd9ab259d88de": {
      "text": "Ah [fremennik name], many have tried, but The Moon Clan are by no means a sharing group of people. They do everything by magic, something we never use. But they are so secretive about it. If only they would share, we",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "de543fe3f35e865af0cb8bd717f742ce8286dd275057819f6ed9226411328637": {
      "text": "Yes, but you have no room to carry it. You should have thought of that before, [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "ce169316902d4d4878225a803aeb2b7ec466fd771871179c25753ad089fc379f": {
      "text": "Ah, [fremennik name]. How goes the peace talks with the accursed Moon Clan?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "12bad6bce181d359c594761aa0c443006434dfc221d68b107789b8bd659b42f6": {
      "text": "Well if it isn't [fremennik name]. I've heard of your exploits in the Lunar Isles!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "a2a3780986f883f79b095b3acebe6e2e859fbb4bb97897d06ad420d8a87c171d": {
      "text": "Amusing, [fremennik name], but as a Fremennik yourself you know better than that.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5588b580a27ac475209ac64e5b8342121974116d2fa94a8543bec39ebbddfa9a": {
      "text": "You truly have the Fremennik spirit in you, [player name]",
      "placeholders": [
        "[player name]"
      ]
    },
    "eb006a2ddaa30676c0249261c5af9e062c9b0e94c140a873628421f85f708f75": {
      "text": "As a matter of fact [fremennik name], I do have a quest for you. Are you interested?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "db4383588d105b83a9ef8c2b3a3a4c7f1073bce6300de2f0663705781dfe4150": {
      "text": "I'm a fan of your enthusiasm, [fremennik name], but-",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "78c645d944e51e6b64a6063aeb701bc6d8b13b42d3471f653bebd7afa6387091": {
      "text": "Nothing quite that fancy I'm afraid, [fremennik name]. I just need you to investigate a minor disturbance.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "898814ea9aa973c7034a9750eecdbd162abf99190b90247f09b0a9e0bf0ff260": {
      "text": "Thank you, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "751891930e59979c63889365e282b1d249f80864c400dc27f47959af891c0ce8": {
      "text": "How goes the investigation, [fremennik name]?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "b86ce4b9428c11d8a879a99c8c134175cf5f0c8fd46d00b53b5cbb908e8840db": {
      "text": "No rush, [fremennik name]. I'm sure it's nothing to worry about. Just talk to Freygerd and Reeso at the sandpit when you're ready.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "81ff308a8317a7bc588c52aa0e06abfedda63346ede8aa5c0bfb817f82b77a12": {
      "text": "[fremennik name], I'm glad you've returned! This letter you have found is very worrying and requires our utmost attention.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "f20cd062bc666452f38c17edbab221fd6f7be7c7773fbee3e3f4bf229ac0cf46": {
      "text": "[fremennik name], please read the letter and talk to me afterwards with any questions you may have.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "740743e4667564404b98384a2b7add4a31fc0877209cb7b3eca9ab7b8525cd7c": {
      "text": "We will stay strong, [fremennik name]. We'll...",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "f03a7afbf17e822514cf6e24f3dd3fe2a38b170efb3fdfd9ad819c2bbfa67651": {
      "text": "[fremennik name], you're strong. But you're no army.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "c982f8ead083588a29bbc832667f502d58f74a95ed706e1d6910f9ea84d3ddeb": {
      "text": "Well I won't deny there's been a little issue but [fremennik name] and I will soon have things back under control.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "498cf0bceed637aa31fb03f13d3da08da01d05b91547131ae9350ec05f6a6f26": {
      "text": "[fremennik name] is no outerlander! He passed our trials and is a Fremennik, just like you and I.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "8ba0e76af51c973cfa187d9462e0b2ede9065369265fcf0c87043a2e8c36833d": {
      "text": "This is outrageous! [fremennik name] is one of us!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "8a3c05ef344582bbc1d6b00c2450014936de7e808895907c1f4063119816c5ec": {
      "text": "Indeed. I'm sorry [fremennik name]. The reality is that many on the council did not take kindly to you becoming one of us. They've been looking for a good excuse to exile you ever since you arrived.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "bd7e8e7776dac51166e7d2c92775f9436a31542d17d95ae249c23218324516cb": {
      "text": "Well, [fremennik name], that's why I asked you to meet me out here. If you are to help us put a stop to this threat, you'll need to regain the trust of the council. And I think I know just how you can do that.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "afdf8b31c7db80fba1defdbe169234417bed17f62a0215dabaa388f830d7b77c": {
      "text": "Do you have any more questions about V's Shield, [fremennik name]?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "69d64c0e848a3c8e4713bb820b52cd853491c76b01b8103f88bd400973bd2481": {
      "text": "Greetings [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "9b73a54a83dd795d2429d8af880da24743d5e0329ff3aaba39615615556dbf66": {
      "text": "Hand it over then, [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "b1916db9d7fde6a946c1eb2a606cb1203342dfca1b84cb4505c8be5a83db147f": {
      "text": "[fremennik name]... This is incredible! It's as if you forged the shield from a picture. It's exactly how I imagined it from the stories!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "42ecaaa1e43705abeca27e7b719b36ec841ebccfd56149b8d878f38b594f1355": {
      "text": "I hope so [fremennik name]. I do suspect some of them may never respect you though.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "421ec9a6dc3c90b31af21b27ffa7304f7ccd2031bd2fd83a07eb0f200d28b6b9": {
      "text": "Good to see you [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "ca31eac88587ce1f94311cd54c35ecf39fffa254d75e05dda984550f1c563b7b": {
      "text": "We Fremennik know how to handle a drink, [fremennik name]. Anyway, I have some good news for you.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "7a1c3f4ecdb92dd659f5c63cdcd34cd0682555a49abbd57ac47e833979bbbcd8": {
      "text": "So you should be [fremennik name]. V was our greatest hero. There is no greater honour than to bear his shield in battle.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "abe4811831f14d8889bbeaaa7d6cbf37e816842fae1457a749e1bb959d8d99a3": {
      "text": "[fremennik name]! Get to the boat. It's time for us to go!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "6c318966cd4fae2849fa739b094ea5d52edf80838de2df08e9ffc1fc77a6d2d6": {
      "text": "This isn't good [fremennik name]. The prison has already been breached.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "990848c6b4199b7da3137b43a85832f2f2ba607bd63c28ffc2a6dff6ce783f91": {
      "text": "Hurry [fremennik name]. We can't afford to waste any time.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "28d506332386f42d06258ec8bdd77660a18db340504db86642b3b721a05488db": {
      "text": "Hurry [fremennik name]. We need to get inside before it's too late.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "1b35e8bc0564afc6aed94b0c12ea7bc3b33fbfefcc4b79fca9c983d617d39db0": {
      "text": "Good work [fremennik name]. Let's get inside and see what's going on.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "509043ff8f61a1cc34859dfc23f6f44a41e92a2e78c814d856084553b8f35bb1": {
      "text": "With me [fremennik name]! Let's kill these foul beasts!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "85e42011cb2bc84d16caaef1e9d406c2cb2ee41a7146ddc3ccae7c23da41f0e4": {
      "text": "This isn't over yet [fremennik name], the Jormungand is weak from his imprisonment! We can still stop him!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "0f9ba9f9ff59e87a6e095ac5320e7e12319eb7bd0edd6a1d1a1bf71ce178747a": {
      "text": "You will not defeat us this day! Come [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "7b1d443078a229ddf297c74351f2c76c902cb2a1017a12807bcd5c16e2f37675": {
      "text": "Turn away [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "01dfae2f1556ec999c82855205c5508c0dede361d939c88adfed5e7f5372fc75": {
      "text": "Don't look at him [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "47d4fc6f222b71fadccaa4b04a3598e6ba22a9f563899812285ddd2d461267d6": {
      "text": "[fremennik name]! Do not face him!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "07f93bc66f9279d3f57faa0e3debf4d92c7f02f296969cb485cab5d3a9e56c50": {
      "text": "Try to break free [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "fd0da133c149b206ee9a621e5d0960506eef73f96a822420d1ad4dbe1939076e": {
      "text": "[fremennik name]! You need to break loose!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "e227873cd285522d9bff7ce846ecd2cb3707d9b1fb8ef9828e39e75ade0d663e": {
      "text": "You can free yourself [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5f5d4eefec2be90a92da8c5d8e561f75f7ea2542af52ac2f2eb45f6bf0740ba6": {
      "text": "Hurry [fremennik name]! We need to get inside and stop those basilisks!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "6f8d07af2f591fc0a0bdcc1bfd9a3a03a98ca03e2ebb9c05fa6736cb5f9082b7": {
      "text": "Wait [fremennik name]! I have some things for you!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "685d1ce5f542e74ba08f29a1f0d14fef80d113306d0e8f27dfd751cb2694e655": {
      "text": "I do have some of your items here [fremennik name]. Do try to be careful with them.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5ed88cc30078df46119d0dc44ab26f7b646218642df9513af0c11040b1a88e89": {
      "text": "I'm afraid I don't have anything for you [fremennik name]. If I did have any of your items, but you died before collecting them, they'll now be lost.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "afb243c35efdedca307b75717ea949d398571b526732cd0c82b428e09696998f": {
      "text": "You worry too much [fremennik name]. If the end had begun, we'd have noticed by now. Come! Let us go and celebrate!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "0a7864daf62a8b869331d44d443d7143a72bd896db7ed065f0f8ad32fcdc2b33": {
      "text": "But it wouldn't have been possible without [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5c77b51782370f6307ec78c5b0b3f165656a4aa52cba72fbc59085805d081a87": {
      "text": "From this day onward, you are outerlander no more! In honour of your acceptance into the Fremennik You gain a new name to be known as. You will now be called [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "ec123c86dd35e294854d950d33df25194f23c24c9ed43136c6742fbbb74b0bce": {
      "text": "You are definitely a great asset to the Fremennik, [fremennik name]!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "43f83f6336ea7f06473a3458c45360f87ad3284018eef72c49e685bd2a06bf8c": {
      "text": "I don't think you have [fremennik name]. I suggest you try looking for it again.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "898a9ec2f1ab32aa595fabefc1211d8470174f99ee9170b4c58c53dd02272f7a": {
      "text": "You really should be more careful [fremennik name]. Luckily for you I found it again but you'll have to pay to get it back.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "175495986f1586903d41618267cfca334dcf58a1e4a0079741dbf33adcb4a581": {
      "text": "Here you go [fremennik name]. Use it well.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "54a4c7690cc1c8762b4730a09a7a1e9db201171d191d281e8ff514b0210c0b7e": {
      "text": "Hello again brother [fremennik name]! I hope your travels have brought you wealth and joy! What compels you to visit me on this day?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "cdb742e8c113eb514f493635d62944e92ad0133f5550d0448afcf4a1430ec65e": {
      "text": "Hello again sister [fremennik name]! I hope your travels have brought you wealth and joy! What compels you to visit me on this day?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "84a264da58c213c628307c4a0feed94fabf8a087d87239bc55c3c1325f8c6679": {
      "text": "Well met, brother [fremennik name]. It is always good to see your face in glorious Rellekka once more!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "9964a47c6cc4177fe099609d04a931a591653431a97d3dfe0694bc58496ff01b": {
      "text": "Well met, sister [fremennik name]. It is always good to see your face in glorious Rellekka once more!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "7223f1d49b12eedf2fe7deaa980d98b9d200c482622c1f8831690e584b86d014": {
      "text": "Not at the moment [fremennik name]. Rest assured, should your services to the Fremennik be required, I will call upon you.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "c58a0162d224df60275fa916d93d4ea4b3dd650af46bb71b32e3b317c8f4c1b1": {
      "text": "Aye, that it is brother [fremennik name]. Should you desire one of your own, you should go to Skulgrimen's shop and see what they have available!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "9f8cc3244574cb01096930a51420d59bb61adb84ae956211d4a57006d7bc8d75": {
      "text": "Aye, that it is sister [fremennik name]. Should you desire one of your own, you should go to Skulgrimen's shop and see what they have available!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "f7826e34592d8649b909244315a9d39112abc34aa8a90336535bef04466e228e": {
      "text": "Why, of course [fremennik name]! Do not say 'your people' like that, for you are now a Fremennik yourself! What did you want to hear of?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5d0ec68e501744bbad890ee373ba3770d60b6f737acf5680c5455edc6c3f33c6": {
      "text": "So, [fremennik name]. Was there anything more you wished to hear?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "5a974df9af655edb97be12b705f8e1b11de872e513a4025e8ea4795ba2b9e1dc": {
      "text": "My affairs are concentrated mostly on Rellekka, so my knowledge is not great, but I will happily share what I do know with you [fremennik name].",
      "placeholders": [
        "[fremennik name]"
      ]
    }
  }
}