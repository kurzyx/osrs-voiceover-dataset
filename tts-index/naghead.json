{
  "ref": "naghead",
  "speakerRefs": [
    "naghead"
  ],
  "textByHashes": {
    "d763abb076ff4fbe33a9335d709938ac8d41fddba91541f5e5e339c29e9f5835": "What was I talking about, now?",
    "c0c2f6e14daf1436a37d6ba44418a736d44f0cf1dc9eced3245ccbd9a213fbc7": "Oh yeah, that was it!",
    "f2f8be8aece9bcd1fc1a20513b6bdb02474a44f410236b12bb2088c75a141310": "It's about the new family.",
    "ab802e4516cd1fe29f1e116d52ae4e072e0cb1641dd4c5bf7c1cd18d932d0f5b": "The very same!",
    "37e3cd0adeddcef3e95f48d253d2e2d039f051a4db49d1969f5da72e9347f283": "I were hangin' out me washin'.",
    "edb17b9bab07e3ffb330c43e93c4ccd08ee08c71fa7b34531cfc6b63a963e90d": "And I looked over at-",
    "f2d99c75e07db1f9ab3dc63d87f5869f4d37c5fcde919999069de36973504708": "Wait, we're being watched!",
    "05c0fe33453f89847720e2c99107147e5e3a84ff3b201cfed68784b45b2e8bdd": "Yes, a person over there.",
    "0ce80904a1608976904e1596a3b55baa66b5fb3a7314610ba3a3064657e8fd14": "No! Don't make eye contact.",
    "1b6733a1c8108e7d2a2f248497e37a74aa60dd7fe61c14bde38394eb058f7234": "They're listening to us.",
    "0a9fe0b00ce193086ecb96093f61f99cedfa3818af13742ef22efaf526561ae0": "Oh no! It's one of those tall people.",
    "34b34ad6a2cf13a6c263da17e217fe2b011b7def196fad4395fae414da7a35f6": "Makes my skin crawl to see them.",
    "e14d0c385bf22f394019b0436dd3cf9a650312a2934a15a61be49800d86939ac": "So tall and neat.",
    "338266cd7862a49bc5ca8ea8ae5a502e4cb174bd680893aa867a6f185bc67044": "I hope it doesn't come to speak with us.",
    "e8fd1033c864f6d99e4b8dbb7d29792baea3a745895802cb362900f64e2e1466": "Horrid indeed, my dear.",
    "34ed7f1e295caf57f0b865a4ed28db864f6a85b91ab7d3fcfff5d4e6baad0c93": "Let us carry on our conversation.",
    "b54173bfae13ec3d91187172c4974c44a1a9e5480e709774e9a041a581f395e1": "So..."
  }
}