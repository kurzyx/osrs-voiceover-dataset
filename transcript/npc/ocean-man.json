{
  "ref": "ocean-man",
  "categoryRef": "npc",
  "title": "Ocean Man",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello. Do you need any help?"
            },
            {
              "speaker": "Ocean Man",
              "text": "Just soaking up the thirst of the land, man."
            },
            {
              "speaker": "Player",
              "text": "Is that a no?"
            },
            {
              "speaker": "Ocean Man",
              "text": "Let me show you what I mean."
            },
            {
              "speaker": "Ocean Man",
              "text": "Give me your hand."
            },
            {
              "speaker": "Player",
              "text": "I don't understand."
            },
            {
              "speaker": "Ocean Man",
              "text": "I once met a cyclops who sold some wonderful hand-made souvenirs."
            },
            {
              "speaker": "Player",
              "text": "That sounds lovely."
            },
            {
              "speaker": "Ocean Man",
              "text": "Nice boat."
            },
            {
              "speaker": "Player",
              "text": "It is, isn't it?"
            },
            {
              "speaker": "Ocean Man",
              "text": "The gang's all here."
            },
            {
              "speaker": "Player",
              "text": "I can't stick around all day, I'm afraid."
            },
            {
              "speaker": "Ocean Man",
              "text": "A holiday is better if you bring a couple of goofy friends along."
            },
            {
              "speaker": "Ocean Man",
              "text": "Let's party 'til we're purple."
            }
          ]
        }
      ]
    }
  ]
}