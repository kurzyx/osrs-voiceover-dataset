          "lines": [
            {
              "speaker": "Guard",
              "text": "Stand back. This area is restricted."
            },
            {
              "speaker": "Player",
              "text": "What's so special about it?"
            },
            {
              "speaker": "Guard",
              "text": "That's none of your business."
            },
            {
              "speaker": "Player",
              "text": "I think I've left some of my loot in there. Can I get it quick?"
            },
            {
              "speaker": "Guard",
              "text": "Nice try, [Colosseum rank]."
            },
            {
              "speaker": "Player",
              "text": "What if I share some of it with you?"
            },
            {
              "speaker": "Guard",
              "text": "I do not care for wealth. Now move along."
            },
            {
              "speaker": "Player",
              "text": "May I pass?"
            },
            {
              "speaker": "Guard",
              "text": "You shall not... *cough*"
            },
            {
              "speaker": "Guard",
              "text": "No one is allowed past I'm afraid."
            },
            {
              "speaker": "Player",
              "text": "How suspicious..."
            }
          ]
        }
      ]
    }
  ]
