{
  "ref": "lubufu",
  "categoryRef": "npc",
  "title": "Lubufu",
  "sections": [
    {
      "title": "Standard dialogue before Tai Bwo Wannai Trio",
      "sections": [
        {
          "title": "First dialogue",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Lubufu",
                  "text": "Watch where you're going, young whippersnapper!"
                },
                {
                  "speaker": "Player",
                  "text": "I wasn't going anywhere..."
                },
                {
                  "speaker": "Lubufu",
                  "text": "Well then go away from here!"
                },
                {
                  "speaker": "Player",
                  "text": "What's a whippersnapper?"
                },
                {
                  "speaker": "Lubufu",
                  "text": "It's a whip. Which snaps. Like me. Now leave!"
                },
                {
                  "speaker": "Lubufu",
                  "text": "I am Lubufu - the only fisherman who knows the secret of the Karambwan!"
                },
                {
                  "speaker": "Player",
                  "text": "What's a Karambwan?"
                },
                {
                  "speaker": "Lubufu",
                  "text": "What a foolish question! Now leave!"
                }
              ]
            }
          ]
        },
        {
          "title": "Attempting to speak with Lubufu again",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Lubufu",
                  "text": "I said go away!"
                },
                {
                  "speaker": "Player",
                  "text": "Ok, I'm going..."
                }
              ]
            }
          ]
        },
        {
          "title": "Interacting with his fishing spot",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Lubufu",
                  "text": "Keep off my fishing spot, whippersnapper!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Standard dialogue after Tai Bwo Wannai Trio",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Lubufu",
              "text": "You deceived me you confoundering dolt! Because of you, my entire business is ruined! Get out of my sight!"
            }
          ]
        }
      ]
    }
  ]
}