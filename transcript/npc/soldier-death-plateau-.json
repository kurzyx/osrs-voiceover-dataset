      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Are you OK?"
            },
            {
              "speaker": "Soldier",
              "text": "Urrrgggh....."
            },
            {
              "speaker": "Soldier",
              "text": "I'll be OK, the trolls only leave the plateau at nightfall. The guys are bringing a stretcher shortly."
            },
            {
              "speaker": "Player",
              "text": "As long as you're sure."
            },
            {
              "speaker": "Soldier",
              "text": "It's my own fault really, I was having a walk and wandered past the danger sign. The trolls throw rocks down at any one who goes up the path!"
            },
            {
              "speaker": "Soldier",
              "text": "Don't go up there!"
            },
            {
              "speaker": "Player",
              "text": "OK, thanks for the warning."
            }
          ]
        }
      ]
    }
  ]
