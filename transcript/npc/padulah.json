{
  "ref": "padulah",
  "categoryRef": "npc",
  "title": "Padulah",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Padulah",
              "text": "What do you want?"
            },
            {
              "speaker": "Player",
              "text": "Oh, nothing in particular really."
            },
            {
              "speaker": "Padulah",
              "text": "Well stop distracting me then. I'm meant to be guarding this sacred statue from the temple of Marimbo."
            },
            {
              "speaker": "Player",
              "text": "Where is the temple of Marimbo?"
            },
            {
              "speaker": "Padulah",
              "text": "You're not from around here are you?"
            },
            {
              "speaker": "Player",
              "text": "Actually, I'm not. I'm a visitor from foreign lands."
            },
            {
              "speaker": "Padulah",
              "text": "Very well. The temple is to the east of the village."
            },
            {
              "speaker": "Player",
              "text": "What is the statue of?"
            },
            {
              "speaker": "Padulah",
              "text": "It's of Marimbo, you cretin!"
            },
            {
              "speaker": "Player",
              "text": "Ah yes. How stupid of me not to see the likeness."
            },
            {
              "speaker": "Player",
              "text": "I'll be back later."
            },
            {
              "speaker": "Padulah",
              "text": "I wouldn't count on it."
            },
            {
              "speaker": "Player",
              "text": "What!?"
            },
            {
              "speaker": "Padulah",
              "text": "Oh, nothing."
            }
          ]
        }
      ]
    }
  ]
}