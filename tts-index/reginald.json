    "b23411f13aa2121bf86067511b94e428189598a539a97b1fedd7ba21bbc50d22": "Who are you?",
    "d1152cd5e2433ba89b33d3bd72c07dae188f890eae966a2073150a4c9a00ec5a": "Hi me.",
    "520e591e1bc82857c3ec5f86a14e5794c1ea628aec4aa943c7cc6f6b843228e5": "...I'm not you.",
    "4e0d555c0b5db39730b6611d1b45d019fc07bb91870d0e291dca8a567a82e400": "Me.",
    "a7978217c2409e20e1c610a46a4b4788a2f641d5d0b91a9d7a80b644e5c5d1f1": "But you're not the real you.",
    "7f56c723b01c55c9ffe1c024dff30bb2462d5386fd06221089febbb187171192": "Woah."
