  "ref": "lumiere",
  "categoryRef": "npc",
  "title": "Lumiere",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hi!"
            },
            {
              "speaker": "Lumiere",
              "text": "...Hi?"
            },
            {
              "speaker": "Player",
              "text": "Who are you?"
            },
            {
              "speaker": "Lumiere",
              "text": "I am..."
            },
            {
              "speaker": "Player",
              "text": "..."
            },
            {
              "speaker": "Lumiere",
              "text": "...Lumiere."
            },
            {
              "speaker": "Player",
              "text": "It's nice to meet you, Lumiere."
            },
            {
              "speaker": "Lumiere",
              "text": "...It is?"
            },
            {
              "speaker": "Player",
              "text": "Yeah?"
            },
            {
              "speaker": "Lumiere",
              "text": "..."
            },
            {
              "speaker": "Player",
              "text": "Why are you here?"
            },
            {
              "speaker": "Lumiere",
              "text": "I... light the candles..."
            },
            {
              "speaker": "Player",
              "text": "Oh, I've always wondered who did that. It doesn't sound like much fun..."
            },
            {
              "speaker": "Lumiere",
              "text": "I... did not choose this fate..."
            },
            {
              "speaker": "Player",
              "text": "Punishment?"
            },
            {
              "speaker": "Lumiere",
              "text": "Yes... for my sins."
            },
            {
              "speaker": "Player",
              "text": "Tough break."
            },
            {
              "speaker": "Lumiere",
              "text": "It is not too bad... There has been plenty of blood... Although stocks are frighteningly low..."
            },
            {
              "speaker": "Player",
              "text": "Good thing the sanctuary was unsealed. Plenty of adventurer folk you could grab some blo-"
            },
            {
              "speaker": "Lumiere",
              "text": "You are... not imaginary?"
            },
            {
              "speaker": "Player",
              "text": "Oh... no... I'd better go."
            },
            {
              "speaker": "Lumiere",
              "text": "Stay... we have so much to discuss."
            },
            {
              "speaker": "Player",
              "text": "Bye!"
            },
            {
              "speaker": "Lumiere",
              "text": "..."
            }
          ]
        }
      ]
    }
  ]
}