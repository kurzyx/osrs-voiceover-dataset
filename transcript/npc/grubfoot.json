{
  "ref": "grubfoot",
  "categoryRef": "npc",
  "title": "Grubfoot",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "Before Goblin Diplomacy",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Grubfoot",
                  "text": "Grubfoot wear red armour! Grubfoot wear green armour!"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Why they not make up their minds?"
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                }
              ]
            }
          ]
        },
        {
          "title": "After Goblin Diplomacy",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Grubfoot",
                  "text": "Me lonely."
                },
                {
                  "speaker": "Player",
                  "text": "Why?"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Other goblins in village follow either General Wartface or General Bentnoze. Me try to follow both but then me get left out of both groups."
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Don't talk to me!"
                },
                {
                  "speaker": "Player",
                  "text": "Why not?"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Me not allowed to talk. Generals will tell me to shut up whenever I talk."
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Grubfoot do this! Grubfoot do that! They always want different things and they never satisfied!"
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Me wish generals wouldn't tell me to shut up."
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Sometimes they tell me to shut up when me not even say anything!"
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                },
                {
                  "speaker": "Grubfoot",
                  "text": "Me wish me weren't so small. Other goblins all pick on me and make me do all hard work for generals."
                },
                {
                  "speaker": "General Wartface",
                  "text": "Shut up Grubfoot!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
}