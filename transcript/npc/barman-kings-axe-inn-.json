      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Barman",
              "text": "And what will it be for you, fine friend?"
            },
            {
              "speaker": "Barman",
              "text": "Yes? Can I help you with something?"
            },
            {
              "speaker": "Player",
              "text": "A beer please."
            },
            {
              "speaker": "Barman",
              "text": "That'll be 1 gold coin please."
            },
            {
              "speaker": "Player",
              "text": "I'm sorry, I seem to have run out of money."
            },
            {
              "speaker": "Barman",
              "text": "Here you go. One delicious pint of beer."
            },
            {
              "speaker": "Player",
              "text": "Sorry, I changed my mind."
            },
            {
              "speaker": "Player",
              "text": "A dwarven stout please."
            },
            {
              "speaker": "Barman",
              "text": "It'll be yours for just 2 gold coins!"
            },
            {
              "speaker": "Player",
              "text": "I'm sorry, I seem to have run out of money."
            },
            {
              "speaker": "Barman",
              "text": "One dwarven stout, best in all of Keldagrim!"
            },
            {
              "speaker": "Player",
              "text": "Sorry, I changed my mind."
            },
            {
              "speaker": "Player",
              "text": "A fine wine please."
            },
            {
              "speaker": "Barman",
              "text": "Ah, I see you have taste! A jug of wine will cost you 10 gold coins."
            },
            {
              "speaker": "Player",
              "text": "I'm sorry, I seem to have run out of money."
            },
            {
              "speaker": "Barman",
              "text": "I hope you enjoy it!"
            },
            {
              "speaker": "Player",
              "text": "Sorry, I changed my mind."
            },
            {
              "speaker": "Player",
              "text": "Nothing, thanks."
            }
          ]
        }
      ]
    }
  ]
