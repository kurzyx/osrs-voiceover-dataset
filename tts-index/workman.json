  "textByHashes": {
    "28cdd0f2697e25a74176041967c3f5a2332061df571b9833dfed60a81bcd7504": "- Oi - stop gabbing and get that chair finished!",
    "25fdd12e5ea2be86203f400f2d9262fa686d58d371b77669a81690b4fabe772a": "Great, just what my arms need!",
    "7516396a23da0efb071230d400696a7e74f460f756c384aca0433cc71c0139ed": "Ohhh, time for a break.",
    "65894c9376c3969d530d537478783467734790d0ccf149b4a1502c8a300da61b": "Time I got moving...",
    "3b3282b147ad8d91f79a5fd5fe5c8f3063bcfb27ed2c2a8fa94017f30f89138b": "Bleah",
    "fbd1f4a54a0b3236dc9b986dc0df2710cc4c8835b5776ca6ea71b0c884d58626": "Another lot for ya!",
    "7c0747e9833a093adf90f37a39a45120ce60c04fc00d6124bc8bc67d21bbde8b": "Off we go again!",
    "1df036780835fddc669757eabc9d747d1117d9cb91dd2a17a677a48627c10b03": "How's it going, officers?",
    "c95ad51fe8e733dbb2bd8c71c05b59269c47b2566f5c2422e6f522971be73adf": "Nothing new there.",
    "58673ca275327427e7f3c77a45e5e09de2594fdefba7ed913ee75ea22f851917": "Oh, they're all dead.",
    "4336cbbd900c27d6c1566e4b0b76b0ba4f4df255caeb9e10811f9367bc81d4d7": "Yeah, yeah, I'm movin' guv.",
    "d65519501f663c3fcc620a0c4818489ce31bbaa1031aba5f6fdae5ce53923dcc": "Hmm, time for a break.",
    "1684114cfb5e63795b835cab58b07a3fac4e28436f9981a9d25982c49dd35c87": "What do you want? I've got work to do!",
    "a2b1d432bc1a8d5fae870103c9010ec8763ec52c4fd155ed931f230718b6bf93": "No - I've got one lousy apprentice already, and that's quite enough hassle! Go away!"
  }
}