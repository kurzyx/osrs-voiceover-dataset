  "textByHashes": {
    "6f80e10d537afacc8ab4a1ea52cc0a2723faefbbfd0733e156174f20cf16e832": "AT LAST!",
    "b1c99276127bc80deefcc807b9fa1f826051217231244c9185eb661934de6ef5": "Fumus!",
    "2965173214900cadeb3a611b0fa46edab1cbc19d99ee2903a6c93ef62b57100b": "Umbra!",
    "e3ec80305dfa1d8ac2771ed0341dd4cd1bf7763c52edb032f30badb4bb5a88f8": "Cruor!",
    "b7ab59ca833bc6530f0ef2a1e5d5aa808daf9d870eeaac16e4c1395c5fc807ee": "Glacies!",
    "94d47073f3b625604c182a78aadc31481ad696a1829428c7af16d27592335d6e": "Fill my soul with smoke!",
    "f968a657bba360101c8267e03ba24c1d604c2722e627b4755c7055b9134a3938": "Let the virus flow through you!",
    "4f149e86971ba5bfbfa61a14f6134d57c957df8fe91e3cf19268c64fbd51509f": "There is...",
    "a88d6ee807f2cbb2ebce9a9acbaa9686a375460d82537ee28d6721aa06ca7801": "NO ESCAPE!",
    "52fd2b7ceddc66f23632c690fc760258438526205bf0684e5ddffdef9f6f7c91": "Fumus, don't fail me!",
    "7d695a1b9979bca2ea4af4c45a1b57ebbe0361fefc0c7ef39da9c062ef20fcd6": "Darken my shadow!",
    "038795aaf17fe4641f54531a8a3e37d9a4809c3c9e2bab5f5f990dce86f46505": "Fear the shadow!",
    "f66eba05cbbf7afceefa1c2fe94dc9026c809fbdc8cb0d6f294db70196860596": "Embrace darkness!",
    "614dfe47ec15b1fedc9548006e17749b51c8f88598f57ed1d5b61b9c296b3759": "Umbra, don't fail me!",
    "61b4f2e5b33192dc9099b944e76614c484839a9839c9ef57bebe6f973991d28a": "Flood my lungs with blood!",
    "a6a1020a0193ae9ad31c59928019a87150167d219717fa42ef6f6f4fc8f70259": "A siphon will solve this!",
    "05ff26c85daccf898e60937f13b07ce181598d09e1b9602e2eb360f76bf1c6b0": "I demand a blood sacrifice!",
    "4400d919ab4ce409e04686fdba620fdb0e27c76a2083734b8e51b0ddaab5f29b": "Cruor, don't fail me!",
    "7d2c8bc0f44a6e29e73e9e3e588109a202359058817f065a2a91520f0fa67467": "Infuse me with the power of ice!",
    "9609e17a77f2b38b614d513992c194e3222c15cc226498ff1a7f7005f886fcee": "Contain this!",
    "62b2a7dd21f6895f50bd438b75a926572649969afc85df7f5d2ded61bec99ec5": "Die now, in a prison of ice!",
    "633dc489dd20f5927a5855baf9d22093a42038f0228565273db3c9200a032041": "Glacies, don't fail me!",
    "7d91f8139c0f775e0f5ac9d55b56eecd5d6aaf5a3db801c5d40c3dcb320689a5": "NOW, THE POWER OF ZAROS!",
    "1467e16c3f7e9c0ea37605322a9e4bff1ddffb253945cf68dc2a7e42a828a0c0": "Taste my wrath!"
  }
}