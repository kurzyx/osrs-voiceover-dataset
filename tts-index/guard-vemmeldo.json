  "textByHashes": {
    "514ea5ddbae3d11f9103e3562688c11ed69db3b98873f6dc25e40c5d28eee4b7": "My job is to ensure that everyone can use the bank safely. Shifty types always hang around banks, you know.",
    "d2192aaa1c7bda4eb96b299b3d8d4a7047ad3b5f9a34c4b8fc57b9d353a1dc88": "You're not shifty, are you?",
    "0daebf83b6527381ecb87db5bbb6007ed88e6e24237ed57398810da23a76cc3c": "Jolly good. Carry on then.",
    "f505157252da8fe12f7ee8727f03a6b366367b2e04d3ba51a54015a49b0928d0": "Thank you. Be vigilant.",
    "93422379eaa4ffc1b0da50b9a6a5d35b0e3d5b0ce99b7c8f2acce36b7b0b0819": "Please help me with this!",
    "4908b517f8a915997b04d4805ea9aa4120e06d147217c6f32a7be36fabf1020a": "Well done!"
  }
}