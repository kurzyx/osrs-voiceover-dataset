        {
          "title": "Random rabbits in Bunbridge",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello there."
                },
                {
                  "speaker": "Rabbit",
                  "text": "No time to talk, another time perhaps."
                },
                {
                  "speaker": "Player",
                  "text": "Hello fellow bunny, how's it hanging?"
                },
                {
                  "speaker": "Rabbit",
                  "text": "Hello friend, no time to talk, the early rabbit gets the carrot as they say."
                },
                {
                  "speaker": "Player",
                  "text": "Hop along then."
                },
                {
                  "speaker": "Player",
                  "text": "Hey."
                },
                {
                  "speaker": "Player",
                  "text": "..."
                },
                {
                  "speaker": "Player",
                  "text": "I'm going to go."
                },
                {
                  "speaker": "Player",
                  "text": "Hi there."
                },
                {
                  "speaker": "Rabbit",
                  "text": "I'm late, I'm late for a very important date."
                },
                {
                  "speaker": "Player",
                  "text": "You seem to be having an eggsistential crisis."
                },
                {
                  "speaker": "Rabbit",
                  "text": "You're not funny, it's rabbits like you that give us a bad name."
                },
                {
                  "speaker": "Player",
                  "text": "Hello there."
                },
                {
                  "speaker": "Rabbit",
                  "text": "Hello friend, would you like to hear a joke?"
                },
                {
                  "speaker": "Player",
                  "text": "Not really."
                },
                {
                  "speaker": "Rabbit",
                  "text": "What's a rabbit's favorite dance style?"
                },
                {
                  "speaker": "Player",
                  "text": "..."
                },
                {
                  "speaker": "Rabbit",
                  "text": "Hip-Hop!"
                },
                {
                  "speaker": "Player",
                  "text": "Hello there."
                },
                {
                  "speaker": "Rabbit",
                  "text": "Fellow rabbit..."
                },
                {
                  "speaker": "Player",
                  "text": "What are you up to?"
                },
                {
                  "speaker": "Rabbit",
                  "text": "I'm just pondering."
                },
                {
                  "speaker": "Player",
                  "text": "About what?"
                },
                {
                  "speaker": "Rabbit",
                  "text": "Did the Wise Old Rabbit ever tell you about Duke Harrous the dumb."
                },
                {
                  "speaker": "Player",
                  "text": "No, I don't think he did?"
                },
                {
                  "speaker": "Rabbit",
                  "text": "Hmph, not a story he would ever tell you, it's a rabbit legend, but perhaps another time."
                },
                {
                  "speaker": "Rabbit",
                  "text": "No time to talk, another time perhaps."
                }
              ]
            }
          ]
        },
        {
          "title": "Campfire rabbits",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Rabbit",
                  "text": "Isn't this wonderful, coming out here and looking out over the sea."
                },
                {
                  "speaker": "Rabbit",
                  "text": "I could stay here with you forever..."
                }
              ]
            }
          ]
        }
