{
  "ref": "monks-friend",
  "categoryRef": "quest",
  "title": "Monk's Friend",
  "sections": [
    {
      "title": "Getting started",
      "sections": [
        {
          "title": "Talking to Brother Omad",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello there, What's wrong?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "*yawn*...oh, hello...*yawn* I'm sorry! I'm just so tired! I haven't slept in a week!"
                },
                {
                  "speaker": "Player",
                  "text": "Why can't you sleep, what's wrong?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "It's brother Androe's son! With his constant: Waaaaaah! Waaaaaaaaah! Androe said it's natural, but it's so annoying!"
                },
                {
                  "speaker": "Player",
                  "text": "I suppose that's what kids do."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "He was fine, up until last week! Thieves broke in! They stole his favourite sleeping blanket!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Now he won't rest until it's returned... ...and that means neither can I!"
                },
                {
                  "speaker": "Player",
                  "text": "Can I help at all?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Please do. We won't be able to help you as we are peaceful men but we would be grateful for your help!"
                },
                {
                  "speaker": "Player",
                  "text": "Where are they?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "They hide in a secret cave in the forest. It's hidden under a ring of stones. Please, bring back the blanket!"
                },
                {
                  "speaker": "Player",
                  "text": "I'm sorry to hear that! I hope you find his blanket."
                },
                {
                  "speaker": "Player",
                  "text": "Sorry! I'm too busy to hear your problems!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to brother Omad before retrieving the blanket",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "*yawn*...oh, hello again...*yawn*"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Please tell me you have the blanket."
                },
                {
                  "speaker": "Player",
                  "text": "I'm afraid not."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "I need some sleep!"
                }
              ]
            }
          ]
        },
        {
          "title": "Monk overhead",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Monk",
                  "text": "*yawn*"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Child's blanket",
      "sections": [
        {
          "title": "Entering the stone circle",
          "sections": [],
          "dialogues": [
            {
              "lines": []
            }
          ]
        },
        {
          "title": "Talking to Brother Omad after retrieving the blanket",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "*yawn*...oh, hello again...*yawn*"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Please tell me you have the blanket."
                },
                {
                  "speaker": "Player",
                  "text": "Yes! I've recovered it from the clutches of the evil thieves!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Really, that's excellent, well done! Maybe now I will be able to get some rest."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "*yawn*..I'm off to bed! Farewell brave traveller!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to a Monk after retrieving the blanket",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Monk",
                  "text": "Can't wait for the party!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Brother Cedric",
      "sections": [
        {
          "title": "Talking to Brother Cedric before agreeing to find him",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Honey, money, woman and wine!"
                },
                {
                  "speaker": "Player",
                  "text": "Are you ok?"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Yesshh...hic up...beautiful!"
                },
                {
                  "speaker": "Player",
                  "text": "Take care old monk."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "La..di..da..hic..up!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Omad again",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello, how are you?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Much better now I'm sleeping well! Now I can organise the party."
                },
                {
                  "speaker": "Player",
                  "text": "Ooh! What party?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "The son of Brother Androe's birthday party. He's going to be one year old!"
                },
                {
                  "speaker": "Player",
                  "text": "That's sweet!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "It's also a great excuse for a drink!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "We just need Brother Cedric to return with the wine."
                },
                {
                  "speaker": "Player",
                  "text": "Who's Brother Cedric?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Cedric is a member of the order too. We sent him out three days ago to collect wine. But he didn't return!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "He most probably got drunk and lost in the forest!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "I don't suppose you could look for him?"
                },
                {
                  "speaker": "Player",
                  "text": "I've no time for that, sorry."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Okay traveller, take care."
                },
                {
                  "speaker": "Player",
                  "text": "Where should I look?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Oh, he won't be far. Probably out in the forest."
                },
                {
                  "speaker": "Player",
                  "text": "Ok, I'll go and find him."
                },
                {
                  "speaker": "Player",
                  "text": "Can I come to the party?"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Of course, but we need the wine first."
                },
                {
                  "speaker": "Player",
                  "text": "Enjoy it! I'll see you soon!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Take care traveller."
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Omad before finding Brother Cedric",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello brother Omad."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Hello adventurer, have you found Brother Cedric?"
                },
                {
                  "speaker": "Player",
                  "text": "Not yet."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Well, keep looking, we need that wine!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Brother Cedric are you okay?"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Yeesshhh, I'm very, very drunk..hic..up.."
                },
                {
                  "speaker": "Player",
                  "text": "Brother Omad needs the wine for the party."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Oh dear, oh dear, I knew I had to do something!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Pleashhh, find me a jug of water. Once I'm sober I'll 'elp you take the wine back."
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric before getting water",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Are you okay?"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Hic up! Oh my head! I need a jug of water."
                },
                {
                  "speaker": "Player",
                  "text": "I'll see if I can get some."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Thanks! *hic*"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Omad after finding Brother Cedric",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Brother Omad",
                  "text": "Hello adventurer, have you found Brother Cedric?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes I've seen him, he's a bit drunk!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Well, try your best to get him back here!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric with water",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Are you okay?"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Hic up! Oh my head! I need a jug of water."
                },
                {
                  "speaker": "Player",
                  "text": "Cedric! Here, drink! I have some water."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Good stuff, my head's spinning!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Gulp... gulp!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Aah! That's better!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Now I just need to fix this cart and we can go party."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Could you help?"
                },
                {
                  "speaker": "Player",
                  "text": "No, I've helped enough monks today!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "In that case I'd better drink more wine! It helps me think."
                },
                {
                  "speaker": "Player",
                  "text": "Yes, I'd be happy to!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Excellent, I just need some wood. Some plain logs, or maybe a basic plank."
                },
                {
                  "speaker": "Player",
                  "text": "OK, I'll see what I can find."
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric after giving him water before accepting to help with the cart",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Brother Cedric",
                  "text": "Now I just need to fix this cart and we can go party."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Could you help?"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Omad after giving Brother Cedric water",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello again brother Omad."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Hello adventurer, where's Brother Cedric?"
                },
                {
                  "speaker": "Player",
                  "text": "He's having a bit of trouble with his cart."
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Hmmm! Maybe you could help?"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric before getting some wood",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Brother Cedric",
                  "text": "Did you manage to get some wood?"
                },
                {
                  "speaker": "Player",
                  "text": "Not yet, I'm afraid."
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric while holding some wood",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Brother Cedric",
                  "text": "Did you manage to get some wood?"
                },
                {
                  "speaker": "Player",
                  "text": "Here you go!"
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Well done! Now I'll fix this cart. You head back to Brother Omad and tell him I'll be there soon."
                },
                {
                  "speaker": "Player",
                  "text": "Ok! I'll see you later!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Cedric again before returning",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello Cedric."
                },
                {
                  "speaker": "Brother Cedric",
                  "text": "Hi, I'm almost done here. Could you tell Omad that I'll be back soon?"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to Brother Omad after finding and helping Brother Cedric",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hi Omad, Brother Cedric is on his way!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Good! Good! Now we can party!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "I have little to repay you with but please, take these runes."
                },
                {
                  "speaker": "Player",
                  "text": "Thanks Brother Omad!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "OK, let's party!"
                }
              ]
            }
          ]
        },
        {
          "title": "Dancing cutscene",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Brother Omad",
                  "text": "Party!"
                },
                {
                  "speaker": "Player",
                  "text": "Woop!"
                },
                {
                  "speaker": "Monk",
                  "text": "Yeah!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Let's boogie!"
                },
                {
                  "speaker": "Player",
                  "text": "Oh baby!"
                },
                {
                  "speaker": "Monk",
                  "text": "GO!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Get down!"
                },
                {
                  "speaker": "Player",
                  "text": "Feel the rhythm!"
                },
                {
                  "speaker": "Monk",
                  "text": "Dance!"
                },
                {
                  "speaker": "Brother Omad",
                  "text": "Oh my!"
                },
                {
                  "speaker": "Player",
                  "text": "Watch me go!"
                },
                {
                  "speaker": "Monk",
                  "text": "You go!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "Post-quest dialogue for 20 minutes",
      "sections": [
