  "hashesWithUnresolvedText": {
    "efa9bc390a8e2a94e642e6510a73f17460471d4aaded660abe3425a36264f0ab": {
      "text": "Please ask him, [player name]! For me and My Arm!",
      "placeholders": [
        "[player name]"
      ]
    },
    "2a46e9079459322b839e545b7e8bf422bd791d8a373d75a43877e54532adcd81": {
      "text": "My Arm, [player name], Old Man, we are going to get out of here, and punish my father for what he has done.",
      "placeholders": [
        "[player name]"
      ]
    },
    "2a9462c12d9a5585f36224a2851cfcf3e4111920991668673af843c1c3a97d42": {
      "text": "Old Man, [player name], thank you both for your help.",
      "placeholders": [
        "[player name]"
      ]
    },
    "7efc04649cb7433954ce85f21bd440814f7dd4fffb026955537fc695b7d15bf3": {
      "text": "Then the throne of Weiss is mine. I also call you to witness our marriage. [player name], please step forward.",
      "placeholders": [
        "[player name]"
      ]
    },
    "f586f614c8ca1a43506b7de18b95b0c838b94691cd880f96b7b48634f184f79c": {
      "text": "[player name], we owe you so much, and we will thank you - but we still need one small favour first.",
      "placeholders": [
        "[player name]"
      ]
    },
    "3dd4916042055c314e7804266f85176a37760194027e4a701abff04f51e177a9": {
      "text": "That is right, [player name]. You can mine the salts in the cave below, next to the prison.",
      "placeholders": [
        "[player name]"
      ]
    }
  }
