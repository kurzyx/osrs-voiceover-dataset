{
  "ref": "naghead",
  "categoryRef": "npc",
  "title": "Naghead",
  "sections": [
    {
      "title": "Overhead dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Naghead",
              "text": "What was I talking about, now?"
            },
            {
              "speaker": "Wagchin",
              "text": "Weren't you going to tell me about the rumour?"
            },
            {
              "speaker": "Naghead",
              "text": "Oh yeah, that was it!"
            },
            {
              "speaker": "Wagchin",
              "text": "Carry on."
            },
            {
              "speaker": "Naghead",
              "text": "It's about the new family."
            },
            {
              "speaker": "Wagchin",
              "text": "That joined our horde?"
            },
            {
              "speaker": "Naghead",
              "text": "The very same!"
            },
            {
              "speaker": "Wagchin",
              "text": "Oh my! Do tell."
            },
            {
              "speaker": "Naghead",
              "text": "I were hangin' out me washin'."
            },
            {
              "speaker": "Wagchin",
              "text": "Yes..."
            },
            {
              "speaker": "Naghead",
              "text": "And I looked over at-"
            },
            {
              "speaker": "Wagchin",
              "text": "I'm listening."
            },
            {
              "speaker": "Naghead",
              "text": "Wait, we're being watched!"
            },
            {
              "speaker": "Wagchin",
              "text": "We are?"
            },
            {
              "speaker": "Naghead",
              "text": "Yes, a person over there."
            },
            {
              "speaker": "Wagchin",
              "text": "Where?"
            },
            {
              "speaker": "Naghead",
              "text": "No! Don't make eye contact."
            },
            {
              "speaker": "Wagchin",
              "text": "Oh my!"
            },
            {
              "speaker": "Naghead",
              "text": "They're listening to us."
            },
            {
              "speaker": "Wagchin",
              "text": "A goblin folk?"
            },
            {
              "speaker": "Naghead",
              "text": "Oh no! It's one of those tall people."
            },
            {
              "speaker": "Wagchin",
              "text": "Bizarre creatures for sure."
            },
            {
              "speaker": "Naghead",
              "text": "Makes my skin crawl to see them."
            },
            {
              "speaker": "Wagchin",
              "text": "Why?"
            },
            {
              "speaker": "Naghead",
              "text": "So tall and neat."
            },
            {
              "speaker": "Wagchin",
              "text": "For sure, my dear."
            },
            {
              "speaker": "Naghead",
              "text": "I hope it doesn't come to speak with us."
            },
            {
              "speaker": "Wagchin",
              "text": "What a horrid thought!"
            },
            {
              "speaker": "Naghead",
              "text": "Horrid indeed, my dear."
            },
            {
              "speaker": "Wagchin",
              "text": "What should we do?"
            },
            {
              "speaker": "Naghead",
              "text": "Let us carry on our conversation."
            },
            {
              "speaker": "Wagchin",
              "text": "Let's!"
            },
            {
              "speaker": "Naghead",
              "text": "So..."
            },
            {
              "speaker": "Wagchin",
              "text": "Yes?"
            }
          ]
        }
      ]
    }
  ]
}