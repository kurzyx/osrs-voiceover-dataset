  "title": "Gnome",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Gnome",
              "text": "Can't stop sorry! Busy, busy, busy!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Gnome",
              "text": "Hello traveller. Are you enjoying your stay?"
            },
            {
              "speaker": "Player",
              "text": "It's a nice place."
            },
            {
              "speaker": "Gnome",
              "text": "Yes, we try to keep it that way."
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Player",
              "text": "Are you OK?"
            },
            {
              "speaker": "Gnome",
              "text": "Youssh go gesshh em."
            },
            {
              "speaker": "Player",
              "text": "Pardon?"
            },
            {
              "speaker": "Gnome",
              "text": "Gessh ush a cosshtail."
            },
            {
              "speaker": "Player",
              "text": "A what?"
            },
            {
              "speaker": "Gnome",
              "text": "Blurssh berry."
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Gnome",
              "text": "I don't think I can take much more!"
            },
            {
              "speaker": "Player",
              "text": "What's wrong?"
            },
            {
              "speaker": "Gnome",
              "text": "It's just the wife, she won't stop moaning!"
            },
            {
              "speaker": "Player",
              "text": "Maybe you should give her less to moan about."
            },
            {
              "speaker": "Gnome",
              "text": "She'll always find something."
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Gnome",
              "text": "How's life treating you?"
            },
            {
              "speaker": "Player",
              "text": "Not bad, not bad at all."
            },
            {
              "speaker": "Gnome",
              "text": "It's good to see a human with a positive attitude."
            }
          ]
        }
      ]
    }
  ]
}