          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Eliza",
                  "text": "Hey there. Looking to buy something?"
                },
                {
                  "speaker": "Player",
                  "text": "What are you selling?"
                },
                {
                  "speaker": "Eliza",
                  "text": "A selection of fun items for the best of adventurers! That said, be aware that I have little interest in the usual currencies..."
                },
                {
                  "speaker": "Player",
                  "text": "Right..."
                },
                {
                  "speaker": "Eliza",
                  "text": "So, looking to buy?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes please."
                },
                {
                  "speaker": "Player",
                  "text": "I'd like to claim some trophies."
                },
                {
                  "speaker": "Eliza",
                  "text": "I'm afraid you don't have any trophies to claim."
                },
                {
                  "speaker": "Player",
                  "text": "I'll pass."
                },
                {
                  "speaker": "Eliza",
                  "text": "Fair enough."
                }
              ]
            }
          ]
        },
