      ]
    },
    "30d926a79f2c25ad1a97a6d2372cffe5cc2d598937f0c6864ef762bf093ce676": {
      "text": "Sorry, [player name], but Raley says I need to get some rest. We'll talk later, once you've sorted out that gryphon.",
