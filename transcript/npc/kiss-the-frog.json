{
  "ref": "kiss-the-frog",
  "categoryRef": "npc",
  "title": "Kiss the frog",
  "sections": [
    {
      "title": "Crowned frog",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Frog",
              "text": "Please help me. I was transformed into a frog by a well-meaning but sadly frog-obsessed old wizard. Only your touch can turn me back. Will you help me?"
            },
            {
              "speaker": "Player",
              "text": "Okay."
            },
            {
              "speaker": "Player",
              "text": "Alright."
            },
            {
              "speaker": "Player",
              "text": "Sure, I will."
            },
            {
              "speaker": "Player",
              "text": "Yeah, okay."
            },
            {
              "speaker": "Player",
              "text": "I suppose so, sure."
            },
            {
              "speaker": "Player",
              "text": "All right."
            },
            {
              "speaker": "Player",
              "text": "Very well, if a touch is all you need, I'll do it."
            },
            {
              "speaker": "Player",
              "text": "Yes, I will touch you."
            },
            {
              "speaker": "Player",
              "text": "Sure, I'll touch you."
            },
            {
              "speaker": "Player",
              "text": "A touch? Yes, I'll do that."
            }
          ]
        },
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "No way, I'm not kissing you."
            },
            {
              "speaker": "Player",
              "text": "I'd rather not."
            },
            {
              "speaker": "Player",
              "text": "Eww, no way!"
            },
            {
              "speaker": "Player",
              "text": "I don't want to."
            },
            {
              "speaker": "Player",
              "text": "Leave me alone."
            },
            {
              "speaker": "Player",
              "text": "A kiss? Not a chance."
            },
            {
              "speaker": "Player",
              "text": "It looks better to be a frog. Make me one!"
            },
            {
              "speaker": "Player",
              "text": "I'd rather become a frog too!"
            },
            {
              "speaker": "Player",
              "text": "What if I want to be a frog like you?"
            }
          ]
        },
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "I would prefer not to, sorry."
            },
            {
              "speaker": "Player",
              "text": "I'm sorry, I'd prefer not to do that."
            }
          ]
        },
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "How about if we kiss?"
            },
            {
              "speaker": "Player",
              "text": "May I kiss you instead?"
            },
            {
              "speaker": "Player",
              "text": "Would a kiss be acceptable?"
            }
          ]
        },
        {
          "lines": [
            {
              "speaker": "Frog",
              "text": "Thank you so much, [player name]. I must return to my fairytale kingdom. But take this as a reward. You can exchange it at the Varrock clothes store for a costume."
            },
            {
              "speaker": "Frog",
              "text": "Yes!"
            },
            {
              "speaker": "Frog [Prince/Princess]",
              "text": "Thank you so much, [player name]. I must return to my fairytale kingdom. But take this as a reward. You can exchange it at the Varrock clothes store for a costume."
            }
          ]
        }
      ]
    },
    {
      "title": "Other frogs",
      "sections": [
