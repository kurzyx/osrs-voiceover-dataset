                  "text": "Trolls? Schmolls!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "The trolls are coming!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "The trolls took my baby son!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Welcome to Burthorpe!"
                },
                {
                  "speaker": "Player",
                  "text": "Thanks!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Trolls!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Hello stranger."
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Go away!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Run!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "Hi!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
                  "text": "The Imperial Guard can no longer protect us!"
                },
                {
                  "speaker": "Player",
                  "text": "Hi!"
                },
                {
                  "speaker": "Hild",
