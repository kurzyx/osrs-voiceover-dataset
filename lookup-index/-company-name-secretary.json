      ]
    },
    "b9b98b06fedf9a9c30924e7bf68c29894c27b41031dece2a92eb4018c6172aac": {
      "text": "Come to help us out some more, [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "371dbd28db883e4e36cdd8372a971ba7214c219e46572ae087587d53d0aace05": {
      "text": "Have you completed your task yet? Did you get our [number] pieces of copper ore?",
      "placeholders": [
