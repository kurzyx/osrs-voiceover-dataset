  "textByHashes": {
    "5aa3965889d724e6b7b561fe587cff14a93f811a41aaa0fab1d611349c77c820": "Come here little fox!",
    "824ecfa85c0cf5b65622acceb1a4b60fb12b50ba9ca7344c11a47ffe7f949dba": "I'll just pop this here...",
    "6436cf2bcbf3499e642849bb4de7773ca9caa49fc30a642bae1e87860f03f513": "This'll get that mangy fox!",
    "625e42dda21232ab8e9b559106c12c86fe73d57cef66b873f8e85b659253f455": "Hey, you're not a fox!",
    "79214f79d45434835aef156c0858e346b0927e7c0c3c1c965f75a11da969db1e": "Hey, don't touch that!",
    "dffae2152f3ed3e957ad305d88f132dc540c31ab5228183b2d524e40f7d74638": "Oi, leave those traps alone!",
    "31e6fcde828d08901c9022a64f3662fa0b05f3e9fd28b1c12f36136d9a3a51bb": "You win this time!",
    "28349f911aad719bd653fa7dbc0fc32fa2d195377f79311a6648568fb5724734": "Let's get out of here!",
    "8436173877fc51f1e49c0d3fbbf5df04139e16e4d11291b39c88bd72e6af431c": "We'll get you next time, fox!",
    "7032239b26c2425aa3208c9b398c348bae06d5dfc20d08d06ece125cf5d937e0": "We've got you now, fox!",
    "4a180512a2749d3198a9dd066cbdbabcae72fd9e9197b9b28885330fd9375533": "Maybe I'll make a nice new hat!",
    "1c252197a6dc9d8de853366a5ee226e5ab5ec49130d25e7165a90221320ea706": "Its pelt will fetch a nice price!"
  }
}