{
  "ref": "sol-heredit",
  "categoryRef": "npc",
  "title": "Sol Heredit",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "First attempt",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "By Ralos, we finally have a worthy challenger."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "You've torn through multiple waves of combatants and you're still standing. I'm almost impressed."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Now let's see how you handle a real foe..."
                }
              ]
            }
          ]
        },
        {
          "title": "Second attempt",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "You're back so soon? A lesser combatant would've retired in shame after the show you put on last time..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "But you're clearly different. Let's see what you have this time..."
                }
              ]
            }
          ]
        },
        {
          "title": "Third attempt",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "What is it they say? Third time's the charm? Let's see if that's true."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "To arms!"
                }
              ]
            }
          ]
        },
        {
          "title": "Subsequent attempts without defeating Heredit",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "You might be an incapable fighter, but at least you're persistent. Shall we?"
                }
              ]
            }
          ]
        },
        {
          "title": "During the fight",
          "sections": [
            {
              "title": "Start of fight",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "Let's start by testing your footwork."
                    }
                  ]
                }
              ]
            },
            {
              "title": "Upon reaching 1350 hitpoints",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "Not bad. Let's try something else..."
                    }
                  ]
                }
              ]
            },
            {
              "title": "Upon reaching 1125 hitpoints",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "Impressive. Let's see how you handle this..."
                    }
                  ]
                }
              ]
            },
            {
              "title": "Upon reaching 750 hitpoints",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "You can't win!"
                    }
                  ]
                }
              ]
            },
            {
              "title": "Upon reaching 375 hitpoints",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "Ralos guides my hand!"
                    }
                  ]
                }
              ]
            },
            {
              "title": "Upon reaching 150 hitpoints",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Sol Heredit",
                      "text": "LET'S END THIS!"
                    }
                  ]
                }
              ]
            }
          ],
          "dialogues": []
        },
        {
          "title": "Praying early against the triple attack",
          "sections": [],
          "dialogues": [
