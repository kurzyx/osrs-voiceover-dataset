          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Gnome child",
                  "text": "I have a riddle for you."
                },
                {
                  "speaker": "Player",
                  "text": "OK."
                },
                {
                  "speaker": "Gnome child",
                  "text": "A tree which is planted on Monday and doubles in size each day is fully grown on the following Sunday. On what day is it half grown?"
                },
                {
                  "speaker": "Player",
                  "text": "Erm... I'm not sure."
                },
                {
                  "speaker": "Gnome child",
                  "text": "Saturday. You big folk really aren't the quickest!"
                }
              ]
            }
          ]
        },
        {
