    "2490b16865fa7b0066e7e55fb729ed375a1c81424fd29d42c43a84fb985c056b": {
      "text": "Now, I must return to the capital. I need to see to arrangements around a new Teokan. [player name]. Itzla. Well done. Timoiva for now, and may the sun light your way.",
      "placeholders": [
        "[player name]"
      ]
    },
    "90f50220a61f3bf96f67035c24a2a679cec7b009ba6eb78678ffdf21e45e9834": {
      "text": "Nilsal, [player name]. It is good to see you.",
      "placeholders": [
        "[player name]"
      ]
    },
    "4ffe2abed8d2f8c6208c6f0c4c32dfa94e558b64fba55561017b9c62396cab1a": {
      "text": "Anyway, if there's nothing else, I'm afraid I must return to my work. May the sun light your way, [player name].",
