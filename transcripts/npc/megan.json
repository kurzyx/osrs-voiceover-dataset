          "lines": [
            {
              "speaker": "Megan",
              "text": "Hi! I'm Megan. Welcome to the Party Room!"
            },
            {
              "speaker": "Player",
              "text": "One beer please Megan!"
            },
            {
              "speaker": "Megan",
              "text": "Coming right up! That's two gold please."
            },
            {
              "speaker": "Player",
              "text": "I'm sorry but I don't have enough money!"
            },
            {
              "speaker": "Player",
              "text": "Can you dance, Megan?"
            },
            {
              "speaker": "Megan",
              "text": "Can I dance?!"
            },
            {
              "speaker": "Megan",
              "text": "CAN I dance?!!"
            },
            {
              "speaker": "Player",
              "text": "Dance with me Megan!"
            },
            {
              "speaker": "Player",
              "text": "Do you have any news?"
            },
            {
              "speaker": "Megan",
              "text": "Not at the moment. I've heard that the known world is expanding as new places are discovered."
            },
            {
              "speaker": "Megan",
              "text": "These are exciting times indeed!"
            }
          ]
        }
      ]
    }
