  "textByHash": {
    "023fdf61a4a47f43c2efa4e1a530ec1e6704741a57fbd5acd472f25f247d1f3a": "This work isn't going to do itself.",
    "21296ca9c1c5110b90ddde001f388a200024bf63bf52164f49feb456819846ee": "Is it lunch break yet?",
    "94008804b6f2694eb0486946d1b08ad73c7ce664e82aa50e131fd72cfeb461b1": "Ouch! That was my finger!",
    "e2dbc762363c582d8226111a6b9e020f6242464eb9390d915140d9b0d03ee3a0": "Hey I'm working here, I'm working here.",
    "04e1a03cc7d1024051a9b5f23b36f4a34392ea60105c570a376c6c23a07b904a": "Wonder when I'll get paid.",
    "d03380e647730b77e8eb1c5e6973f9a9323bd435c0833df1a6e55740eb43c4af": "Can't stop. Too busy."
  }
