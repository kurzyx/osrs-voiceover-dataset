{
  "ref": "fisherman-fishing-platform-",
  "categoryRef": "npc",
  "title": "Fisherman (Fishing Platform)",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello there."
            },
            {
              "speaker": "Fisherman",
              "text": "You are not part of our family..."
            },
            {
              "speaker": "Player",
              "text": "Umm. Not last time I checked."
            },
            {
              "speaker": "Fisherman",
              "text": "Soon you will be... Soon you will..."
            },
            {
              "speaker": "Fisherman",
              "text": "Lost to us.. She is Lost to us..."
            },
            {
              "speaker": "Player",
              "text": "Who is lost?"
            },
            {
              "speaker": "Fisherman",
              "text": "Trapped by the light... Lost and trapped..."
            },
            {
              "speaker": "Player",
              "text": "Ermm... So you don't want to tell me then?"
            },
            {
              "speaker": "Fisherman",
              "text": "Trapped... In stone and darkness..."
            },
            {
              "speaker": "Fisherman",
              "text": "Must find family..."
            },
            {
              "speaker": "Player",
              "text": "What?"
            },
            {
              "speaker": "Fisherman",
              "text": "Soon we will all be together..."
            },
            {
              "speaker": "Player",
              "text": "Are you ok?"
            },
            {
              "speaker": "Fisherman",
              "text": "Must find family... They are all under the blue... Deep deep under the blue..."
            },
            {
              "speaker": "Player",
              "text": "Ermm... I'll leave you to it then."
            },
            {
              "speaker": "Fisherman",
              "text": "Free of the deep blue we are..."
            },
            {
              "speaker": "Fisherman",
              "text": "We must find..."
            },
            {
              "speaker": "Player",
              "text": "Yes?"
            },
            {
              "speaker": "Fisherman",
              "text": "a new home..."
            },
            {
              "speaker": "Fisherman",
              "text": "We must leave this place..."
            },
            {
              "speaker": "Player",
              "text": "Where will you go?"
            },
            {
              "speaker": "Fisherman",
              "text": "Away.. Away to her..."
            },
            {
              "speaker": "Player",
              "text": "Riiight."
            },
            {
              "speaker": "Fisherman",
              "text": "Below the deep, deep blue she waits..."
            },
            {
              "speaker": "Player",
              "text": "Who waits?"
            },
            {
              "speaker": "Fisherman",
              "text": "They came to her with fire and faith..."
            },
            {
              "speaker": "Player",
              "text": "Who? Who came to who?"
            },
            {
              "speaker": "Fisherman",
              "text": "Too many... Too many..."
            },
            {
              "speaker": "Player",
              "text": "Too many what? Make sense!"
            },
            {
              "speaker": "Fisherman",
              "text": "Locked away for all eternity..."
            },
            {
              "speaker": "Player",
              "text": "You'd better start making sense Sonny Jim or I'll..."
            },
            {
              "speaker": "Fisherman",
              "text": "Free... Soon to be free..."
            },
            {
              "speaker": "Fisherman",
              "text": "Must escape the blue.. Deep deep blue"
            },
            {
              "speaker": "Player",
              "text": "Pardon?"
            },
            {
              "speaker": "Fisherman",
              "text": "Family... Under the blue... Must escape the blue..."
            }
          ]
        }
      ]
    }
  ]
}