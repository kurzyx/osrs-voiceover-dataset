            {
              "speaker": "Bartender",
              "text": "Welcome to the Sheared Ram. What can I do for you?"
            },
            {
              "speaker": "Player",
              "text": "I'll have a beer please.?"
            },
            {
              "speaker": "Bartender",
              "text": "That'll be two coins please."
            },
            {
              "speaker": "Player",
              "text": "Oh dear, I don't seem to have enough money."
            },
            {
              "speaker": "Player",
              "text": "Heard any rumours recently?"
            },
            {
              "speaker": "Bartender",
              "text": "One of the patrons here is looking for treasure apparently. A chap by the name of Veos."
            }
          ]
        }
