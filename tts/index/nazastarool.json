    "99809f67e12d1c0f2f676ee65fa16e2fff2f0bff1c709ca112e963a15409dd7d": "I am Nazastarool! Prepare to die!",
    "99adf938fb1b0390fac2df462f19cb488b7c62560b9c200088ccac3639dbee5b": "Quake in fear, for I am reborn!",
    "cb8bf703a9a1a8bb504ecd474f096daa1d97ccdbff6226e93ace2f865fc67221": "Nazastarool returns with vengeance!"
  }
