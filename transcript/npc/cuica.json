  "title": "Cuica",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Cuica",
              "text": "Human."
            },
            {
              "speaker": "Player",
              "text": "So what do you do?"
            },
            {
              "speaker": "Cuica",
              "text": "Drink."
            },
            {
              "speaker": "Player",
              "text": "For a living?"
            },
            {
              "speaker": "Cuica",
              "text": "Is that a problem?"
            },
            {
              "speaker": "Player",
              "text": "No, but I can't imagine it pays well."
            },
            {
              "speaker": "Cuica",
              "text": "As you've not taken the hint, I'm a hunter. I go out and kill things, sell the results, and then come here to drink."
            },
            {
              "speaker": "Player",
              "text": "Sounds like a fun and varied routine."
            },
            {
              "speaker": "Cuica",
              "text": "It is. Now, if you'll excuse me."
            }
          ]
        }
      ]
    }
  ]
}