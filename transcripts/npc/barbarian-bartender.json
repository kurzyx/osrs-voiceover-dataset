{
  "ref": "barbarian-bartender",
  "categoryRef": "npc",
  "title": "Barbarian bartender",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "What a lovely pub this is!"
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Isn't it just."
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Alfred's the name, Bartending's the game."
            },
            {
              "speaker": "Player",
              "text": "Pleasure."
            },
            {
              "speaker": "Player",
              "text": "Wait a minute, Bar. Alfred."
            },
            {
              "speaker": "Player",
              "text": "Oh my, you're Alfred Grimhand?!"
            },
            {
              "speaker": "Barbarian bartender",
              "text": "My barcrawl is still used to this day?"
            },
            {
              "speaker": "Player",
              "text": "It's legendary."
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Originally it was a funny prank back in the day for new recruits."
            },
            {
              "speaker": "Player",
              "text": "They seem to take it very seriously now."
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Ha Ha, amazing."
            },
            {
              "speaker": "Barbarian bartender",
              "text": "I do miss that bunch of barbs..."
            },
            {
              "speaker": "Player",
              "text": "Shall we have a drink?"
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Absolutely."
            },
            {
              "speaker": "Barbarian bartender",
              "text": "Have a splendid day [player name]!"
            }
          ]
        }
      ]
    }
  ]
}