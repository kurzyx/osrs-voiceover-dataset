  "title": "Army Commander",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "All those penguins, what are they doing?"
            },
            {
              "speaker": "Army Commander",
              "text": "Ah, they are doing drills! Getting ready for the invasion. What a glorious day that will be!"
            },
            {
              "speaker": "Player",
              "text": "Invasion? Of..."
            },
            {
              "speaker": "Army Commander",
              "text": "Yes, yes, I know we all get excited. But, I need you to get out of the way. Move along!"
            }
          ]
        }
      ]
    },
    {
      "title": "Overhead dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Army Commander",
              "text": "Put some wing into it."
            },
            {
              "speaker": "Army Commander",
              "text": "We will fly quietly into the night...and destroy them all!"
            },
            {
              "speaker": "Army Commander",
              "text": "Keep those beaks high, men!"
            },
            {
              "speaker": "Army Commander",
              "text": "No slacking! Slackers will be punished."
            },
            {
              "speaker": "Army Commander",
              "text": "Think of the motherland!"
            },
            {
              "speaker": "Army Commander",
              "text": "This isn't ballet soldier!"
            }
          ]
        }
      ]
    },
