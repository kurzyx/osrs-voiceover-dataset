    "f4d0faf9c8ae8c618f573653097769150cb114b61486075c87498577eb1fb9af": "Ash will boil!",
    "985c5979529abbf73d32f830f61f6e90523fbfaa33d22f0bad394ffb32d65b93": "Boil better!",
    "fa73092fc957a8c00d6d9fc5187a201f82041b15b6bfef9fd0d8925815450b7d": "Boil!",
    "515575ef8551e74544ea7b073cf90c5af00af11a7dc0b391ad8b36f8fdc2e916": "Ow!",
    "07f59e11965a61fc47e42e9fb3e68e8f6551f7102e889f4e7a9c03a16a238ec8": "Dung not hit Ash!",
    "73d51d6756a57f4070c3876a942e138b086e8005668f7c6a1cbb5f5f679d7a49": "Ouch!",
    "7fca66698dd96d645aa5a1a6fe0dfd9456b953352af260d3020fc5f6a47801f7": "Ash hate Dung!"
