  "hashesWithUnresolvedText": {
    "ce643d0dfd5d70caf990b34be1a4fd96ba77b3aa61be562932cd8a699abf358f": {
      "text": "Hello [player name]! Have you seen the statue? It looks beautiful! It's a pity it's been overshadowed by the departure of the Red Axe.",
      "placeholders": [
        "[player name]"
      ]
    },
    "ac2bac2ae71974390bac1117aeb75377934ac0c47c679f01b55c521de1d3c905": {
      "text": "Forthwith, [player name], forthwith! I'll order the removal at once!",
      "placeholders": [
        "[player name]"
      ]
    },
    "56cf90417838bcff12c4e3009c39305df435cac7cdae6d6c7e9e5428ee50aa78": {
      "text": "My secretary will deal with any inquiries you have about the [company name].",
      "placeholders": [
        "[company name]"
      ]
    },
    "8f2ee1dc7bb3c405c0059a66674b912623ee19c0e374b2276d097a3a5414d07f": {
      "text": "You are an exceptional member of the [company name].",
      "placeholders": [
        "[company name]"
      ]
    },
    "56a884c161f5eb2b1b680474eccbfefd01ab3ee297b78587df846f0e27606be2": {
      "text": "[player name]! I've been hearing great things about you!",
      "placeholders": [
        "[player name]"
      ]
    },
    "097bfa7dd0d346a604e66a84da89a8894c85730414cffc2cad8a55cd90ad306d": {
      "text": "Come in, [player name], my secretary has been saying good things about you.",
      "placeholders": [
        "[player name]"
      ]
    },
    "4e320ba26630047c74e1a3227c0a3f892b682d23b6b857b6ccb774db53cf2269": {
      "text": "What have you come to ask of us, honourable [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "59393344c63295a1b71bf7e6eb4fdcf649086c294fafa3e71f3e261064c5b75e": {
      "text": "Have you come to serve the [company name] again, [player name]?",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    },
    "38e700abea200ed43fc0309fb3d1873ba52bd220413a8b8d59ef322dd06bf9ae": {
      "text": "Come, [player name], let us converse a while on your future with us.",
      "placeholders": [
        "[player name]"
      ]
    },
    "cc87e1dd97a9f71a5440d8f194aefc529d75023144866fc8ff2dbaf2663133f3": {
      "text": "You are proving yourself a loyal member of the [company name], [player name]!",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    },
    "72704086d1def2b02193cc561bfdb1e6bb66cf55394834c2a41520e653cea577": {
      "text": "Hello again, [player name], come in!",
      "placeholders": [
        "[player name]"
      ]
    },
    "904b5a0a7d1360160d1edca466ba5a836979897c869c9d8fed400160dcaa026a": {
      "text": "The [company name] is pleased to see you again!",
      "placeholders": [
        "[company name]"
      ]
    },
    "6ca8f7d8141a5a48bc96389d588c5e047bb076145238bf77515d6074e953ccdc": {
      "text": "Welcome back [player name], it's great to see you again!",
      "placeholders": [
        "[player name]"
      ]
    },
    "5a1706272b4b41d4879ef2f2b0ff7c455cd08af4c5b57350a429bc708df87675": {
      "text": "I'm always happy to make time for you, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "d512cb07c4a75d1c287e88b422e4553ed51c8a2e5455ba2b136bd370088293e8": {
      "text": "And I'm honoured to make some time for you, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "bc0a55435782941b80ca79afb2f476547f8e9e39bc8851b9d66749affb65967d": {
      "text": "Don't mention it, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "49cca605aa2c6f8c63068caebfd9ed994ae8964f2bbcbac466c4a621817ed339": {
      "text": "Almost as much an honour as it is to meet you again, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "a50cb70ce39b3aedca613a67af9098e2c39b5747281141582ca998cf5befaa69": {
      "text": "Hmm, interesting, a human joining the [company name].",
      "placeholders": [
        "[company name]"
      ]
    },
    "76c9083ce8368c1e0aca9264295988364bbf8a411b14f7e7a42d63df399cfbd6": {
      "text": "So no, I cannot grant you this request yet, but I will certainly keep it in mind. In the mean time make sure you help out the [company name] in any way you can.",
      "placeholders": [
        "[company name]"
      ]
    },
    "1df03be562ee4015faf1d7a1aeb7a539d4f593b0e3ab39463f0d927707b7ce49": {
      "text": "It is agreed then! You are now a 'trusted associate' of the [company name]. Welcome!",
      "placeholders": [
        "[company name]"
      ]
    },
    "35a508fce767295a274570e517c6ce074f545fd7c6b7d30e2bda0fd260e477bc": {
      "text": "We need [number] bars of bronze in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "002458b6f67b99c4775723a5315804b7227870720294822981b9b6f6f7cbdbb5": {
      "text": "We need [number] bars of iron in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "6ae2bdc266af3d5a49d612a5ff4a970f1a9af95a39648f1fe873d3e23269d85d": {
      "text": "We need [number] bars of steel in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "ce489cde0b45e5aa71744c3f87b62ff5389c03b6ea6160853f4cf9d87598b741": {
      "text": "We need [number] bars of silver in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "9c208180e2124580989cc1424c024581d5e3de9db572780e0099cdf5e9a8eebe": {
      "text": "We need [number] bars of gold in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "e0a77a7ba3abad5572cafa1ea529c26d614b20861d6b6e10b6671c11f8385de8": {
      "text": "We need [number] bars of mithril in the next [number] minutes.",
      "placeholders": [
        "[number]",
        "[number]"
      ]
    },
    "4aba6962af73a58e4f267f0858f426cfd9efe6c3c8a068bce7bf8f80b79d35f2": {
      "text": "Admirable attitude, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "5dd34cec070f716c989fe31e0dbc32b1ee99531c8a2b4db40b066e4d249524a8": {
      "text": "The [company name] appreciates what you're doing, [player name].",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    },
    "75244b11371dce377f1b5cc9eeb77e6cc4e3750240d7be54fae71ca56412b351": {
      "text": "Then hurry back, [player name], I'm counting on you!",
      "placeholders": [
        "[player name]"
      ]
    },
    "01a485c29ddfd38d6ab5c2efce47f93eac0c32891609d6e4092eb28d1fc0f906": {
      "text": "I'm sorry to hear that, [player name], the company really needed those bars.",
      "placeholders": [
        "[player name]"
      ]
    },
    "2289183aa1af0ef6cd66b6c1e359e8a4ce1c226efb8c4815aa59dfa4c2dfd6e0": {
      "text": "Then why did you ask, [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "7cb3c7d3d37dffc72e4a839fa4ef41a006e00edc0428ac6b72ac6c0334de2a40": {
      "text": "That is an unusual thing to say for you, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "83a78e6b243a2f182fbeaf8144f1a9ce22e16f04c7f9e525dd13b761e5dee351": {
      "text": "I'm not altogether sure... much appreciated though you are, you are not really part of the [company name]. Not as such.",
      "placeholders": [
        "[company name]"
      ]
    },
    "cec4a4740effc5d5a6da28f86f44a9d5633b519cd29eeb9274633ba30b573327": {
      "text": "Were what? A part of the [company name]?",
      "placeholders": [
        "[company name]"
      ]
    },
    "a850d1e479f28d051880bc635f6aa9c9b896828c3701b9803706609f7c8af5b1": {
      "text": "You never fail to satisfy, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "b465bc87d342ec8c21f40f896ca3f797d384350c8b8d684ef05a35980d782aa4": {
      "text": "You are a true asset to the [company name]!",
      "placeholders": [
        "[company name]"
      ]
    },
    "99d2d4981cf88b1d60047131ae9200cdce3201952aba99b062bdaeefe685abec": {
      "text": "I am well pleased with your work, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "8b5f004d7931c27fdaee6f5a2fdf51145c7a3650145708060d7a889d4b4ecc75": {
      "text": "The [company name] can always rely on you, [player name].",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    },
    "e5bd75e6266df797cf71f9c61aadb427063f3ddfba0c6702563e51bbd6227e98": {
      "text": "Have you ever considered joining the [company name], [player name]? You would truly make a marvelous member.",
      "placeholders": [
        "[company name]",
        "[player name]"
      ]
    }
  }
}