    "90acbc660e389f00cbafd76ccd33263335a5bbf35d72b6870dd5a9c5490b8a37": "Finest silver in all of Keldagrim, come and see!",
    "9592120472581c53762c20d2173d1b35a130bd929b1686d38bb7992abebcb9d6": "What'll it be, son?",
    "a335995126e1bb53764cdf27f16d123ce060d0b686746d5fa2c625a8d43e017f": "What's your father want now?",
    "cb4ed46756517de40fdc6e72323ef499ef40dedc5cdde5918e4179d3c0e39232": "Silver, what else!"
  }
