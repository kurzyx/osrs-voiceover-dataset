    {
      "title": "Gulliver",
      "sections": [
        {
          "title": "Standard dialogue",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "So what exactly are you? I can't tell if you're a bird or some kind of cat... thing."
                },
                {
                  "speaker": "Gulliver",
                  "text": "What kind of question is that? I'm a gryphon."
                },
                {
                  "speaker": "Player",
                  "text": "You remind me of a seagull, except much bigger and with claws."
                },
                {
                  "speaker": "Gulliver",
                  "text": "You remind me of a monkey, except well dressed and somehow even more annoying."
                },
                {
                  "speaker": "Player",
                  "text": "Well, they say that comparison is the thief of joy, so how about we stop this line of thought."
                },
                {
                  "speaker": "Gulliver",
                  "text": "Fine by me. Caw!"
                },
                {
                  "speaker": "Player",
                  "text": "What a pretty bird you are!"
                },
                {
                  "speaker": "Gulliver",
                  "text": "If you talk to me like that again, you'll promptly find yourself down one finger."
                },
                {
                  "speaker": "Player",
                  "text": "Wow, you can talk! Can all gryphons talk? Are you like parrots?"
                },
                {
                  "speaker": "Gulliver",
                  "text": "I haven't met every gryphon. You took me from the nest remember?"
                },
                {
                  "speaker": "Player",
                  "text": "Oh, right."
                },
                {
                  "speaker": "Gulliver",
                  "text": "I'd rather enjoy the opportunity to meet a parrot. It sounds tasty."
                }
              ]
            }
          ]
        },
        {
          "title": "Giving Gulliver raw fish",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Gulliver",
                  "text": "How delightful."
                },
                {
                  "speaker": "Gulliver",
                  "text": "Mine!"
