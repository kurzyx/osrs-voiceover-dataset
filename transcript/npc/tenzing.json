  "title": "Tenzing",
  "sections": [
    {
      "title": "Before Death Plateau",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Tenzing",
              "text": "No milk today! Thank you!"
            }
          ]
        }
      ]
    },
    {
      "title": "After Death Plateau",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Can I buy some Climbing boots?"
            },
            {
              "speaker": "Tenzing",
              "text": "Sure, I'll sell you some in your size for 12 gold."
            },
            {
              "speaker": "Player",
              "text": "OK, sounds good."
            },
            {
              "speaker": "Player",
              "text": "I don't have the money on me."
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Player",
              "text": "No, thanks."
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Player",
              "text": "What does a Sherpa do?"
            },
            {
              "speaker": "Tenzing",
              "text": "We are expert guides that take adventurers, such as yourself, on mountaineering expeditions."
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Player",
              "text": "How did you find out about the secret way?"
            },
            {
              "speaker": "Tenzing",
              "text": "I used to take adventurers up Death Plateau and further north before the trolls came. I know these mountains well."
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Player",
              "text": "Nice place you have here."
            },
            {
              "speaker": "Tenzing",
              "text": "Thanks, I built it myself! I'm usually self sufficient but I can't earn any money with the trolls camped on Death Plateau."
            },
            {
              "speaker": "Player",
              "text": "Now that the Imperial Guard know about the secret way they will be able to destroy the trolls!"
            },
            {
              "speaker": "Tenzing",
              "text": "Let us hope so traveller!"
            },
            {
              "speaker": "Tenzing",
              "text": "Was there anything else?"
            },
            {
              "speaker": "Player",
              "text": "Nothing, thanks!"
            }
          ]
        }
      ]
    }
  ]
}