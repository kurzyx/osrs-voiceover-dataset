          "lines": [
            {
              "speaker": "Gorhak quo Narga",
              "text": "Greetings human."
            },
            {
              "speaker": "Player",
              "text": "Hello. What is this place?"
            },
            {
              "speaker": "Gorhak quo Narga",
              "text": "This is one of your human banks. We set it up here to help your kind serve the balance with us."
            },
            {
              "speaker": "Player",
              "text": "Do you not use it yourself?"
            },
            {
              "speaker": "Gorhak quo Narga",
              "text": "No. We have no need for it. We have no possessions. We only have our cause."
            },
            {
              "speaker": "Player",
              "text": "To serve the balance?"
            },
            {
              "speaker": "Gorhak quo Narga",
              "text": "To serve the balance."
            }
          ]
        }
      ]
    }
  ]
}