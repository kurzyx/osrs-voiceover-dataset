        {
          "title": "Picking up a load from the Digsite",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Dig Site workman",
                  "text": "Got another load for ya!"
                },
                {
                  "speaker": "Workman",
                  "text": "Great, just what my arms need!"
                }
              ]
            }
          ]
        },
        {
          "title": "Taking a break while travelling to Varrock, just before reaching the gate",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Workman",
                  "text": "Ohhh, time for a break."
                },
                {
                  "speaker": "Workman",
                  "text": "Time I got moving..."
                }
              ]
            }
          ]
        },
        {
          "title": "Upon reaching the gate next to the museum guard after leaving the Digsite",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Museum Guard",
                  "text": "Keep 'em coming!"
                },
                {
                  "speaker": "Workman",
                  "text": "Bleah"
                }
              ]
            }
          ]
        },
        {
          "title": "Upon reaching Varrock Museum, while unloading the wheelbarrow near the Dig Site specimen rocks",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Workman",
                  "text": "Another lot for ya!"
                },
                {
                  "speaker": "[Sinco Doar/Tinse Torpe]",
                  "text": "Alright, thanks!"
                },
                {
                  "speaker": "Workman",
                  "text": "Off we go again!"
                }
              ]
            }
          ]
        },
        {
          "title": "Upon leaving Varrock, near the guards stationed at the eastern exit",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Workman",
                  "text": "How's it going, officers?"
                },
                {
                  "speaker": "Guard",
                  "text": "Another boring day."
                },
                {
                  "speaker": "Workman",
                  "text": "Nothing new there."
                },
                {
                  "speaker": "Workman",
                  "text": "How's it going, officers?"
                },
                {
                  "speaker": "Guard",
                  "text": "I'm being slaughtered!"
                },
                {
                  "speaker": "Workman",
                  "text": "Nothing new there."
                },
                {
                  "speaker": "Workman",
                  "text": "How's it going, officers?"
                },
                {
                  "speaker": "Workman",
                  "text": "Oh, they're all dead."
                }
              ]
            }
          ]
        },
        {
          "title": "Upon reaching the gate next to the museum guard after leaving Varrock",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Museum Guard",
                  "text": "Don't dawdle there!"
                },
                {
                  "speaker": "Workman",
                  "text": "Yeah, yeah, I'm movin' guv."
                }
              ]
            }
          ]
        },
        {
          "title": "Taking a break while travelling to the Digsite",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Workman",
                  "text": "Hmm, time for a break."
                }
              ]
            }
          ]
