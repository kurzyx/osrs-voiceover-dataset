{
  "ref": "birds-eye-jack",
  "categoryRef": "npc",
  "title": "'Birds-Eye' Jack",
  "sections": [
    {
      "title": "On the Lady Zay after docking at Lunar Isle",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "I feel a little sea-sick from this travelling."
            },
            {
              "speaker": "'Birds-Eye' Jack",
              "text": "Well there's a good remedy for that."
            },
            {
              "speaker": "Player",
              "text": "There is?"
            },
            {
              "speaker": "'Birds-Eye' Jack",
              "text": "Yes."
            },
            {
              "speaker": "Player",
              "text": "What?"
            },
            {
              "speaker": "'Birds-Eye' Jack",
              "text": "Swim."
            },
            {
              "speaker": "Player",
              "text": "Oh HA HA. Thanks for the help!"
            },
            {
              "speaker": "'Birds-Eye' Jack",
              "text": "My pleasure."
            },
            {
              "speaker": "Player",
              "text": "I was being sarcastic."
            },
            {
              "speaker": "'Birds-Eye' Jack",
              "text": "I know. So was I."
            }
          ]
        }
      ]
    },
    {
      "title": "At Lunar Isle bank",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "I'd like to access my bank account, please."
            },
            {
              "speaker": "Player",
              "text": "I'd like to collect items."
            },
            {
              "speaker": "Player",
              "text": "I'd like to check my PIN settings."
            },
            {
              "speaker": "Player",
              "text": "What is this place?"
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "This is a branch of the Bank of Gielinor. We have branches in many towns."
            },
            {
              "speaker": "Player",
              "text": "And what do you do?"
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "We will look after your items and money for you. Leave your valuables with us if you want to keep them safe."
            },
            {
              "speaker": "Player",
              "text": "Hi."
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "How's Cyrisus? Where is he?"
            },
            {
              "speaker": "Player",
              "text": "He's fine now. Back to full health."
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "Good, I'm pleased."
            },
            {
              "speaker": "Player",
              "text": "No problem."
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "Don't think that this means I like you now!"
            },
            {
              "speaker": "Player",
              "text": "Look at my face."
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "Yes? What about it."
            },
            {
              "speaker": "Player",
              "text": "Does it look like I care?"
            },
            {
              "speaker": "'Bird's-Eye' Jack",
              "text": "Not really."
            },
            {
              "speaker": "Player",
              "text": "Well, there you go."
            }
          ]
        }
      ]
    }
  ]
}