{
  "ref": "sabeil",
  "categoryRef": "npc",
  "title": "Sabeil",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hi!"
            },
            {
              "speaker": "Sabeil",
              "text": "Well. This beats doing the shopping!"
            },
            {
              "speaker": "Sabeil",
              "text": "I wouldn't want to be the poor guy that has to clean up after the duels."
            },
            {
              "speaker": "Player",
              "text": "Me neither."
            },
            {
              "speaker": "Sabeil",
              "text": "Hi!"
            },
            {
              "speaker": "Sabeil",
              "text": "What did the skeleton say before it ate?"
            },
            {
              "speaker": "Player",
              "text": "I don't know?"
            },
            {
              "speaker": "Sabeil",
              "text": "Bone-appetit."
            },
            {
              "speaker": "Sabeil",
              "text": "Ooh. This is exciting!"
            },
            {
              "speaker": "Player",
              "text": "Yup!"
            },
            {
              "speaker": "Sabeil",
              "text": "How can you make a very lively hankerchief?"
            },
            {
              "speaker": "Player",
              "text": "I don't know?"
            },
            {
              "speaker": "Sabeil",
              "text": "Put a little boogey in it."
            },
            {
              "speaker": "Sabeil",
              "text": "Why did the skeleton burp?"
            },
            {
              "speaker": "Player",
              "text": "I don't know?"
            },
            {
              "speaker": "Sabeil",
              "text": "'Cause it didn't have the guts to fart!"
            },
            {
              "speaker": "Sabeil",
              "text": "My son just won his first duel!"
            },
            {
              "speaker": "Player",
              "text": "Congratulations!"
            },
            {
              "speaker": "Sabeil",
              "text": "He ripped his opponent in half!"
            },
            {
              "speaker": "Player",
              "text": "That's gotta hurt!"
            },
            {
              "speaker": "Sabeil",
              "text": "He's only 10 as well!"
            },
            {
              "speaker": "Player",
              "text": "You gotta start 'em young!"
            },
            {
              "speaker": "Sabeil",
              "text": "Can't you see I'm watching the duels?"
            },
            {
              "speaker": "Player",
              "text": "I'm sorry!"
            },
            {
              "speaker": "Sabeil",
              "text": "Knock knock!"
            },
            {
              "speaker": "Player",
              "text": "Who's there?"
            },
            {
              "speaker": "Sabeil",
              "text": "Boo."
            },
            {
              "speaker": "Player",
              "text": "Boo who?"
            },
            {
              "speaker": "Sabeil",
              "text": "Don't cry, it's just me!"
            },
            {
              "speaker": "Sabeil",
              "text": "Waaaaassssssuuuuupp?!"
            },
            {
              "speaker": "Sabeil",
              "text": "Hi! I'm here to watch the duels!"
            },
            {
              "speaker": "Player",
              "text": "Me too!"
            },
            {
              "speaker": "Sabeil",
              "text": "My favourite fighter is Mubariz!"
            },
            {
              "speaker": "Player",
              "text": "The guy at the information kiosk?"
            },
            {
              "speaker": "Sabeil",
              "text": "Yeah! He rocks!"
            },
            {
              "speaker": "Player",
              "text": "Takes all sorts, I guess."
            },
            {
              "speaker": "Sabeil",
              "text": "Hmph."
            },
            {
              "speaker": "Sabeil",
              "text": "Did you know they think this place dates back to the second age?!"
            },
            {
              "speaker": "Player",
              "text": "Really?"
            },
            {
              "speaker": "Sabeil",
              "text": "Yeah. The guy at the information kiosk was telling me."
            }
          ]
        }
      ]
    }
  ]
}