    "eda5fb6da420f5daddd51ff2596a4c41d8f4a7de196a140e45760f4191478c41": {
      "text": "Oh, my name's [citizen name]. I just help out around here, you know, looking for food and so on.",
      "placeholders": [
        "[citizen name]"
      ]
    },
    "b2283ca48f67e482ee738495d67cdb31630202d4b08e495ad420e7ed72569a80": {
      "text": "Not that it makes much difference but my name's [citizen name]. Like all the other survivors here, I just try to make do and get through each day at a time.",
      "placeholders": [
        "[citizen name]"
      ]
    },
    "7a33bb6964c9bef9cd90dda9ff6d5a90c97fe52bc9a2e6bc90bc73502f939590": {
      "text": "Oh hi. I'm [citizen name]. I hunt rats mostly. Speaking of which, this rat tastes awful, but it's the only food we have!",
      "placeholders": [
        "[citizen name]"
      ]
    },
    "12b04d62ad8ccd85d62d916e82f8f38982ab61633f55260986fde5c965ea30ce": {
      "text": "Huh? I'm [citizen name]. Ravaging after food is what I mostly do. Ocasionally I'll happen across a rat, and that's a good day, just like today!",
      "placeholders": [
        "[citizen name]"
      ]
    },
    "cb0eace4f41dd79eb863db77e1f986cc58454252d80f6ae090f433e6b030683a": {
      "text": "Oh, hello. [citizen name] is the name and I help to keep the village clear of rat infestations. Clearly I love my work, as I bring it home with me... On a stick!",
      "placeholders": [
        "[citizen name]"
      ]
    },
    "ac636a108dbcb8dbf4c0ade3cec68923b585f8db4fe6b01ba2469189ea6fcdbd": {
