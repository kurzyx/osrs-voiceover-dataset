          "lines": [
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Hello there! Nice weather we've been having."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "All these newcomers - what are they up to?"
            },
            {
              "speaker": "Player",
              "text": "What are you talking about?"
            },
            {
              "speaker": "Villager",
              "text": "Argh! Another one! No, I don't want to help with your scheme! I'm very busy!"
            },
            {
              "speaker": "Player",
              "text": "Ohhh kaaay... I'll leave you to it then."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "I'm fine, how are you?"
            },
            {
              "speaker": "Player",
              "text": "Very well, thank you."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Player",
              "text": "Do you wish to trade?"
            },
            {
              "speaker": "Villager",
              "text": "No, I have nothing I wish to get rid of. If you want to do some trading, there are plenty of shops and market stalls around though."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Argh! Don't rob me!"
            },
            {
              "speaker": "Player",
              "text": "What are you talking about?"
            },
            {
              "speaker": "Villager",
              "text": "Sorry, I thought you were a bandit."
            },
            {
              "speaker": "Player",
              "text": "There are a lot of them around here..."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "None of your business."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Get out of my way, I'm in a hurry!"
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Not too bad, thanks."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Player",
              "text": "I'm in search of enemies to kill."
            },
            {
              "speaker": "Villager",
              "text": "The desert just outside of town is full of wolves, snakes, and even wild Ugthanki. Try there."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Player",
              "text": "I'm in search of a quest."
            },
            {
              "speaker": "Villager",
              "text": "I'm sorry, I can't help you there."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "How can I help you?"
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Do I know you? I'm in a hurry!"
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "I'm very well thank you."
            },
            {
              "speaker": "Player",
              "text": "Hello, how's it going?"
            },
            {
              "speaker": "Villager",
              "text": "Who are you?"
            },
            {
              "speaker": "Player",
              "text": "I'm a bold adventurer."
            },
            {
              "speaker": "Villager",
              "text": "Ah, a most noble profession."
            }
          ]
