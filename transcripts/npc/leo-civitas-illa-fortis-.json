      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "What are you doing here?"
            },
            {
              "speaker": "Leo",
              "text": "I'm blending in. Scopin' out the place."
            },
            {
              "speaker": "Player",
              "text": "Are you preparing for a heist? You're only a kid."
            },
            {
              "speaker": "Leo",
              "text": "Let's just say there are some wealthy people about, with full pockets."
            },
            {
              "speaker": "Player",
              "text": "Any tips? I'm not having much luck myself."
            },
            {
              "speaker": "Leo",
              "text": "I'm quite sneaky. Every now and then I'll get their attention so their pockets aren't being so carefully watched."
            },
            {
              "speaker": "Player",
              "text": "That is sneaky. I'll keep an eye out for your... distractions."
            },
            {
              "speaker": "Leo",
              "text": "Now leave me be. I'm already distracting!"
            }
          ]
        }
      ]
    },
    {
      "title": "Overhead dialogue",
      "sections": [
        {
          "title": "When distracting wealthy citizens",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Leo",
                  "text": "I've been robbed!"
                },
                {
                  "speaker": "Leo",
                  "text": "*Sobbing*"
