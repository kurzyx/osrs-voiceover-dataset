{
  "ref": "guard-jatizso-watchtower-",
  "categoryRef": "npc",
  "title": "Guard (Jatizso watchtower)",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "What are you doing here?"
            },
            {
              "speaker": "Guard",
              "text": "I'M ON SHOUTING DUTY!"
            },
            {
              "speaker": "Player",
              "text": "No need to shout."
            },
            {
              "speaker": "Guard",
              "text": "I'M SORRY I'VE BEEN SHOUTING INSULTS SO LONG I CAN'T HELP IT!"
            },
            {
              "speaker": "Player",
              "text": "Who are you insulting?"
            },
            {
              "speaker": "Guard",
              "text": "THE TOWER IN NEITIZNOT. THEY SHOUT INSULTS BACK."
            },
            {
              "speaker": "Player",
              "text": "Err, why?"
            },
            {
              "speaker": "Guard",
              "text": "THE KING TELLS US TO."
            },
            {
              "speaker": "Player",
              "text": "Your King is a strange person."
            },
            {
              "speaker": "Player",
              "text": "Can I watch? I'm curious."
            },
            {
              "speaker": "Guard",
              "text": "IF YOU LIKE!"
            },
            {
              "speaker": "Player",
              "text": "Oh well, I'd better get going"
            }
          ]
        }
      ]
    },
    {
      "title": "Watching the shouting",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "YOU WOULDN'T KNOW HOW TO KILL A TROLL IF IT CAME UP AND BIT YER ARM OFF!"
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "YOU WOULDN'T KNOW HOW TO SHAVE A YAK IF YOUR LIFE DEPENDED ON IT!"
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "YAK LOVERS!"
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "MISERABLE LOSERS!"
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "CALL THAT A TOWN, I'VE SEEN BETTER HAMLETS!"
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "YOUR MOTHER WAS A HAMSTER."
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "AND YOUR FATHER SMELLED OF WINTERBERRIES."
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "AT LEAST WE HAVE SOMETHING OTHER THAN SMELLY FISH!"
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "WOODEN BRIDGES ARE RUBBISH!"
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "AT LEAST WE CAN COOK!"
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "OUR KING'S BETTER THAN YOUR BURGHER!"
            },
            {
              "speaker": "Guard (Jatizso tower)",
              "text": "JATIZSO!"
            },
            {
              "speaker": "Guard (Neitiznot tower)",
              "text": "NEITIZNOT!"
            }
          ]
        }
      ]
    }
  ]
}