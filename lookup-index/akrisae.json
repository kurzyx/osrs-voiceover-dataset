  "hashesWithUnresolvedText": {
    "64b629c1ef5e178a62c01279406c403ce01e7c5c9d8f69ad3582aa9b304162c9": {
      "text": "Glad to have you with us, [player name]. I've heard a lot about you from Sir Tiffy. It's Saradomin's will that you're doing!",
      "placeholders": [
        "[player name]"
      ]
    },
    "a62a4d4453740125a2ade4d92701effd8d8e57b258eafbc5d989be883a744499": {
      "text": "[player name], given your experience in the field, I believe you'll be best placed for this task. Take this orb and plant it on one of Lucien's spies.",
      "placeholders": [
        "[player name]"
      ]
    },
    "41d49f4931ea8ce3b9e3bbe24cb34782ee7cf4c1f4ac46b2d81ce9b35a4ec441": {
      "text": "Welcome back, [player name]. Any luck with that orb?",
      "placeholders": [
        "[player name]"
      ]
    },
    "149d3830b9ebd249a2474d0525711bd51c1a9cce6b1ab8c73a325ce9f47c0951": {
      "text": "Saradomin be with you, [player name]. How are things going with that truth serum?",
      "placeholders": [
        "[player name]"
      ]
    },
    "be4df16ecff64c06ae76a3f54e7a583419c1f552b7b7aa688e19795a7b430a0a": {
      "text": "Saradomin be with you, [player name]. How are things going with that spy?",
      "placeholders": [
        "[player name]"
      ]
    },
    "a2d89469a0564127e6e3bfc389f5edd05260dfddead9132828ea40013a436ff1": {
      "text": "Saradomin be with you, [player name]. I hear Idria has you recruiting more heroes to our cause. You should speak to her if you need help with anything.",
      "placeholders": [
        "[player name]"
      ]
    },
    "4a7c94cacae17aec8638ceb9cd8aed257f2fcfe29e355e6f5013a023536eec12": {
      "text": "Hello there, [player name]. I believe Idria has more heroes for you to recruit. You should speak to her about the details.",
      "placeholders": [
        "[player name]"
      ]
    },
    "126e99d9aa1824c0d1442ea1bc22cb14310bf71b2a7160f95cc497a0997f4c70": {
      "text": "Ah, there you are, [player name]. There has been a potential development in our hunt for the Dark Squall, but I am concerned about...",
      "placeholders": [
        "[player name]"
      ]
    },
    "b85512f0cb5f584e3b021c9e6abebf67eb939b9cdb06c628177084973f146884": {
      "text": "Good luck, [player name]. Don't forget to take some sort of disguise with you. I can't see you getting into the fortress otherwise. Oh, and keep an eye out for Silif as well. He may be in need of support.",
      "placeholders": [
        "[player name]"
      ]
    },
    "fb2a9e3c780b4b05676a6214458e7aad4dd1b61bcf845f0c35b0c55a1280021a": {
      "text": "Hello there, [player name]. Any luck finding Silif or the Dark Squall?",
      "placeholders": [
        "[player name]"
      ]
    },
    "a37cf29f720d98522f98728c8e21e9ea40f13b5937b406694d519a817856480e": {
      "text": "Welcome back, [player name]. We've already heard about your heroics in those catacombs from Silif. Good work! Thanks to your help, he was able to gather some very useful information for us.",
      "placeholders": [
        "[player name]"
      ]
    },
    "9d3716a19d5f2f35ff52df67ace05240d8edff6cae841a40eee85665936a2463": {
      "text": "Hello there, [player name]. When you're ready to go, just step inside the cell. We're going to use that teleorb you planted to swap your location with Surok's.",
      "placeholders": [
        "[player name]"
      ]
    },
    "60e17b9c26f56d48f177f59e20ffe234761b5d6f260a0673c61d8b8790e70ba9": {
      "text": "Are you ready, [player name]? I'll teleport you as soon as you enter the cell.",
      "placeholders": [
        "[player name]"
      ]
    },
    "71c3fbc838bc5def844d52f8b3fdf55f82d64a178ecaf3f32a35e75a74842256": {
      "text": "Saradomin be with you, [player name]. How goes your mission?",
      "placeholders": [
        "[player name]"
      ]
    },
    "9ab8971435aef0faba3cbfee5ad12563bebf654ac7b6b47ebcddb2e720daeacb": {
      "text": "Well keep it up, [player name]. I have no doubt you'll lead us to success.",
      "placeholders": [
        "[player name]"
      ]
    },
    "33ea9e658b0ac4bbefc6ea960af2af3457870c42d546fcc1160abdfbac33778f": {
      "text": "[player name], you must return to the temple below Lumbridge! Idria and her Guardians of Armadyl have already departed to support you!",
      "placeholders": [
        "[player name]"
      ]
    },
    "0815c5c79e9316f1aa27331685cb386f787a27c93e3894d009fe607d07cbbb5a": {
      "text": "Saradomin be with you, [player name]. We have a lot to be grateful to you for.",
      "placeholders": [
        "[player name]"
      ]
    }
  }
}