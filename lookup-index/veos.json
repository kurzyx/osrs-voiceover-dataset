  "hashesWithUnresolvedText": {
    "14d7b1347bf52afef9482cbfaf7c3a8dda0556d49610a075ccc52e4bc1080950": {
      "text": "Hello again, [player name]! What can I do for you?",
      "placeholders": [
        "[player name]"
      ]
    },
    "1ea45211659494da1cd38b0b472f7c42289cc4346ca8e9e9647c72fbddf93fa2": {
      "text": "As a matter of fact, [player name], I do...",
      "placeholders": [
        "[player name]"
      ]
    },
    "804843941f517c2fad435fde8b51406b32e0c728d9934a40d3b73641e68f5965": {
      "text": "Well that's just the thing, [player name]. My client is pleased you found such information. Tell me... Would you be willing to do one last thing for him?",
      "placeholders": [
        "[player name]"
      ]
    },
    "81786d0da4dbfb9f8d0a8cf0c4b6ac1d777b5ba2a95639d0046ec29f356508a8": {
      "text": "[player name]? What are you talking about?",
      "placeholders": [
        "[player name]"
      ]
    },
    "f09fa0d361243a912e2e96e9ba1383071195625d6b754f9326d625de0d165fd4": {
      "text": "[player name], I haven't spoken with you since bringing you to Zeah, I have no idea what you're on ab--",
      "placeholders": [
        "[player name]"
      ]
    },
    "25494ead90cfc3c5bd0f459b46077d415e10f47e99ed2cf290dd860e2aeb0084": {
      "text": "[player name], I haven't spoken with you since bringing you to Kourend, I have no idea what you're on ab--",
      "placeholders": [
        "[player name]"
      ]
    },
    "84b0c1be0ba8396bfdcd680faa07592b65c75cde32d480850ff56d52c0865476": {
      "text": "I'll be happy to provide you with another scroll, [player name], though I'm afraid you don't seem to have any room in your backpack! Return to me when you have.",
      "placeholders": [
        "[player name]"
      ]
    },
    "d98a965ae2877a84a067cebcfe6fc2a9b6d511d94afe1cabb4c27b772f66c52e": {
      "text": "Worry not, [player], I have many of those scrolls. Luckily, due to the way it works, you haven't lost any information on it!",
      "placeholders": [
        "[player]"
      ]
    },
    "4f88b62f23107c7179992fc67535964d1f10f1ebaa17bccbf3dd410341d1bea7": {
      "text": "You already have your scroll, [player], I can literally see it peeking out of your backpack...",
      "placeholders": [
        "[player]"
      ]
    },
    "7222df43b453f200f711e38891e1c83c8f232d5e6e9d3aaac37951edb4f7a036": {
      "text": "Well that's just the thing, [player name]. My client is pleased you found such information. Tell me... Would you be willing to do one last thing for them?",
      "placeholders": [
        "[player name]"
      ]
    },
    "d5d58f8f6244647256f086c8942f7e4d4b4c30c88b45ce02c5558a79d16fbd1b": {
      "text": "You already have the orb, [player name], I can literally see it peeking out of your backpack...",
      "placeholders": [
        "[player name]"
      ]
    },
    "fcd40aea42184083b3b0947bf31a984028f665b46fd8c3f65738caffc497b15a": {
      "text": "I'll be happy to provide you with another orb, [player name], though I'm afraid you don't seem to have any room in your backpack! Return to me when you have room.",
      "placeholders": [
        "[player name]"
      ]
    },
    "96d9cd93c15db8d3467a8c04c6b70600bfe0d9f503f22c8968eb703d143dc3f5": {
      "text": "Please be more careful, [player name]. Remember to return to me when you have used the orb in the area.",
      "placeholders": [
        "[player name]"
      ]
    },
    "cbc247866f3b85ba2691e1c057c7d3ea3e11911826c39945fe86ab76abce7259": {
      "text": "I once had a wolf, [player name]. His name was Copper. He was loyal. Brave... Gentle. He'd wear this beautiful crimson red collar.",
      "placeholders": [
        "[player name]"
      ]
    },
    "eea4708dff732886e6279ddeeef55bb037a0f2f15731ccf68d5a342789d1deed": {
      "text": "I ran, [player name]... Like a coward.",
      "placeholders": [
        "[player name]"
      ]
    },
    "1cbf28dedbe0f70f739beed41ca024c6fb11c4ae6df31b737c2d4673adcce7b9": {
      "text": "Truly? You'd do that for me? Thank you so much, [player name]. I can't thank you enough! My heart's been filled with regret ever since it happened... and I think having a small part of Copper back, would make me complete again.",
      "placeholders": [
        "[player name]"
      ]
    },
    "4b59a49e77aedd18f65384c0ca375eb367e6e08da5234e7272c8dff94d621cf7": {
      "text": "How goes the hunt for Copper's collar, [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "adce80761895555afc7a229fccf7270c08ef04c223465c69fdb6ffd06d8d6947": {
      "text": "[Player name]... I can't thank you enough. I don't have a reward, but know that to me, this means so much. Perhaps in the future, I can repay you.",
      "placeholders": [
        "[Player name]"
      ]
    },
    "45f58d05d34434849ee24234abbbd397477a50306f78559ac4d06cdbff306f36": {
      "text": "[Player name]... I can't thank you enough for what you've done for me. I don't have a reward, but know that to me, this means so much. Perhaps in the future I can repay you.",
      "placeholders": [
        "[Player name]"
      ]
    }
  }
}