  "textByHash": {
    "880cd7376f27ce3ddb84364b5cba113e0261f9f4bdbfae20f2f4c777e8bb8bc6": "Kill them, you cowards!",
    "3ddf3a09005c8e914a5a6bc641d160611301c7f9d64b7f9cf297c25c81110605": "Zamorak curse them!",
    "6638f5c16b1b1e0a985af4d56884ba7bd71b5fddd2cda9ccad77a651a5c59f2c": "Death to Saradomin's dogs!",
    "45b0e25a612b42ddb3f74b3d730415f885469479a5b6f2ed1d7c3c6e7f0f17e1": "Rend them limb from limb!",
    "6119ca48d350ec6dafa7783f6f70ce84ba122ae1c3cc6c620c7ea31d33dc5718": "Flay them all!",
    "4840ab75d83a36230bca2338688bf52a362552f1169cae54bb8da829a5931a7b": "Attack them, you dogs!",
    "b5d666db5afc30ece758599a1ebe791248bc9fa554c00dff4ccc272a2d78f0e3": "Forward!",
    "9ed73d2d9c82f50feba33a67639f1f9e39389b2e041c6d15b4ede7253af5568c": "Attack!",
    "80e37be0501d61e47ccb540379953f9ff942b85189a331b98c5bb2aa8ae9c027": "The Dark One will have their souls!",
    "90f9e7f765439c8106ecf4c9e53e543589f2c7d82310d9fda46399dd65068734": "No retreat!",
    "26eb487f5c377c7b030c6b7b6c1b357696a24961b1ef978b447507659e5b3642": "YARRRRRRR!"
  }
}