      "title": "Standard dialogue",
      "sections": [
        {
          "title": "When using the right-click call-Over option",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Zombie",
                  "text": "Durrrr..."
                },
                {
                  "speaker": "Player",
                  "text": "Hey! Come over here!"
                },
                {
                  "speaker": "Zombie",
                  "text": "Who? Me?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes, you!"
                },
                {
                  "speaker": "Zombie",
                  "text": "Give me a moment...I can't move that fast."
                },
                {
                  "speaker": "Player",
                  "text": "Why not?"
                },
                {
                  "speaker": "Zombie",
                  "text": "I used to be a magician's assistant until the accident..."
                },
                {
                  "speaker": "Player",
                  "text": "What accident?"
                },
                {
                  "speaker": "Zombie",
                  "text": "Looook..."
                }
              ]
            }
          ]
        },
        {
          "title": "When using the right-click insult option",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Zombie",
                  "text": "Braaaaains..."
                },
                {
                  "speaker": "Player",
                  "text": "Zombie, it has come to my attention that you are a fool, a nitwit if you will."
                },
                {
                  "speaker": "Player",
                  "text": "I propose that your head, instead of being filled with the brains you so crave, is instead filled with a mixture of crushed lemons and kelp!"
                },
                {
                  "speaker": "Zombie",
                  "text": "Oh noooo..I'd best take it off then..."
                },
                {
                  "speaker": "Player",
                  "text": "What?"
                }
              ]
            }
          ]
        },
        {
          "title": "When using the right-click scare option",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Zombie",
                  "text": "Traaa laaa laaa..."
                },
                {
                  "speaker": "Player",
                  "text": "Oogaboogabooga!"
                },
                {
                  "speaker": "Zombie",
                  "text": "Aaaaaargh!"
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
