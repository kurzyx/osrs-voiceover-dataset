      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Cassim",
              "text": "Greetings! I'm Cassim. Welcome to my home."
            },
            {
              "speaker": "Player",
              "text": "That's a big barrel of wine!"
            },
            {
              "speaker": "Cassim",
              "text": "Isn't it just! I'm a bit of a connoisseur."
            },
            {
              "speaker": "Player",
              "text": "Do you make it yourself?"
            },
            {
              "speaker": "Cassim",
              "text": "I've dabbled, but this is all imported. I have a connection in the far west who has the best vineyards."
            },
            {
              "speaker": "Player",
              "text": "In the west?"
            },
            {
              "speaker": "Cassim",
              "text": "Yes! A fine Hosidius grape, strong hints of plum and blackberry, very sweet."
            },
            {
              "speaker": "Player",
              "text": "Sounds lovely!"
            },
            {
              "speaker": "Player",
              "text": "How's the tea here?"
            },
            {
              "speaker": "Cassim",
              "text": "It's fantastic! Ali really knows how to brew a fine tea!"
            },
            {
              "speaker": "Player",
              "text": "Which is your favourite?"
            },
            {
              "speaker": "Cassim",
              "text": "Well I've supplied him with a small import of mine. I call the concoction 'Zamorak's Fire'."
            },
            {
              "speaker": "Player",
              "text": "Sounds hot!"
            },
            {
              "speaker": "Cassim",
              "text": "Yes, yes. It has a certain kick to it! Although, it'll keep you safe from fire for a short time after drinking!"
            },
            {
              "speaker": "Cassim",
              "text": "Great for when dragons attack!"
            },
            {
              "speaker": "Player",
              "text": "Does that happen often here?"
            },
            {
              "speaker": "Cassim",
              "text": "You never know... Dragons can be sneaky."
            },
            {
              "speaker": "Player",
              "text": "I'd best be off."
            },
            {
              "speaker": "Cassim",
              "text": "May the flames of Zamorak light your path."
            },
            {
              "speaker": "Player",
              "text": "Er... yeah..."
            }
          ]
        }
      ]
    }
  ]
}