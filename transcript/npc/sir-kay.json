      "title": "Standard dialogue",
      "sections": [
        {
          "title": "Before completing Merlin's Crystal",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sir Kay",
                  "text": "Good morrow [madam/sirrah]!"
                },
                {
                  "speaker": "Player",
                  "text": "Morning. Know where an adventurer has to go to find a quest around here?"
                },
                {
                  "speaker": "Sir Kay",
                  "text": "An adventurer eh? There is no service finer than serving the bountiful King Arthur, and I happen to know there's an important quest to fulfill."
                }
              ]
            }
          ]
        },
        {
          "title": "After completing Merlin's Crystal",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sir Kay",
                  "text": "Good morrow [madam/sirrah]!"
                },
                {
                  "speaker": "Sir Kay",
                  "text": "Sir Knight! Many thanks for your assistance in restoring Merlin to his former freedom!"
                }
              ]
            }
          ]
        },
        {
          "title": "After completing King's Ransom",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sir Kay",
                  "text": "Good morrow [madam/sirrah]!"
                },
                {
                  "speaker": "Sir Kay",
                  "text": "We owe you a great debt for freeing us from that dungeon."
                },
                {
                  "speaker": "Player",
                  "text": "Awww, shucks. It was nothing."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
