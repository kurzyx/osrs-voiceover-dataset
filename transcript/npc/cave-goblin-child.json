  "ref": "cave-goblin-child",
  "categoryRef": "npc",
  "title": "Cave goblin child",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Cave goblin child",
              "text": "Shh! Don't tell anyone!"
            },
            {
              "speaker": "Player",
              "text": "Don't tell anyone what?"
            },
            {
              "speaker": "Cave goblin child",
              "text": "SHHH!"
            },
            {
              "speaker": "Cave goblin child",
              "text": "Are you [player name]? Did you help Zanik save the city?"
            },
            {
              "speaker": "Player",
              "text": "Yes, that was me!"
            },
            {
              "speaker": "Cave goblin child",
              "text": "When I'm older I'm going to be an adventurer, just like Zanik!"
            },
            {
              "speaker": "Cave goblin child",
              "text": "Are you a surface-dweller?"
            },
            {
              "speaker": "Player",
              "text": "Yes..."
            },
            {
              "speaker": "Cave goblin child",
              "text": "Haha! You look funny! All tall and skinny with tiny eyes!"
            },
            {
              "speaker": "Cave goblin child",
              "text": "Help! Help! The surface people are attacking!"
            },
            {
              "speaker": "Player",
              "text": "It's alright, I'm friendly!"
            },
            {
              "speaker": "Cave goblin child",
              "text": "Sorry, I'm not meant to talk to strangers."
            }
          ]
        }
      ]
    }
  ]
}