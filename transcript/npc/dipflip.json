      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Dipflip",
              "text": "Who you?"
            },
            {
              "speaker": "Player",
              "text": "Me [goblin name]. Who you?"
            },
            {
              "speaker": "Dipflip",
              "text": "Me Dipflip."
            },
            {
              "speaker": "Player",
              "text": "What you doing, Dipflip?"
            },
            {
              "speaker": "Dipflip",
              "text": "Me thinking."
            },
            {
              "speaker": "Player",
              "text": "What thinking?"
            },
            {
              "speaker": "Dipflip",
              "text": "Me have big idea for High Priest. It big goblin competition to see who best goblin. Only strongest goblin win. Me call it Goblin League."
            },
            {
              "speaker": "Player",
              "text": "You have good idea, Dipflip."
            },
            {
              "speaker": "Dipflip",
              "text": "You think so?"
            },
            {
              "speaker": "Player",
              "text": "Yes. High Priest and others be stupid to not see value of Goblin League."
            },
            {
              "speaker": "Dipflip",
              "text": "Yes. Goblin League good. Me know it."
            },
            {
              "speaker": "Player",
              "text": "I leave you to think."
            },
            {
              "speaker": "Player",
              "text": "You have bad idea, Dipflip."
            },
            {
              "speaker": "Dipflip",
              "text": "You wrong. Goblin League good. Me know it."
            }
          ]
        }
      ]
    }
  ]
}