          ]
        },
        {
          "title": "Speaking to a guard in a pair",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Rightie",
                  "text": "Are you all right? Leftie?"
                },
                {
                  "speaker": "Leftie",
                  "text": "No, I'm on the left."
                },
                {
                  "speaker": "Rightie",
                  "text": "Only from your perspective. Someone entering the gate should call you Rightie, right Leftie?"
                },
                {
                  "speaker": "Leftie",
                  "text": "Right, Rightie. So you'd be Leftie not Rightie, right?"
                },
                {
                  "speaker": "Rightie",
                  "text": "That's right Leftie, that's right."
                },
                {
                  "speaker": "Leftie",
                  "text": "Rightie-oh Rightie, or should I call you Leftie?"
                },
                {
                  "speaker": "Rightie",
                  "text": "No, Rightie's fine Leftie."
                },
                {
                  "speaker": "Player",
                  "text": "Aaagh! Enough! If either of you mention left or right in my presence I'll have to scream! Can I come through the gate?"
                },
                {
                  "speaker": "Leftie",
                  "text": "Don't let us stop you."
                },
                {
                  "speaker": "Rightie",
                  "text": "Yes, head right on in, [sir/madam]."
                },
                {
                  "speaker": "Player",
                  "text": "You said it! You said it! ARRRRRRRRGGH!"
                }
              ]
            }
          ]
        }
      ],
