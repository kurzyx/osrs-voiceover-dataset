            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hello."
                },
                {
                  "speaker": "Gnome child",
                  "text": "To be or not to be."
                },
                {
                  "speaker": "Player",
                  "text": "Hey I know that. Where's it from?"
