          "title": "During or after completing Underground Pass",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Player",
                  "text": "Hi there, you okay?"
                },
                {
                  "speaker": "Kamen",
                  "text": "Ooooh, my head... I'm fried."
                },
                {
                  "speaker": "Player",
                  "text": "What's wrong?"
                },
                {
                  "speaker": "Kamen",
                  "text": "Too much of this home brew my friend. We make it from plant roots, but it blows your head off."
                },
                {
                  "speaker": "Kamen",
                  "text": "You don't wanna put it near any naked flames. I've got a barrel full of it here, want some?"
                },
                {
                  "speaker": "Player",
                  "text": "Okay then."
                },
                {
                  "speaker": "Kamen",
                  "text": "Here you go... Hic!"
                },
                {
                  "speaker": "Player",
                  "text": "Aaarrgghh!"
                },
                {
                  "speaker": "Kamen",
                  "text": "Ha ha! I warned you that it's strong stuff. Have a good meal. It may sober you up a bit. I could part with some food for a few coins."
                },
                {
                  "speaker": "Kamen",
                  "text": "75 coins pleashe."
                },
                {
                  "speaker": "Kamen",
                  "text": "You'll need to make some room in your inventory first."
                },
                {
                  "speaker": "Kamen",
                  "text": "75 coins pleashe."
                },
                {
                  "speaker": "Player",
                  "text": "Oh dear, I haven't enough money..."
                },
                {
                  "speaker": "Kamen",
                  "text": "Sorry, I can't just give it away to anyone that walks past."
                },
                {
                  "speaker": "Player",
                  "text": "Okay then."
                },
                {
                  "speaker": "Kamen",
                  "text": "75 coins pleashe."
                },
                {
                  "speaker": "Kamen",
                  "text": "Enjoy."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                },
                {
                  "speaker": "Kamen",
                  "text": "Well come back any time."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                },
                {
                  "speaker": "Kamen",
                  "text": "Your losh... Hic!"
                },
                {
                  "speaker": "Kamen",
                  "text": "Well maybe a good meal? I could part with some food for a few coins."
                }
              ]
            }
          ]
