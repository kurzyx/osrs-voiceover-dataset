  "categoryRef": "npc",
  "title": "Metla",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Metla",
              "text": "Yeah? Need something?"
            },
            {
              "speaker": "Player",
              "text": "What do you have?"
            },
            {
              "speaker": "Metla",
              "text": "Rock. Lots of it."
            },
            {
              "speaker": "Player",
              "text": "What brings you here?"
            },
            {
              "speaker": "Metla",
              "text": "Rock. This here is Stonecutter Outpost. We get rock, cut it, then sell it."
            },
            {
              "speaker": "Player",
              "text": "So you're pretty far from home then?"
            },
            {
              "speaker": "Metla",
              "text": "What? No. We go back to Cam Torum sometimes, but this is home."
            },
            {
              "speaker": "Player",
              "text": "Fair enough."
            },
            {
              "speaker": "Metla",
              "text": "Need something else?"
            },
            {
              "speaker": "Player",
              "text": "I'm good."
            },
            {
              "speaker": "Metla",
              "text": "Then why you keep staring? Get gone!"
            }
          ]
        }
      ]
    }
  ]
}