  "hashesWithUnresolvedText": {
    "4c70b3322757007f4f2d420364c0aff3cabbe7a61e0193b2f41d2505a68cdcca": {
      "text": "Greetings, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "c3abbfbe38b50e45999e4d565425efcaad9f5f1eabd294c0dfcfef6513d17686": {
      "text": "That is an area that - luckily for you, young [player name] - I have studied. Have you heard of the diplomat known as Charos?",
      "placeholders": [
        "[player name]"
      ]
    },
    "899d1d7f825d0cf8da1821dc4f6f807ce5fde823bd2d07eb756e595109710aae": {
      "text": "... Congratulations! You have clearly got what it takes to use the Ring of Charos. Wait a moment, [player name]...",
      "placeholders": [
        "[player name]"
      ]
    },
    "2401bbf3281d836e1eb2b0ccba5bd251d8a8495424bb7babe6a031f29b79cbda": {
      "text": "The Ring of Charos has now been opened to you, [player name]. You may use its power to charm the weak-minded, but it will only work whilst you are wearing it.",
      "placeholders": [
        "[player name]"
      ]
    },
    "a09bea38e5184a55c618889538cc2bc162666f328378ba23bf8a7dafaf5b5e06": {
      "text": "Ha ha! I thought you might try that!! But remember, [player name] - the power of the Ring of Charos will not work with everybody, especially not a wise old bird like me!",
      "placeholders": [
        "[player name]"
      ]
    },
    "5ed724048cb4fed5019562be39c2e4ff09e82ab1075f113fec975b76bd0efbcd": {
      "text": "Just joking, [player name] - good good, I will now tell you what this ring is capable of.",
      "placeholders": [
        "[player name]"
      ]
    },
    "eaf240d9fbb5f2efcde13529eeb39e7b8be32f1633120cbaa2054cc39ca448c9": {
      "text": "It's good of you to pop in, [player name]. What brings you to Draynor today?",
      "placeholders": [
        "[player name]"
      ]
    },
    "adabc276618a5231d0dd0864c306089dca482ee0af32944b1a688f2752743556": {
      "text": "I don't think I could get in there either, even if the smell weren't abhorrent. But [player name] might be able to fit.",
      "placeholders": [
        "[player name]"
      ]
    },
    "042ec49c20d685044e2aca759bfedff33ba65175628639c538436db42fdbc698": {
      "text": "[player name], you heard Odd Mushroom's warning. We can't use our teleport magicks, so the only escape - for you - is down the smelly hole.",
      "placeholders": [
        "[player name]"
      ]
    },
    "f6733da588334768c12de515870b3c6104ad50410e427142486cde8bb660a86b": {
      "text": "As you wish. Farewell, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "48e828abfb74d0cd2b730351460b53ef909c72e7b347780a6df358bfdc75f8dc": {
      "text": "Hello again, [player name]! I must thank you for persuading me to come - I feel quite invigorated in the sea breeze!",
      "placeholders": [
        "[player name]"
      ]
    },
    "193d64531605a574521c7366cbf8b853e7f7635572e0fcb45c8c7ea3000571aa": {
      "text": "Hello, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "3a6518a21c38c6f7557774ef89ce78b7859a29759428ebab9a743823d5faee79": {
      "text": "So what you need to do, [player name], is to fetch us an army!",
      "placeholders": [
        "[player name]"
      ]
    },
    "0630a176850600e43b57396028844302c441cbd3ebc4abd6747e067cb1414365": {
      "text": "Do get a move on, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "5b87ab970573f83d74b66e66c3dc37360edde918723da8e6c518dba00c00a808": {
      "text": "Well, I suppose so. [player name], this could be VERY dangerous. Do you feel ready to fight?",
      "placeholders": [
        "[player name]"
      ]
    },
    "1e4def096b31426418558e309a90199bd0012b9ea8454da6fac9ef8d0867ee44": {
      "text": "I... can't... move... [player name], you must fight this for me...",
      "placeholders": [
        "[player name]"
      ]
    },
    "2ee82fff33e34fee2f769b3aebd85503a32e27fad63010fe62e48a456c40d1e5": {
      "text": "Your fight was truly magnificent, [player name]! Congratulations!",
      "placeholders": [
        "[player name]"
      ]
    },
    "f47faf34381eb45ad7c29929691cfc64a3d061890295860cafc61f86316edacd": {
      "text": "I just wanted to say congratulations [player name]. I've been watching you in your adventures - very well done.",
      "placeholders": [
        "[player name]"
      ]
    },
    "baf4dbbd5f4c87d0ae33453708ee0a7dd3d6a8171a5812066edc6c9d6068dfb2": {
      "text": "Deary me, [player name], your imagination is running wild! What could make you think you saw me do that?",
      "placeholders": [
        "[player name]"
      ]
    },
    "dba153e41ace3f507f5d100a544d631f4cfe58d6fd3a5a3aa2d8698756c60d8d": {
      "text": "I need some bronze bars. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3e462d435f1eed05f670e3631d65bab87f5a5accbe879c9429c2f0ffff70e79b": {
      "text": "I need a few bronze daggers to keep the goblins at bay. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3d7be889f09f469da37f1e21be88848d3fc871efedfeb3b78fd51d1e8f46107d": {
      "text": "I'd like some maces made of bronze. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "c827e138b7935b657e6830fb3daf4b7944cc9d7aceb571d9824e8ebb67254f2d": {
      "text": "I need a few bronze arrowheads to complete some arrows I was making. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "0d109db54083fa218a3c76a19d47d7f7eee44204005fda64a833b270f007916c": {
      "text": "I'd like some bronze knives to throw at goblins. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "5713d615d9e0f925377173ebb705303af9b5d3212ef3aa35116b27a08939843e": {
      "text": "My weapons collection isn't all it used to be. Some short swords made of bronze would be much appreciated. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "80b56d6021972b9f0eb1b6fec2c116b6173bdabcb103748810449e1be9edb394": {
      "text": "The head fell off my axe when I was chopping wood last week, so I need some more bronze axes. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "97a59af4d1c069634522d098cbbd20858e415b9c59099e8c6267b332d2c9a072": {
      "text": "Could you fetch me some big warhammers made of bronze? Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "0ccbbf7e9ea16a597694b07e05b0a53ca608ea5214c06111b88a2811815451ac": {
      "text": "I could do with some medium-sized helmets. I'd like bronze ones. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "893c5a62f3e2c27937c582bf7d381d632845cb70e265132d0e2e50f7067fa79b": {
      "text": "I need some lengths of bronze wire to repair something. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "2eed6195d0b8d3129dbb94682bea3375c21228fc0cdcaf359c1e01f178e5f827": {
      "text": "I need some iron bars. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "75e8414f136cdce1200e4d8e8c228b4d6af581a1227a5e5022cb9e7f9a637501": {
      "text": "I need some iron arrowheads to put on the arrows I was making. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "99c80f060a71fb220aa03c16c0445d6912c3284059a559a9866fad04448cd693": {
      "text": "I could do with some iron throwing knives to keep the goblins away from my house. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "90e7864331012dea1f1665744eaa198532c641e6259ae1e36f1531827f4d90d7": {
      "text": "I'd like some chunky iron warhammers. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "17425b091e7696f0f565027c072c24a3b494dfaf701f8230913767741d627902": {
      "text": "Some iron maces would be useful. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "433a24a4bbf8aa7c098a87e173d2743405b0c49b372fa63fd48bcecb3396bb62": {
      "text": "A few lumps of iron ore would be nice. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3d3c9fabfebb30c38774d4790615acb2741bbccc854fa070ba09bf57cb94b006": {
      "text": "I've found a use for cadava berries. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3aca002a6bcb4629c4bcef75c7f7cb47d06b712c86d7a5745a9e92b2ed7dc4d3": {
      "text": "The hail can be very heavy here, so I'd like a few leather cowls. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "32475b592c461bacc4e78f441c917e8306275d801cfd5acf89bd7141904eaf8b": {
      "text": "Strange as it may seem, I want a lot of beer! Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "baefdb466cd5b3f977b6b8d4c7aaf8bd2d8f0cd2f158eccc9b284ab60bbd5cfc": {
      "text": "I don't have a decent larder here, so I can't store food very well. Now I'm out of loaves of bread. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "5757dc3e70c0466490f035e9c62b3df993b16d48a7e7d8972d5a04e18d430255": {
      "text": "I'll be needing a few pieces of soft leather. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "59fa2842e807c443eb4bf0f906c5d3eab7f0ecafe2f18c375c4f711590e914be": {
      "text": "I saw an interesting bed in Karamja called a 'hammock'. It seemed to be made out of string, and I'd like some balls of wool so I can make my own. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "57613bae7b1a7a5fe796c8aa6ca7166cc6736b615c898b939b21c2afb29b345a": {
      "text": "It's a bit nippy in this house, and my hands are cold. I need some leather gloves. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "525998867a3a59456c96f6b7fe82412066e4756e7150f420644cd58071446ebb": {
      "text": "I'm going to make an omelette, so I'll need some eggs. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "436d2221429cd157428da62c10442bc3888ff586a5c970f383ccb4276fcefee2": {
      "text": "My undergarments are getting a bit worn out. I'll be needing some sheets of silk to patch them. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "251b60cf736e07f6a3c4769aa973eea93c5f314b5aa053eaab2a7b6ff79a1381": {
      "text": "I'll need some clay that's been softened so I can craft it. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "d895e7e723b9c47547010bceadaa23f5b39a7d8a0d741a71b7786a5b00f850f7": {
      "text": "Believe it or not, I need a few unfired clay pots. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "075599899d52b9bc6e670b36e0401237a93dacafed404971caa92790f0a7d111": {
      "text": "My roof is leaking, so I need some swamp paste to fix it. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "bbb3831cab44cdfd5da2c9558013262ad79c92157c394d503f1e7988b2f2434e": {
      "text": "I need some potatoes, if you'd be so kind. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "52163de837c8b8e510ffd591c4e3d0d7f2e52ba571b12797f3fb6af69404d194": {
      "text": "I want to make some arrows, so I'll need some headless arrows that have the feathers attached. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "cf46241d4e79e4e5f95d529986e1e7192ca82e3505d53ca123fc9212f6b625e6": {
      "text": "I need some bronze spears. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "e868029505b1ba63c1043b53781ea696196fa17c5e3635d08e838448dbdedfd9": {
      "text": "My glassware got damaged when I moved here, so I need some new beer glasses. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "dc73bc567c55a4da93e6e1d58e106a359430d71194ac9711764d8cadf393f260": {
      "text": "My plans for today require some sets of bones, the normal-sized sort you get from goblins. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "29d1ea92f8a93d6180847eaa13a38e76f6aadc4cdd5726220e0ff0578c8f4d9b": {
      "text": "Strange as this may seem, I need some unfired pie dishes. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "6eb807f5f77fae116bc4fbfd2853ab7f8f573d846a131c3baf92f71ac99d08ad": {
      "text": "I hear pet cats are getting popular these days. I'd like some raw rat in case I get one. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "a075ab84722b62177ec20062826226d81b2bcb7e14fcd50cf2d9bbc279961b4e": {
      "text": "I need a few lumps of copper ore. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3c019f349d4e58570918f1f224b22caa5d20184f764cfa7d54381f21c7c81a2f": {
      "text": "I'm out of flour, so I could do with a few pots of that. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "34555d49b61761981941b7169573584773bdba7d35fbfe2902cc144dc5be6ab1": {
      "text": "I need a handful of feathers to stick in my beard. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "81f43d631d6ae824e20d5f235f494d91d18a5c350148bd8c3c184be7306ece91": {
      "text": "This house is a bit cold, so I could do with some normal logs to burn. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "fd4464bac5d27ddc23c98a820c1bd5a4c4d36306d4019e4470dff5c534a3d716": {
      "text": "I'm running short of food, so I'd like some cooked chickens. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "8507992d2e1250bbbd988482cff86ec2763d90fe127f2dc2456d0434d9fef762": {
      "text": "My footwear is getting a bit worn out, so I need a few pairs of leather boots. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "0b46a794852eeda5b3950bda2b8bf5dcaa74ec3ce8b5934deb5a431a604d49b4": {
      "text": "I'd like a few cowhides. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "3ef664957be588674661fcd7ad1a14267b7bb15cd8fdb7d59042316991c3f6ea": {
      "text": "My shortbow's string is getting a bit worn out, so could you fetch me some bow strings? Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "68764974de5d863ba27793634e097d8b607ccbfeabef27c5205492cd631d97e9": {
      "text": "I'm a bit hungry. I'd like some cooked meat, not chicken or any sort of bird. And definitely not camel or rabbit either! Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "2a2f0d3d6d228982fae3735e18e117b457302dd3e34704f9e40a4073ec0576ce": {
      "text": "I'm short of ammunition, so I could do with some bronze arrows. That way I can shoot at goblins through my window. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "1190f5b8f4ac111e84441f03f41f5ff1e3277dfaf5d88952b9d68d55e39a2569": {
      "text": "I'd like a bit of grain. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "0dc9d4e652143ca14a53294ce318fbf0edddc47f8fbe4fcba6c92804d9794bfd": {
      "text": "I need a few lumps of tin ore. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "57a7a5e6bf18f27dfd247efa8696161dc5423b088a9675ebf8a1a76532def32c": {
      "text": "I could do with some freshly cooked anchovies for a salad I'm planning. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "77085fa542ba0d940e1fe259f2a5d69ee9db17edb890531dd5c1ea39e4172e03": {
      "text": "I could do with some freshly cooked shrimps for a salad I'm planning. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "315dafbb1da5418e43561f4f6dbfaac34e5e68231902151cccb49fcf1d32bd98": {
      "text": "I'd like to study the rune essence that the wizards have been talking about recently, so I need a few pieces. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "dc99816ce40938a60cced9dff995107c98fde54aa3fe73ae166334965130378f": {
      "text": "Some chunks of molten glass would be the ideal patch for my cracked window. Please bring me [#].",
      "placeholders": [
        "[#]"
      ]
    },
    "0ff3806bc90ca706971084ecb0cb36e3b24dd25239ce357629ed723439ef7626": {
      "text": "Greetings, [player].",
      "placeholders": [
        "[player]"
      ]
    }
  }
