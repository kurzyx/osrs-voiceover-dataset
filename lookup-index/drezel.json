      ]
    },
    "f22b3e046c38fddfb29c5e524f815d217fdea4d27cb5c21d4fda1547c36ade8e": {
      "text": "You can be sure that a great many people hope for exactly the same thing, [player name]. Good luck to you, and Myreque prevail!",
      "placeholders": [
        "[player name]"
      ]
    },
    "3c54647b1b0c18e8c7c1020fcf48320fa8f227294f267ef0e82be8cd4534ddc0": {
      "text": "Well done for bringing Ivan to the temple, [player name]. He will be much safer here.",
      "placeholders": [
        "[player name]"
      ]
    },
    "e47d4fc9b40a41ebe7b3f7d2f471dd560374c43a3278cfb38c1310fba47a0df9": {
      "text": "Many thanks to you, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "942350659f857c3dde120314878f3062dafa9cfae6d4f42156da40f31177b829": {
      "text": "Ah, [player name]. Glad you made it. Things are worse than I feared down here. I'm not sure if I will be able to repair the damage.",
      "placeholders": [
        "[player name]"
      ]
    },
    "b260c7314ec159d7ff6ccbbca81340d7768a782d31d39e3e847f06f6fa332580": {
      "text": "Thank you. I need [1-50] more.",
