      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Fadli",
              "text": "What?"
            },
            {
              "speaker": "Player",
              "text": "What do you do?"
            },
            {
              "speaker": "Fadli",
              "text": "You can store your stuff here if you want. You can dump anything you don't want to carry whilst you're fighting duels and then pick it up again on the way out."
            },
            {
              "speaker": "Fadli",
              "text": "To be honest I'm wasted here."
            },
            {
              "speaker": "Fadli",
              "text": "I should be winning duels in an arena! I'm the best warrior in Al Kharid!"
            },
            {
              "speaker": "Player",
              "text": "Easy, tiger!"
            },
            {
              "speaker": "Player",
              "text": "What is this place?"
            },
            {
              "speaker": "Fadli",
              "text": "Isn't it obvious?"
            },
            {
              "speaker": "Fadli",
              "text": "This is the Emir's Arena...duh!"
            },
            {
              "speaker": "Player",
              "text": "I'd like to access my bank, please."
            },
            {
              "speaker": "Fadli",
              "text": "Sure."
            },
            {
              "speaker": "Player",
              "text": "I'd like to collect items."
            },
            {
              "speaker": "Fadli",
              "text": "Yeah, okay."
            },
            {
              "speaker": "Player",
              "text": "Do you watch any matches?"
            },
            {
              "speaker": "Fadli",
              "text": "When I can. I used to throw rotten fruit at them, though I can't do that anymore. Wanna buy some? I've plenty to spare."
            },
            {
              "speaker": ">",
              "text": "Sure, I'll but some rotten fruit."
            },
            {
              "speaker": "Player",
              "text": "Sure, I'll buy some rotten fruit."
            },
            {
              "speaker": ">",
              "text": "No, I'm not giving you money for rotten fruit."
            },
            {
              "speaker": "Player",
              "text": "No, I'm not giving you money for rotten fruit."
            },
            {
              "speaker": "Fadli",
              "text": "Suit yourself."
            },
            {
              "speaker": ">",
              "text": "Goodbye, Fadli."
            },
            {
              "speaker": "Player",
              "text": "Goodbye, Fadli."
            }
          ]
        }
      ]
    }
  ]
}