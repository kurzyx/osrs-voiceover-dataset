{
  "ref": "mysterious-bandit",
  "categoryRef": "npc",
  "title": "Mysterious Bandit",
  "sections": [
    {
      "title": "First time speaking",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Mysterious Bandit",
              "text": "I have something for you."
            },
            {
              "speaker": "Player",
              "text": "You're looking very shady."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "I'm here for good reason, [player name]."
            },
            {
              "speaker": "Player",
              "text": "How do you know my name?"
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "You and I share a common friend."
            },
            {
              "speaker": "Player",
              "text": "Azzanadra?"
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Indeed."
            },
            {
              "speaker": "Player",
              "text": "Why are you here?"
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Ever heard of criminals returning to the scene of the crime? Thats why."
            },
            {
              "speaker": "Player",
              "text": "I'm not sure this one is going to return any time soon."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Well never say never, [player name]. Now be on your way."
            },
            {
              "speaker": "Player",
              "text": "Azzanadra offered me a ring..."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "And you need me to give it to you?"
            },
            {
              "speaker": "Player",
              "text": "Pretty much."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Take good care of that. It's very poweful."
            },
            {
              "speaker": "Player",
              "text": "I need another ring."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Very well, but it will cost you..."
            },
            {
              "speaker": "Player",
              "text": "I'd best get going."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Until next time, [player name]."
            }
          ]
        }
      ]
    },
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Mysterious Bandit",
              "text": "Hello again, [player name]. Azzanadra asked me to give you this."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Hello again, [player name]."
            },
            {
              "speaker": "Player",
              "text": "Don't you get bored down here?"
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Not really. I like the peace and quiet. It's also a far more reasonable temperature than outside."
            },
            {
              "speaker": "Player",
              "text": "Good points."
            }
          ]
        }
      ]
    },
    {
      "title": "Historical dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Azzanadra gave me a ring..."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "And you need me to replace it?"
            },
            {
              "speaker": "Player",
              "text": "Pretty much."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "It'll cost you."
            },
            {
              "speaker": "Player",
              "text": "How much we talking?"
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "75,000 of your finest gold coins."
            },
            {
              "speaker": "Player",
              "text": "Seems I don't have enough coins..."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Well off you go then."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "You will need some space to hold it first."
            },
            {
              "speaker": "Mysterious Bandit",
              "text": "Take good care of that. It's very poweful."
            }
          ]
        }
      ]
    }
  ]
}