                  "text": "It's [player name] again!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "What do you want?"
                },
                {
                  "speaker": "Player",
                  "text": "Can I have another rat pole please?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Here you go."
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Stick the ratsies your cat splats on it!"
                },
                {
                  "speaker": "Player",
                  "text": "Er... will do."
                },
                {
                  "speaker": "Phingspet",
                  "text": "Anything else?"
                }
              ]
            }
          ]
        }
