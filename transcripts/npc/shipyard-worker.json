      "dialogues": []
    },
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Player",
              "text": "Quite a few ships you're building!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "This is just the start! The completed fleet will be awesome!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Shipyard worker",
              "text": "No time to talk we've a fleet to build!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Shipyard worker",
              "text": "Hello matey!"
            },
            {
              "speaker": "Player",
              "text": "How are you?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Tired!"
            },
            {
              "speaker": "Player",
              "text": "You shouldn't work so hard!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Player",
              "text": "Quite an impressive set up!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "It needs to be. There's no other way to build a fleet of this size!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Shipyard worker",
              "text": "Hello there. I haven't seen you before."
            },
            {
              "speaker": "Player",
              "text": "I'm new!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Well it's hard work, but the pay is good."
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Player",
              "text": "How are you?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Too busy to waste time gossiping!"
            },
            {
              "speaker": "Player",
              "text": "Touchy!"
            },
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Player",
              "text": "Looks like hard work."
            },
            {
              "speaker": "Shipyard worker",
              "text": "I like to keep busy."
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Player",
              "text": "So where are you sailing?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "What do you mean?"
            },
            {
              "speaker": "Player",
              "text": "Don't worry, just kidding!"
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Hello there, are you too lazy to work as well?"
            },
            {
              "speaker": "Player",
              "text": "Something like that."
            },
            {
              "speaker": "Shipyard worker",
              "text": "I'm just sun bathing!"
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "No time to talk we've a fleet to build!"
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Player",
              "text": "What are you building?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Are you serious?"
            },
            {
              "speaker": "Player",
              "text": "Of course not! You're obviously building a boat."
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "I'm getting tired of this!"
            },
            {
              "speaker": "Player",
              "text": "What?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Breaking my back for pennies! It's just not on!"
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "What do you want?"
            },
            {
              "speaker": "Player",
              "text": "Is that any way to talk to your new superior?"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Oh, I'm sorry, I didn't realise!"
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Ouch!"
            },
            {
              "speaker": "Player",
              "text": "What's wrong?!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "I cut my finger!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Do you have a bandage?"
            },
            {
              "speaker": "Player",
              "text": "I'm afraid not."
            },
            {
              "speaker": "Shipyard worker",
              "text": "That's ok, I'll use my shirt."
            },
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Shipyard worker",
              "text": "Can I help you?"
            },
            {
              "speaker": "Player",
              "text": "I'm just looking around."
            },
            {
              "speaker": "Shipyard worker",
              "text": "Well there's plenty of work to be done, so if you don't mind..."
            },
            {
              "speaker": "Shipyard worker",
              "text": "Of course. Sorry to have disturbed you."
            }
          ]
        }
      ]
    }
  ]
