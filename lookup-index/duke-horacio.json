  "hashesWithUnresolvedText": {
    "22737c8266da83a188a9b87d7a204e0e3ac4679f33a5510bfd8c503bc9fd655d": {
      "text": "Hello again, Zanik, [player name]. I hope you are enjoying your tour. Perhaps someday a human can have a similar tour of your city.",
      "placeholders": [
        "[player name]"
      ]
    },
    "72c349682a95d9566a5c27b51e860aa9ea6655e033a62bd386f10c1be6e2e621": {
      "text": "[Player name], please find out what you can about this brooch. The librarian in Varrock might be able to help identify the symbol.",
      "placeholders": [
        "[Player name]"
      ]
    },
    "8421c1b991b6400ad50ab0c1902f1038b3eacf573c32e39c8c434c7f0b1d9ba5": {
      "text": "[Player name], I would still like you to find out more about this tribe. It cannot hurt to know one's enemy.",
      "placeholders": [
        "[Player name]"
      ]
    },
    "e88e858571cda676734c8a01180668404cd16265960003f4895574c3e5dc08d4": {
      "text": "[Player name], Lumbridge is in your debt. Please accept this ring as a token of my thanks.",
      "placeholders": [
        "[Player name]"
      ]
    },
    "9da18fb48c87490446de5f710102faec522056e9bb7419fd2d522ecfce43b9b1": {
      "text": "[player name]! So glad you could make it. I really do appreciate you rounding up all those monkeys for us.",
      "placeholders": [
        "[player name]"
      ]
    },
    "0f5fa58c1779c6189f78cd30a486efcfd24a4aa8a875d0a821361b7eaa4cb512": {
      "text": "I am grateful for your help, [player name]. If you could free up an inventory space, I wish to reward you.",
      "placeholders": [
        "[player name]"
      ]
    },
    "599eaf58ae667ffadca6a130c070dd5e994ebff9f1576109fa557ed7515321a5": {
      "text": "I am grateful for your help, [player name]. As proof of my gratitude, I have arranged a reward for you!",
      "placeholders": [
        "[player name]"
      ]
    },
    "421bed02a67f3aa11c1000cf9446f5ac952607c96b61753d2745ca97dc3f7364": {
      "text": "Ah, [player name]. I hope you are enjoying the party?",
      "placeholders": [
        "[player name]"
      ]
