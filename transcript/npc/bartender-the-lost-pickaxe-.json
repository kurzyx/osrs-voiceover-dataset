          "lines": [
            {
              "speaker": "Bartender",
              "text": "A human in The Lost Pickaxe? My old pa would be fuming. Still, business is business I guess. What can I get you?"
            },
            {
              "speaker": "Player",
              "text": "What do you have?"
            },
            {
              "speaker": "Bartender",
              "text": "Take a look."
            },
            {
              "speaker": "Player",
              "text": "Nothing thanks."
            },
            {
              "speaker": "Bartender",
              "text": "So you're just lurking here? Pa always said your kind were freaks."
            }
          ]
        }
      ]
    }
  ]
}