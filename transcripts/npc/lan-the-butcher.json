      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Lan the Butcher",
              "text": "What d'ya want?"
            },
            {
              "speaker": "Player",
              "text": "Just exploring the far reaches of this wonderful land."
            },
            {
              "speaker": "Lan the Butcher",
              "text": "Why?"
            },
            {
              "speaker": "Player",
              "text": "For gold! For glory!"
            },
            {
              "speaker": "Lan the Butcher",
              "text": "You got gold?"
            },
            {
              "speaker": "Player",
              "text": "Maybe a little..."
            },
            {
              "speaker": "Lan the Butcher",
              "text": "Well, I'm a butcher, I'll be 'appy to perhaps trade you, that I would."
            },
            {
              "speaker": "Player",
              "text": "I don't see any product around here..."
            },
            {
              "speaker": "Lan the Butcher",
              "text": "Heh, o' course not. I keep it down in the basement, that I do."
            },
            {
              "speaker": "Player",
              "text": "What basement?"
            },
            {
              "speaker": "Lan the Butcher",
              "text": "..."
            },
            {
              "speaker": "Player",
              "text": "..."
            },
            {
              "speaker": "Lan the Butcher",
              "text": "..."
            },
            {
              "speaker": "Player",
              "text": "I think I'll be leaving now."
            },
            {
              "speaker": "Lan the Butcher",
              "text": "Heh heh heh, that you should."
            }
          ]
        }
      ]
    }
  ]
}