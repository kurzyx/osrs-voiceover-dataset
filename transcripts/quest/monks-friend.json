                  "speaker": "Brother Omad",
                  "text": "Dum dee do la la! *hiccup* That was some party!"
                }
              ]
            }
          ]
        },
        {
          "title": "Talking to the Monks",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Monk",
                  "text": "*hic* What a party! Wow!"
                }
              ]
            }
          ]
        }
      ],
