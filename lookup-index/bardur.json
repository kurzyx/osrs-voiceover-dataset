  "hashesWithUnresolvedText": {
    "98d6222ff50b860f068708547b65869ff21cc41f29731bde0c10b07e3c187fb2": {
      "text": "Aye, that I can [fremennik name]! Yonder lies the lair of the daggermouth kings, the three beasts of legend!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "c4e46f912b41b282d89165285bb7d256583c74c8b456d1fac566b579ef293652": {
      "text": "Ah, you did not come prepared [fremennik name]?",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "f7c70cf51716048f46e78c28676046c9d878e15989ef0cdc48283d513e5ba5f2": {
      "text": "Ah, this will serve me well as a backup! My thanks to you [fremennik name], I trust we will one day sing songs together of glorious battles in the Rellekka longhall!",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "51a7d86a99a918333be96a2f6f9c0361599a9ab115d4986d6e42fbf5bb59088f": {
      "text": "As you wish, [fremennik name] My weapons have lasted me this long, I will keep my trust in them yet.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "a3f1450476d32b23ede58de0317f8d613686236827b16db2b369a005933ea925": {
      "text": "No [fremennik name], I will trade you my finely cooked shark for a trusty Fremennik blade, a sturdy Fremennik helm, or a mighty Fremennik shield...",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "6b40fd4244107680649bef60775107fafed0dee6b6f73fd6f0a25aa0dbf52ac2": {
      "text": "Listen, [fremennik name]. I'm sorry about the way I acted while you were exiled. Bardur gets hostile around outerlanders.",
      "placeholders": [
        "[fremennik name]"
      ]
    },
    "301984eb270c8b0a8dc5c1c384ec5f6341b0141ee9a22ea09c0a8865cc7774b5": {
