  "title": "Anja",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello."
            },
            {
              "speaker": "Anja",
              "text": "Hello sir. What are you doing in my house?"
            },
            {
              "speaker": "Player",
              "text": "I'm just wandering around."
            },
            {
              "speaker": "Anja",
              "text": "Oh dear, are you lost?"
            },
            {
              "speaker": "Player",
              "text": "Yes, I'm lost."
            },
            {
              "speaker": "Anja",
              "text": "Okay, just walk north-east when you leave this house, and soon you'll reach the big city of Falador."
            },
            {
              "speaker": "Player",
              "text": "Thanks a lot."
            },
            {
              "speaker": "Player",
              "text": "No, I know where I am."
            },
            {
              "speaker": "Anja",
              "text": "Oh? Well, would you mind wandering somewhere else? This is my house."
            },
            {
              "speaker": "Player",
              "text": "Meh!"
            },
            {
              "speaker": "Player",
              "text": "I was hoping you'd give me some free stuff."
            },
            {
              "speaker": "Anja",
              "text": "Do you REALLY need it?"
            },
            {
              "speaker": "Anja",
              "text": "Er..."
            },
            {
              "speaker": "Anja",
              "text": "I don't have much on me..."
            },
            {
              "speaker": "Anja",
              "text": "I don't know..."
            },
            {
              "speaker": "Player",
              "text": "(beg beg beg beg beg beg)"
            },
            {
              "speaker": "Player",
              "text": "I promise I'll stop bothering you!"
            },
            {
              "speaker": "Player",
              "text": "Pleeease!"
            },
            {
              "speaker": "Player",
              "text": "Pwetty pleathe wiv thugar on top!"
            },
            {
              "speaker": "Anja",
              "text": "Oh, alright. Here you go."
            },
            {
              "speaker": "Anja",
              "text": "Eeeek!"
            },
            {
              "speaker": "Hengel",
              "text": "Aaaarrgh!"
            }
          ]
        }
      ]
    }
  ]
}