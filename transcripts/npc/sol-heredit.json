            },
            {
              "title": "Perfectly parrying the grapple attack",
              "sections": [],
              "dialogues": [
                {
                  "lines": []
                }
              ]
            }
          ],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "I'LL BREAK YOUR BACK!"
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I'LL CRUSH YOUR BODY!"
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I'LL TWIST YOUR HANDS OFF!"
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I'LL BREAK YOUR LEGS!"
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I'LL CUT YOUR FEET OFF!"
                }
              ]
            }
          ]
        },
        {
          "title": "Death",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "Your light shines... brightly..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "A worthy... opponent..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Ralos has smiled upon you..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "My compliments, champion..."
                }
              ]
            }
          ]
        },
        {
          "title": "Killing the player",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Sol Heredit",
                  "text": "How disappointing..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I knew you weren't the one."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "You had me excited for a moment."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Your lack of coordination is concerning."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Your light shines no more."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Maybe next time..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "Pathetic, really..."
                },
                {
                  "speaker": "Sol Heredit",
                  "text": "I was just getting into my rhythm..."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
