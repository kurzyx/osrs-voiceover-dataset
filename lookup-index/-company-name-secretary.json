      ]
    },
    "de96f50af95a10fb0035bad500a6ebb70cdb726d99c43921f80f37b9b2181658": {
      "text": "The [company name] has noted your willingness to help.",
      "placeholders": [
        "[company name]"
      ]
    },
    "1526fab3b0779d3099a02207d6e62a8c769e70f221799377db4932ad2588e3d4": {
      "text": "You never disappoint, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "9346e9f5d0925692a731b14ffd34af78d53a89cd6c28bf275ad82d99e1021063": {
      "text": "The [company name] appreciates the hard work you do.",
      "placeholders": [
        "[company name]"
      ]
    },
    "908beae1c27e045e2a1c08c7fdcd6a5bfda74d4a24ef8d78fface9a347d41203": {
      "text": "The [company name] isn't too pleased to hear that.",
