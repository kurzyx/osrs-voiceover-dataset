          "lines": [
            {
              "speaker": "Barman",
              "text": "Good day to you. What can I get you to drink?"
            },
            {
              "speaker": "Player",
              "text": "I'm trying to do Alfred Grimhand's barcrawl."
            },
            {
              "speaker": "Barman",
              "text": "Oh, another silly human come to have [his/her/their] mind melted? You should take that barcrawl card to Blurberry - he always likes to serve the Fire Toad Blast himself!"
            },
            {
              "speaker": "Player",
              "text": "Um... thanks?!"
            },
            {
              "speaker": "Player",
              "text": "What do you have."
            },
            {
              "speaker": "Barman",
              "text": "Here, take a look at our menu."
            },
            {
              "speaker": "Player",
              "text": "Nothing thanks."
            },
            {
              "speaker": "Barman",
              "text": "Ok, take it easy."
            },
            {
              "speaker": "Player",
              "text": "I was just wanting to buy a cocktail ingredient actually."
            },
            {
              "speaker": "Barman",
              "text": "Sure thing, what did you want?"
            },
            {
              "speaker": "Player",
              "text": "A lemon."
            },
            {
              "speaker": "Barman",
              "text": "20 coins please."
            },
            {
              "speaker": "Player",
              "text": "An orange."
            },
            {
              "speaker": "Barman",
              "text": "20 coins please."
            },
            {
              "speaker": "Player",
              "text": "A cocktail shaker."
            },
            {
              "speaker": "Barman",
              "text": "20 coins please."
            },
            {
              "speaker": "Player",
              "text": "Actually nothing thanks."
            }
          ]
        }
      ]
