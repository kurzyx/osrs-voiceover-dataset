    {
      "title": "Standard dialogue after Darkness of Hallowvale",
      "sections": [
        {
          "title": "In Meiyerditch",
          "sections": [
            {
              "title": "When spoken to",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Player",
                      "text": "Hello?"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Get lost, food sack!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Get out of my face, meat sack, I don't 'play' with my food."
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Get about your business, meat sack, before I perforate you real good!"
                    },
                    {
                      "speaker": "Player",
                      "text": "Send me to the mines!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Very well..."
                    },
                    {
                      "speaker": "Player",
                      "text": "Sorry."
                    }
                  ]
                }
              ]
            },
            {
              "title": "When the player gets noticed",
              "sections": [],
              "dialogues": [
                {
                  "lines": [
                    {
                      "speaker": "Vyrewatch",
                      "text": "I want a word with you!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Stand where you are!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Halt! Halt, I say!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Slurp! You look positively delicious - let me help you lose a bit of weight! Either I get a bite or you can go to the mines; which is it to be, meat sack?"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Hmm, you look like a tasty specimen - in fact I'm quite peckish right now. You can either go to the mines or give me a bite; what do you say?"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Ooh, a meat sack... I could just do with a snack. What's it to be: some time in the mines or do I get a bite?"
                    },
                    {
                      "speaker": "Player",
                      "text": "Okay, have a bite."
                    },
                    {
                      "speaker": "Player",
                      "text": "Send me to the mines!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Very well..."
                    },
                    {
                      "speaker": "Player",
                      "text": "Hey, look over there!"
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "Ha! I'm not falling for that! Prepare to be tithed..."
                    },
                    {
                      "speaker": "Vyrewatch",
                      "text": "What? What? Where?"
                    }
                  ]
                }
              ]
            }
          ],
          "dialogues": []
        },
        {
          "title": "Next to the bank in Ver Sinhaza",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Vyrewatch",
                  "text": "Clear off food sack."
                },
                {
                  "speaker": "Player",
                  "text": "Could you send me to the mines?"
                },
                {
                  "speaker": "Vyrewatch",
                  "text": "You want to go to the mines? Well that's a new one. You asked for it though..."
                },
                {
                  "speaker": "Player",
                  "text": "Sorry."
                }
              ]
            }
          ]
        }
