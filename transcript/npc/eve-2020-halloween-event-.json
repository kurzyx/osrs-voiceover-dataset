  "ref": "eve-2020-halloween-event-",
  "categoryRef": "npc",
  "title": "Eve (2020 Halloween event)",
  "sections": [
    {
      "title": "Post-event",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hey Eve!"
            },
            {
              "speaker": "Eve",
              "text": "[player name]! You're back! Here to party some more?"
            },
            {
              "speaker": "Player",
              "text": "You never get sick of partying, do you?"
            },
            {
              "speaker": "Eve",
              "text": "Well, you see, I spend the rest of the year in the afterlife. And that is quite boring."
            },
            {
              "speaker": "Player",
              "text": "The afterlife?"
            },
            {
              "speaker": "Eve",
              "text": "Yes. You know, where you go when you die. Anyway, that's boring stuff. Coming back here is fun!"
            },
            {
              "speaker": "Player",
              "text": "How do you come back?"
            },
            {
              "speaker": "Eve",
              "text": "Magic, my friend!"
            },
            {
              "speaker": "Player",
              "text": "What kind of magic?"
            },
            {
              "speaker": "Eve",
              "text": "You wouldn't understand. If you're so interested, talk to the other people around here. They've returned from the afterlife as well!"
            },
            {
              "speaker": "Player",
              "text": "Have they? Interesting."
            },
            {
              "speaker": "Player",
              "text": "Goodbye."
            },
            {
              "speaker": "Eve",
              "text": "Come back soon!"
            }
          ]
        }
      ]
    }
  ]
}