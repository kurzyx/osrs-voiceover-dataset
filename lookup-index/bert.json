  "hashesWithUnresolvedText": {
    "ef8c02a5a6fe52abff904b96a453dc03edf7aa70cbeead5768e436cd665d18fe": {
      "text": "Wha' info ye find 'bout hand, [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "e2d096cfa73eaeae9c212bc45a5bf56c359613f6fcabbb924a260fe3885226af": {
      "text": "Ey'up [player name]. Did yer see Sandy in Brimhaven 'bout me rota?",
      "placeholders": [
        "[player name]"
      ]
    },
    "4f4acd5c5c36ebeb540b33dc98ed844e51e539bd4b1a5eb8202067f73c4de52d": {
      "text": "O'course [player name], le's be 'avin'yon rota and 'ere be tha scroll, yer be takin' it back ta those inferrrnal wizards quick sharp!",
      "placeholders": [
        "[player name]"
      ]
    },
    "18db7576c2f68f2b768ac95d16ba765632d92a559a4c3bfd219cfae210b05bf8": {
      "text": "I din't think so... bu' iffen yer ever need someone ta haul buckets o'sand 'round, ye be lettin' me know [player name], I's can help yer!",
      "placeholders": [
        "[player name]"
      ]
    },
    "e94ec130855c3826f311dbd69c61035d33f723367946225f522e30aeda16722e": {
      "text": "'Ello there [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "4c36891464cfd674cebff0a071aab012e3299d092726b1b49d7298f540d364a0": {
      "text": "Eeee, ye've go' no free space in yon bank [player name]. Make some room 'tween the fishes 'n boots fore ye come back ta me.",
      "placeholders": [
        "[player name]"
      ]
    },
    "8804421ac9527ef0a26189b5b44edf014e760aca86078b2e8ac34fe8fd74d458": {
      "text": "Suits me, [player name]! I be a wee bi' busy, an' I'll happily stop takin' sand to yer bank for ye. Come an' see me if ye changes yer mind.",
      "placeholders": [
        "[player name]"
      ]
    }
  }
