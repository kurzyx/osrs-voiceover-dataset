                {
                  "lines": [
                    {
                      "speaker": "General Hining",
                      "text": "Do not waste my time."
                    },
                    {
                      "speaker": "General Hining",
                      "text": "You have done well."
                    }
                  ]
                }
              ]
            }
          ],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "General Hining",
