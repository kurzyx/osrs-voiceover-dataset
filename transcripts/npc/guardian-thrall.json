            {
              "lines": [
                {
                  "speaker": "Guardian thrall",
                  "text": "You have everything you need to succeed."
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "I'll never leave your side!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Take it one day at a time."
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "You're doing great!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Eat up!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "I hope you get the drop soon!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "I believe in you!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Stay strong, you're doing great."
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "You're doing an incredible job!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Honey I'm home!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Your hard work is inspiring!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Great things are coming your way!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "I've got your back!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "You are capable of anything you believe in!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "You've come so far, don't stop now!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "It's okay to take break, you're still making progress."
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Don't forget how far you've come!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "I was taking a break!"
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "Your courage is your super power."
                },
                {
                  "speaker": "Guardian thrall",
                  "text": "What would you do without me?"
                }
              ]
            }
          ]
        },
