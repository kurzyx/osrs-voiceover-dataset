{
  "ref": "aabla",
  "categoryRef": "npc",
  "title": "A'abla",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hi!"
            },
            {
              "speaker": "A'abla",
              "text": "Hi. How can I help?"
            },
            {
              "speaker": "Player",
              "text": "Can you heal me?"
            },
            {
              "speaker": "A'abla",
              "text": "Sorry, I'm not on duty."
            },
            {
              "speaker": "A'abla",
              "text": "PLEASE DON'T KILL ME!"
            },
            {
              "speaker": "Player",
              "text": "I was... looking to be healed."
            },
            {
              "speaker": "A'abla",
              "text": "No way, I'm out of here just as soon as I've packed up my stuff!"
            },
            {
              "speaker": "A'abla",
              "text": "You look healthy to me!"
            },
            {
              "speaker": "A'abla",
              "text": "Of course!"
            },
            {
              "speaker": "Player",
              "text": "Do you see a lot of injured fighters?"
            },
            {
              "speaker": "A'abla",
              "text": "Yes I do. Thankfully we can cope with almost anything. Jaraah really is a wonderful surgeon, his methods are a little unorthodox but he gets the job done."
            },
            {
              "speaker": "A'abla",
              "text": "I shouldn't tell you this but his nickname is 'The Butcher'."
            },
            {
              "speaker": "Player",
              "text": "That's reassuring."
            },
            {
              "speaker": "Player",
              "text": "Do you come here often?"
            },
            {
              "speaker": "A'abla",
              "text": "I work here, so yes!"
            },
            {
              "speaker": "A'abla",
              "text": "You're silly!"
            }
          ]
        }
      ]
    }
  ]
}