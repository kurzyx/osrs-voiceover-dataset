  "title": "Retired sailor",
  "sections": [
    {
      "title": "Talking to the retired sailor",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Retired sailor",
              "text": "Do you have something you'd like to trade, young [man/woman]?"
            },
            {
              "speaker": "Player",
              "text": "What kind of trade can you offer?"
            },
            {
              "speaker": "Retired sailor",
              "text": "Well, we find a lot of soaked pages in our nets. If you've got something we really want, I could swap it for 25 soaked pages."
            },
            {
              "speaker": "Player",
              "text": "What is this place?"
            },
            {
              "speaker": "Retired sailor",
              "text": "Just a little place where we Spirit Anglers can store things, young [man/woman]. I used to be the chief mate on one of our ships, but now I just watch over the stores from the land."
            },
            {
              "speaker": "Retired sailor",
              "text": "Maybe you'd like to do a trade, though, while you're here?"
            },
            {
              "speaker": "Player",
              "text": "No."
            }
          ]
        }
      ]
    },
