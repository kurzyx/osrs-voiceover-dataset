  "ref": "captain-donnie",
  "categoryRef": "npc",
  "title": "Captain Donnie",
  "sections": [
    {
      "title": "Standard dialogue after Rum Deal",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Captain Donnie",
              "text": "Hey! You!"
            },
            {
              "speaker": "Player",
              "text": "Who? Me?"
            },
            {
              "speaker": "Captain Donnie",
              "text": "Aye! Ye!"
            },
            {
              "speaker": "Captain Donnie",
              "text": "Got any more rum?"
            },
            {
              "speaker": "Player",
              "text": "What happens if I don't?"
            },
            {
              "speaker": "Captain Donnie",
              "text": "Then I'll clap ye in Runes!"
            },
            {
              "speaker": "Player",
              "text": "Don't you mean clap me in irons?"
            },
            {
              "speaker": "Captain Donnie",
              "text": "No lad, not irons, Runes!"
            },
            {
              "speaker": "Captain Donnie",
              "text": "We upgraded last week."
            },
            {
              "speaker": "Player",
              "text": "Ok, well it's a good job that I have some over here isn't it?"
            },
            {
              "speaker": "Captain Donnie",
              "text": "Arr, yer a good lad..."
            }
          ]
        }
      ]
    }
  ]
}