      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello!"
            },
            {
              "speaker": "Elson",
              "text": "Hello, what an exquisite day."
            },
            {
              "speaker": "Player",
              "text": "It's lovely round here."
            },
            {
              "speaker": "Elson",
              "text": "I simply can't wait to enter The Nutcracker."
            },
            {
              "speaker": "Elson",
              "text": "I've been training for quite some time."
            },
            {
              "speaker": "Player",
              "text": "Oh yeah?"
            },
            {
              "speaker": "Elson",
              "text": "Indeed."
            },
            {
              "speaker": "Elson",
              "text": "In fact, I haven't slept for twelve days. HA."
            },
            {
              "speaker": "Player",
              "text": "A... are you okay?"
            },
            {
              "speaker": "Elson",
              "text": "Better than ever!"
            },
            {
              "speaker": "Player",
              "text": "Who's your little friend?"
            },
            {
              "speaker": "Elson",
              "text": "This is Gizmo, a dear friend of mine."
            },
            {
              "speaker": "Player",
              "text": "What a lovely name, he sure is handsome."
            },
            {
              "speaker": "Gizmo",
              "text": "No u."
            },
            {
              "speaker": "Gizmo",
              "text": "Ooooo Ah Ah oooOOO."
            },
            {
              "speaker": "Player",
              "text": "What did he say?"
            },
            {
              "speaker": "Elson",
              "text": "He said..."
            },
            {
              "speaker": "Elson",
              "text": "Let me think here..."
            },
            {
              "speaker": "Elson",
              "text": "Okay Oo is Aah, and OOO is oh..."
            },
            {
              "speaker": "Elson",
              "text": "I think he just said hello."
            },
            {
              "speaker": "Player",
              "text": "Oh he's awesome."
            },
            {
              "speaker": "Player",
              "text": "Before I go, I think I heard Santa saying you aren't allowed things on your back in the games."
            },
            {
              "speaker": "Elson",
              "text": "Don't worry about us [player name]. We are sneaky."
            },
            {
              "speaker": "Player",
              "text": "Good luck and Happy holidays!"
            }
          ]
        }
      ]
    }
  ]
