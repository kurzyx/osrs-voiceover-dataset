  "title": "Grimesquit",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "Before starting Ratcatchers",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Grimesquit",
                  "text": "'Ello 'Ello!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "Who's this then?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "I don't know any more than you do!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "Well ask them!"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "You ask them!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "No! I'm not talking to some stranger in a sewer."
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Go away, weirdo! We're busy!"
                }
              ]
            }
          ]
        },
        {
          "title": "After the completion of Ratcatchers",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Grimesquit",
                  "text": "Would you look at that!"
                },
                {
                  "speaker": "Player",
                  "text": "At what?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "It's [player name] again!"
                },
                {
                  "speaker": "Player",
                  "text": "What do you want?"
                },
                {
                  "speaker": "Player",
                  "text": "Where can I find Jimmy Dazzler again?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Didn't you find him in Ardougne?"
                },
                {
                  "speaker": "Phingspet",
                  "text": "He's normally in the Flying Horse Inn."
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Give him a kiss from me!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "I will absolutely not be doing that."
                },
                {
                  "speaker": "Player",
                  "text": "Can you tell me where I can find Hooknosed Jack?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "He's here in Varrock!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "Who 'nose' where, though!"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Ha! I'm sure you can 'scent' him out, [player name]"
                },
                {
                  "speaker": "The Sisters Grime",
                  "text": "Hahahaha!"
                },
                {
                  "speaker": "Phingspet",
                  "text": "Come on, it's not that funny."
                },
                {
                  "speaker": "Grimesquit",
                  "text": "You think our nose jokes are bad? Well..."
                },
                {
                  "speaker": "Phingspet",
                  "text": "Our eye jokes are even cornea!"
                },
                {
                  "speaker": "Player",
                  "text": "Can you tell me where I can find Smokin' Joe?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Last we heard he was in Keldagrim."
                },
                {
                  "speaker": "Player",
                  "text": "Can you tell me where I can find the Face?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "She was in Port Sarim last we heard."
                },
                {
                  "speaker": "Phingspet",
                  "text": "You can't miss her!"
                },
                {
                  "speaker": "Player",
                  "text": "Can you tell me where I can find Felkrash?"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "We shouldn't say, but-"
                },
                {
                  "speaker": "Phingspet",
                  "text": "She's got a secret den in Port Sarim!"
                },
                {
                  "speaker": "Grimesquit",
                  "text": "Not secret now, is it?!"
                }
              ]
            }
          ]
        },
        {
          "title": "After the quest without a rat pole",
          "sections": [],
          "dialogues": [
            {
              "lines": [
