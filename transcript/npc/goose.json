              "lines": [
                {
                  "speaker": "Goose",
                  "text": "*HONK*"
                },
                {
                  "speaker": "Player",
                  "text": "...Six Geese a-laying..."
                },
                {
                  "speaker": "Player",
                  "text": "That's a loud honk."
                },
                {
                  "speaker": "Player",
                  "text": "Ha, HONK right back at you."
                },
                {
                  "speaker": "Player",
                  "text": "What would a goose want with a pub?"
                }
              ]
            }
          ]
        },
        {
          "title": "During the 2023 Christmas event",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Goose",
                  "text": "*HONK*"
                },
                {
                  "speaker": "Player",
                  "text": "Of course, you honk. I don't know what I was expecting."
                },
                {
                  "speaker": "Player",
                  "text": "That is one large, loud chicken."
                },
                {
                  "speaker": "Player",
                  "text": "You're actually pretty cute with that little hat."
                },
                {
                  "speaker": "Player",
                  "text": "I take it that stealth is not your speciality."
                },
                {
                  "speaker": "Player",
                  "text": "I wonder where you came from?"
                }
              ]
            }
          ]
        }
