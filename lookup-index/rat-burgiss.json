  "hashesWithUnresolvedText": {
    "18e30e425a24bb1dbc3936c68f68a16f51baeeefeb0d4922b63679bf10a8f7a4": {
      "text": "Ah, [player name]! Good to see you! I heard you got my letter to Surok. Well done!",
      "placeholders": [
        "[player name]"
      ]
    },
    "59bfc07d68b5b768dc227b279795b26c43520f11ad272bba89b79c2c52345498": {
      "text": "Ah, [player name]! You've returned!",
      "placeholders": [
        "[player name]"
      ]
    },
    "141271e86f678692e45f47186fdf2b325bb490dffaf29de50a4d62420bb35f79": {
      "text": "Yes, [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "b770f8bd0e0cf9d4a8563084a32bcf3f32e3c8e38b98c5bd0f9aa47475950d5d": {
      "text": "Surok is a powerful mage and ruthless too. Who knows what will happen. I am sure that we will prevail, though. Don't worry, [player name]! You'll be fine!",
      "placeholders": [
        "[player name]"
      ]
    },
    "06d6196152b40b917473b4963d3e2192e92366582e733ddb54e6b3d4b634cc0e": {
      "text": "Now it is all down to you, [player name]. As you have proven yourself in the tasks I have set you, I am making you an honorary member of the VPSG!",
      "placeholders": [
        "[player name]"
      ]
    },
    "91df5fd22432e3cb45f8f4d2c99d7336ecaf4a38a9892e88fbf130f19bf2a1a4": {
      "text": "Right then. You have an important task set out for you. Good luck, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "b9710f00bf63adf00c7504a7905e335ecabd9f10b88d7fbc7db179b7935bc339": {
      "text": "Yes, you have an important job! Good luck, [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "3d03ab0d4408cd6102d6cf8e31db383a25a3e11dbdc477c6bc40b1660a4c568f": {
      "text": "Well, [player name], how did it go?",
      "placeholders": [
        "[player name]"
      ]
    },
    "98acac3fab2ff6400b5c087156f6ba7616becb02ff58841ccfc4a00cdf674899": {
      "text": "Ah! [player name]! You did a fine service for us. You might make a good member of the VPSG one day, with a little training and a bit more muscle!",
      "placeholders": [
        "[player name]"
      ]
    },
    "3fb5e33b9374c12e93520d4ad7dab1828194a48f8b44e971a183058000419b80": {
      "text": "But, who knows? We may need your assistance again soon. Thank you, [player name].",
      "placeholders": [
        "[player name]"
      ]
    }
  }
}