  "hashesWithUnresolvedText": {
    "19aeceec62f3c1c056fad639a24b241a4a0ecd00ec613af0b822221670724266": {
      "text": "Hello again, [Fremennik name].",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "c0124ec76f32f2a0b3ca0cfd20be5c863b233606bd32083a51af5b963f02efbe": {
      "text": "Right. Now let us get down to business, young [Fremennik name]. Let us hope we have no more interruptions.",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "5e769d30a802524eea85137fa5a9d6f2ce1ee5508e8377865e1601c7bccb38bc": {
      "text": "Exactly, [Fremennik name]. So are you interested?",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "790823037a1aa2bc0de43f3d990e677438ff651707196ba2434332da713d411e": {
      "text": "Excellent, [Fremennik name], you and I will get on very well.",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "c7cfc837e6dd6740b36a7c591ed26977d633d452c1130c23d58eb4e0e089a905": {
      "text": "Well, you had better find a way, and fast! Oh, [Fremennik name] you seem like someone who gets things done. I now appoint you official tax collector of Jatizso!",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "140c73c5dc131cfed36e4c07a31157970ac06268e6144ae93540495cc0650cd0": {
      "text": "[Fremennik name]! I command you to refill the royal coffers! Thorkel will work out the details.",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "6de11b7832db85e2d76acca3ac47af6aa0dea43de710333864ab9a1371a18f6f": {
      "text": "I have just one final task before you leave [Fremennik name].",
      "placeholders": [
        "[Fremennik name]"
      ]
    },
    "d09050a0d3374dcd621fa84b64a63e7cfb91d4ec06c942f983023784344ee96f": {
      "text": "Do you take me for a fool [Fremennik name]? It's all lies!",
      "placeholders": [
        "[Fremennik name]"
      ]
    }
  }
