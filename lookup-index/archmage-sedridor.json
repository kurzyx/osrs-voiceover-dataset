  "hashesWithUnresolvedText": {
    "ea6b68012520e582d261e5bb5b4d974d319f9c9680b461f01673071c929f6940": {
      "text": "Hello again, [player name]. What can I do for you?",
      "placeholders": [
        "[player name]"
      ]
    },
    "f73034d2296db5ecd437c0b9ba9d69db7d4738ed962f49248f764f12131ee9f3": {
      "text": "Best of luck, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "7f5a83a82c5066554b82dfacd4620c2c88d988f976a0b79174f54d2a8eefc509": {
      "text": "Your name is... [player name]!",
      "placeholders": [
        "[player name]"
      ]
    },
    "5d5d82eaaf96c2ae340cec4b06c77fad45d5c6e0b78635508ed41a260986e730": {
      "text": "Ah, [player name]. How goes your quest? Have you delivered my research to Aubury yet?",
      "placeholders": [
        "[player name]"
      ]
    },
    "00804c656329922f0ea209d93bd61d332f37040c438dd05f2136b9500b4ed45b": {
      "text": "Hmm... this scroll is very interesting. Did you get it from a Zamorakian wizard, perhaps? Don't lie to me, [player name].",
      "placeholders": [
        "[player name]"
      ]
    },
    "15d9f342fcaebb753806e7c9b6b5d1984b2dc8af559fb996d947029cdd06a7e4": {
      "text": "[player name], I'm going to be frank with you. Persten hasn't been seen here for almost a year. My last meeting with her was to discuss changing her line of study due to her lack of results.",
      "placeholders": [
        "[player name]"
      ]
    },
    "90b58a456171167c5e19cc090def8767f2ad8d392a8fba00733d62b35a65daf2": {
      "text": "[player name], are you ready?",
      "placeholders": [
        "[player name]"
      ]
    },
    "f7c08e75302aedad769399ed04c64db8b92c64f2ed045e2d83ba7ad8714c1d39": {
      "text": "I have given Persten and [player name] permission to go through. Until we know it's safe, no one else may enter.",
      "placeholders": [
        "[player name]"
      ]
    },
    "5456a79e2c5c23eda7494ebd7c5022132f6106012a61e7f089957960abf8f23d": {
      "text": "Thank you, [player name]. I appreciate that you did not mean for things to go this way. You should have this. It belonged to Persten. I don't want to think about where she got it.",
      "placeholders": [
        "[player name]"
      ]
    }
  }
