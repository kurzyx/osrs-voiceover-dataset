      ]
    },
    "abdb02375f637076d7ccfe69aad75d41fc072687183c9cf09f712e8ba8c3c217": {
      "text": "Are you becoming forgetful, [player name]? The Seven Priestly Warriors were the ones who originally blessed the River Salve.",
