  "title": "Jamila",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Jamila",
              "text": "Hello there. Looking to buy some of my wares? I also have a special item in stock that I reckon you'll love!"
            },
            {
              "speaker": "Player",
              "text": "Show me what you have."
            },
            {
              "speaker": "Jamila",
              "text": "Certainly!"
            },
            {
              "speaker": "Player",
              "text": "What's this special item?"
            },
            {
              "speaker": "Jamila",
              "text": "Oh it's fantastic! It's an exclusive item just for you! Consider it a thank you for all you've done for our city."
            },
            {
              "speaker": "Player",
              "text": "How is business?"
            },
            {
              "speaker": "Jamila",
              "text": "Slow at the moment. Maybe time will make things better. Perhaps you'd like to help by buying something yourself?"
            },
            {
              "speaker": "Player",
              "text": "I'm good, thanks."
            },
            {
              "speaker": "Jamila",
              "text": "Come back soon!"
            }
          ]
        }
      ]
    }
  ]
}