  "title": "Witch's House",
  "sections": [
    {
      "title": "Getting started",
      "sections": [
        {
          "title": "Talking to him again",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Boy",
                  "text": "Have you got my ball back yet?"
                },
                {
                  "speaker": "Player",
                  "text": "Not yet."
                },
                {
                  "speaker": "Boy",
                  "text": "Well, it's in the shed in that garden."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": [
        {
          "lines": [
            {
              "speaker": "Player",
              "text": "Hello young man."
            },
            {
              "speaker": "Player",
              "text": "What's the matter?"
            },
            {
              "speaker": "Boy",
              "text": "I've kicked my ball over that hedge, into that garden! The old lady who lives there is scary... She's locked the ball in her wooden shed! Can you get my ball back for me please?"
            },
            {
              "speaker": "Player",
              "text": "Ok, I'll see what I can do."
            },
            {
              "speaker": "Boy",
              "text": "Thanks mister!"
            },
            {
              "speaker": "Player",
              "text": "Get it back yourself."
            },
            {
              "speaker": "Boy",
              "text": "You're a meany!"
            },
            {
              "speaker": "Player",
              "text": "Well if you're not going to answer, I'll go."
            }
          ]
        }
      ]
    },
