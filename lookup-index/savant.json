      ]
    },
    "ce88bb9f44f38a63a5d02f41727f8a3743123091eaa9aa5b20e840ca7f7502c6": {
      "text": "[player name], are you there? We've been having a few technical problems...",
      "placeholders": [
        "[player name]"
      ]
    },
    "eb9e6ddb29912601e8311b74207225feb2f2753c68dc4a9708b000802753a7be": {
      "text": "[player name], are you there?",
      "placeholders": [
        "[player name]"
      ]
    },
    "5644b251733eed1d0a4db5b73aa793002c95a5025d07b35dc1c048ed6492b42c": {
      "text": "[player name], are you okay? Speak to me!",
      "placeholders": [
        "[player name]"
      ]
    },
    "9b0043b148c1f9936e2a43462dabc8c10efcb9c10b1175116e441eea61fc523b": {
      "text": "Well, hello! You must be [player name]? Sir Tiffy told me to expect you to call in on this frequency!",
      "placeholders": [
        "[player name]"
      ]
    },
    "bd026721dac789a38dc32e846d57476c1d8fe8b82dc5a289058196f220c299cc": {
      "text": "Listen [player name]. Solus is an incredibly dangerous criminal, and I don't think his grasp on reality is too tight, if you understand what I'm saying.",
      "placeholders": [
        "[player name]"
      ]
    },
    "5392db3e1f254e78613e3b524219f51f1133eb60d38f1193b66621176d9d876e": {
      "text": "Any time, [player name]. Over and out.",
      "placeholders": [
        "[player name]"
      ]
    },
    "caedc347c44dace4884b597b9aa12e03d2b45d6bfd8890e1538a13e29247bb15": {
      "text": "Hey, we're all Temple Knights here, right? Glad I could help, [player name]",
      "placeholders": [
        "[player name]"
      ]
    },
    "1610f932a51666feeec52d919cd937527947ef752e38cf1ec616d47eeb80f16d": {
      "text": "Well, you are not officially a full fledged Temple Knight now, are you Initiate [player name]?",
      "placeholders": [
        "[player name]"
      ]
    },
    "ca3223ebff5e3f0d6ec64cc6fb5dea54f3dbfce28e1372b4e2dc6a43751fd560": {
      "text": "[Player name], I've been monitoring your conversation; You can't let him have Temple Knight equipment, he is a Zamorakian!",
      "placeholders": [
        "[Player name]"
      ]
    },
    "c028dc3aeac7690feafff38cdc5b1e584e355594b730caf6b77e9830050308f9": {
      "text": "Hi [Player name], it sounds like a pretty good deal for this kind of information to me, but it's your call. We REALLY need to find Solus as soon as possible though, who knows what kind of damage he might cause now he is at large again!",
      "placeholders": [
        "[Player name]"
      ]
    },
    "b77c3d08e94b3ee8ee2bb059037057a9e2fd8a41e2c801b117bb9d2b7c1ecd2a": {
      "text": "Wow, that's some good thinking [Player name]! Okay, let's head there and get him!",
      "placeholders": [
        "[Player name]"
      ]
    },
    "6bdeb94eae881effc6e11832b9a390ef5a26792ebd4508057c93b0562ea4ae8e": {
      "text": "Yes [player name], you're right. But if he is using this 'slow-teleport' technique, then that means it is going to be a lot harder to catch him!",
      "placeholders": [
        "[player name]"
      ]
    },
    "f572c0d13ce14917e854bba1099ca562b3cf0d22447b9083d8c88fdb24696729": {
      "text": "Hello there [player name]. What can I help you with?",
      "placeholders": [
        "[player name]"
      ]
    },
    "75e8879262c694b548465154d7b01217942436ad81b2cd6d02ff925798d16c62": {
      "text": "You shouldn't really waste my time like this, [Player]...",
      "placeholders": [
        "[Player]"
      ]
    },
    "636d43c92c697b6a55bf496a07210167163f0f45a13260f6abb04accfb0aaa6d": {
      "text": "Well [player name], bear in mind that it might just be an object that as in the vicinity rather than something he was carrying...",
      "placeholders": [
        "[player name]"
      ]
    },
    "437c826728f43e93978348d5c64730002df7272f62024b5fea19d748b39c0adb": {
      "text": "[player name], I want you to search for him, and use your Comm-Orb to scan for him if you think he is nearby!",
      "placeholders": [
        "[player name]"
      ]
    },
    "de1c1860711aa36e2d33f998aac9a9fbf4a0a076129fb2c362d77c6e18a92eda": {
      "text": "I'm sorry [player name], I should have stopped him using that spell...",
      "placeholders": [
        "[player name]"
      ]
    },
    "1480a558c35f781e69deb6f32cdb018c072785bf91ee4291ad85ddc35d020c32": {
      "text": "Don't worry about it [player name], he may have escaped AGAIN, but I still have him on my tracking spell...",
      "placeholders": [
        "[player name]"
      ]
    },
    "7f707d0fbdff543a83bf7d97ca4602d37899ad9eb5cc613c581362a6f605e9c1": {
      "text": "[player name] I am reading a huge power surge from Solus, be very careful...",
      "placeholders": [
        "[player name]"
      ]
    },
    "b112302126c9752cb0f66677bdcc4b5681fd1fa6677ded5803d31a22e4aa8c18": {
      "text": "[player name]!!!",
      "placeholders": [
        "[player name]"
      ]
    },
    "d3d19ef568aacb647b725b099fb1dbae0d5263181dc5174bcfd0171856bca97e": {
      "text": "You're right [player name], I don't know how he is doing it...",
      "placeholders": [
        "[player name]"
      ]
    },
    "dff7cc0ab9d1ebce82f4406d69797020835f104187ae93a672bad16db83eea56": {
      "text": "No, [player name]. I am sorry that I let him hurt you like that...",
      "placeholders": [
        "[player name]"
      ]
    },
    "efee31edfe4fe52a282802cf9b48b9ea7a1aea4318ccd45a918fe975cd2df858": {
      "text": "That's the spirit [player name]! Just awaiting the data to come through...",
      "placeholders": [
        "[player name]"
      ]
    },
    "9be849daadd3fffa455105b78657189eb45ed05a256b73e3d1ba6f0a81603ba7": {
      "text": "You should probably take a minute to restock on supplies and heal up though [player name].",
      "placeholders": [
