      "title": "Gate guard",
      "sections": [
        {
          "title": "During the Grand Tree",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Shipyard worker",
                  "text": "Hey you! What are you up to?"
                },
                {
                  "speaker": "Player",
                  "text": "I'm trying to open the gate!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "I can see that! Why?"
                },
                {
                  "speaker": "Player",
                  "text": "I'm from the Ministry of Health and Safety."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Never 'erd of 'em."
                },
                {
                  "speaker": "Player",
                  "text": "You will respect my authority!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Get out of here before I give you a beating!"
                },
                {
                  "speaker": "Player",
                  "text": "Glough sent me."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Hmm...really? What for?"
                },
                {
                  "speaker": "Player",
                  "text": "You're wasting my time! Take me to your superior!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "OK. Password."
                },
                {
                  "speaker": "Player",
                  "text": "Ka."
                },
                {
                  "speaker": "Player",
                  "text": "Ko."
                },
                {
                  "speaker": "Player",
                  "text": "Ke."
                },
                {
                  "speaker": "Player",
                  "text": "Lo."
                },
                {
                  "speaker": "Player",
                  "text": "Lu."
                },
                {
                  "speaker": "Player",
                  "text": "Le."
                },
                {
                  "speaker": "Player",
                  "text": "Mon."
                },
                {
                  "speaker": "Player",
                  "text": "Min."
                },
                {
                  "speaker": "Player",
                  "text": "Men."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Sorry to have kept you."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "You have no idea!"
                },
                {
                  "speaker": "Player",
                  "text": "I'm just looking around."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "This ain't a museum! Leave now!"
                },
                {
                  "speaker": "Player",
                  "text": "I'll leave when I choose!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Well you're not on the list so you're not coming in. Go away."
                },
                {
                  "speaker": "Player",
                  "text": "Well I'll just stand here then until you let me in."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "You do that!"
                },
                {
                  "speaker": "Player",
                  "text": "I will!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Yeah?"
                },
                {
                  "speaker": "Player",
                  "text": "Yeah!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "..."
                },
                {
                  "speaker": "Player",
                  "text": "..."
                },
                {
                  "speaker": "Player",
                  "text": "So are you going to let me in then?"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "No."
                },
                {
                  "speaker": "Player",
                  "text": "..."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "..."
                },
                {
                  "speaker": "Player",
                  "text": "You bored yet?"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "No, I can stand here all day."
                },
                {
                  "speaker": "Player",
                  "text": "..."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "..."
                },
                {
                  "speaker": "Player",
                  "text": "Alright you win. I'll find another way in."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "No you won't."
                },
                {
                  "speaker": "Player",
                  "text": "Yes I will."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "I'm not starting that again. Maybe if I ignore you you'll go away..."
                }
              ]
            }
          ]
        },
        {
          "title": "During Monkey Madness I",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Shipyard worker",
                  "text": "Hey you! What are you up to?"
                },
                {
                  "speaker": "Player",
                  "text": "I'm trying to open the gate!"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "I can see that! Why?"
                },
                {
                  "speaker": "Player",
                  "text": "I am on a special mission for King Narnode of the Gnomes."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Narnode? I don't believe you. He wouldn't send a human!"
                },
                {
                  "speaker": "Player",
                  "text": "Well, he did..."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Tough."
                },
                {
                  "speaker": "Player",
                  "text": "Look, I have the Gnome Royal Seal."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Wow. I haven't seen one of these since..."
                },
                {
                  "speaker": "Player",
                  "text": "Since when?"
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "... since Glough used to visit."
                },
                {
                  "speaker": "Shipyard worker",
                  "text": "Anyway. Please step inside, [Sir/Miss]."
                }
              ]
            }
          ]
        }
