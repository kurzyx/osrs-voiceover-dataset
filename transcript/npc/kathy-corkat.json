{
  "ref": "kathy-corkat",
  "categoryRef": "npc",
  "title": "Kathy Corkat",
  "sections": [
    {
      "title": "Before completion of Swan Song",
      "sections": [
        {
          "title": "Standard dialogue near Eagles' Peak",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Kathy Corkat",
                  "text": "Oh dear, oh dear, oh dear..."
                },
                {
                  "speaker": "Player",
                  "text": "Oh dear?"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "It's terrible!"
                },
                {
                  "speaker": "Player",
                  "text": "What's terrible?"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Oh, never mind, dearie. What can I do for you?"
                },
                {
                  "speaker": "Player",
                  "text": "Can you take me downstream in your boat?"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Ooh, it's dangerous up there at the moment!"
                },
                {
                  "speaker": "Player",
                  "text": "I'm not afraid - let's go!"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "It's dangerous up there for me too, dearie."
                },
                {
                  "speaker": "Player",
                  "text": "Would it help if I gave you some money?"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Ooh, that's better! I'll take you up north for 50 shiny coins."
                },
                {
                  "speaker": "Player",
                  "text": "Alright, I'll pay."
                },
                {
                  "speaker": "Player",
                  "text": "Not a chance!"
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Then you can find your own way north, dearie!"
                },
                {
                  "speaker": "Player",
                  "text": "Dangerous? Nah, forget it!"
                },
                {
                  "speaker": "Player",
                  "text": "I don't think I want anything, thanks."
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Everybody wants something, dearie!"
                },
                {
                  "speaker": "Player",
                  "text": "Huh? Oh, forget it!"
                }
              ]
            }
          ]
        },
        {
          "title": "Standard dialogue near Piscatoris Fishing Colony",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Kathy Corkat",
                  "text": "I'll be glad to get away from this place, dearie! Fancy a lift up the river?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes please."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    },
    {
      "title": "After completion of Swan Song",
      "sections": [
        {
          "title": "Standard dialogue near Eagles' Peak",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Kathy Corkat",
                  "text": "Hello dearie. Heading up north to the Fishing Colony, are we?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes please."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                }
              ]
            }
          ]
        },
        {
          "title": "Standard dialogue near Piscatoris Fishing Colony",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Kathy Corkat",
                  "text": "Are ye wantin' a lift up the river, dearie?"
                },
                {
                  "speaker": "Player",
                  "text": "Why don't you row right into the Colony? It'd make it much easier to get in there."
                },
                {
                  "speaker": "Kathy Corkat",
                  "text": "Oh, Franklin doesn't like it if I take my boat too close. He says I'll damage the nets and scare the fish. But were you wanting a lift up to the river?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes please."
                },
                {
                  "speaker": "Player",
                  "text": "No thanks."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
}