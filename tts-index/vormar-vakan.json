    "9884a5f851e792ece39075be19ef828695fb7660ac9084051e7c843603ea0850": "I know right! Bloody brilliant!",
    "432290eb7d92960603eb4ffb8ec947b6e2ce54a6f9840557f3ed1e6e1ceb5734": "I'll have a pint please.",
    "a3949e3c73949673cb1fb1826d37b58dea3113e4aed3787fd3c8d377ee97fa5d": "Sure you do!",
    "7b7ae16c7775f82400ecd1718647b881949317a0555ad2ae13566945f01841de": "Well clear off then.",
    "db05841f9fd6cb75ea604307ac161b5b2ec77e95568ee3e30a17d0fef0434db8": "Human! Get back to the slave pens before I call the guards!"
