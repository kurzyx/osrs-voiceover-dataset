{
  "ref": "basilisk-head-mounted-",
  "categoryRef": "npc",
  "title": "Basilisk head (mounted)",
  "sections": [
    {
      "title": "Standard dialogue",
      "sections": [
        {
          "title": "If the player is a house guest",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Basilisk",
                  "text": "What do you want?"
                },
                {
                  "speaker": "Player",
                  "text": "Oh, er, nothing!"
                }
              ]
            }
          ]
        },
        {
          "title": "If the player is the house owner",
          "sections": [],
          "dialogues": [
            {
              "lines": [
                {
                  "speaker": "Basilisk",
                  "text": "What do you want?"
                },
                {
                  "speaker": "Player",
                  "text": "I want to mock you."
                },
                {
                  "speaker": "Basilisk",
                  "text": "All right. Go on then."
                },
                {
                  "speaker": "Player",
                  "text": "You're a [boring/fat/hideous/puny/smelly/stupid] [beetle/chicken/egg/mud/slime/worm]-[brained/eating/like/loving/smelling/witted] [basilisk/idiot/lizard/mudworm/slimeball/weakling]!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I'm going back to sleep."
                },
                {
                  "speaker": "Player",
                  "text": "I want to apologise for killing you."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Go on then."
                },
                {
                  "speaker": "Player",
                  "text": "I'm, um, very sorry I killed you."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Really sorry?"
                },
                {
                  "speaker": "Player",
                  "text": "No, not really!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I don't care."
                },
                {
                  "speaker": "Player",
                  "text": "Yes really!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Really really?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes, really really!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Fat lot of good that does, I'm still dead."
                },
                {
                  "speaker": "Player",
                  "text": "I'm not THAT sorry!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I don't care."
                },
                {
                  "speaker": "Player",
                  "text": "Will you forgive me?"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Of course I'll forgive you!"
                },
                {
                  "speaker": "Player",
                  "text": "Really?"
                },
                {
                  "speaker": "Basilisk",
                  "text": "No!"
                },
                {
                  "speaker": "Player",
                  "text": "I promise not to do it again."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Of couse you won't do it again, you can only kill me once."
                },
                {
                  "speaker": "Player",
                  "text": "That's why I won't do it again! There'd be no point!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I don't care."
                },
                {
                  "speaker": "Player",
                  "text": "But I won't do it to any other basilisks!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Really?"
                },
                {
                  "speaker": "Player",
                  "text": "Yes, really!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "All right then. Apology accepted. Now leave me alone."
                },
                {
                  "speaker": "Player",
                  "text": "No, not really!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I don't care."
                },
                {
                  "speaker": "Player",
                  "text": "Don't start that again!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Leave me alone then."
                },
                {
                  "speaker": "Player",
                  "text": "Don't push it!"
                },
                {
                  "speaker": "Basilisk",
                  "text": "I don't care anyway."
                },
                {
                  "speaker": "Player",
                  "text": "I just wanted to check that you're okay."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Apart from being dead and stuffed and hanging on a wall, you mean?"
                },
                {
                  "speaker": "Player",
                  "text": "Uh... yeah, apart from that are you okay?"
                },
                {
                  "speaker": "Basilisk",
                  "text": "Actually there's something blocking my view of the far wall."
                },
                {
                  "speaker": "Player",
                  "text": "I don't see anything."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Perhaps if you were to move to one side of me."
                },
                {
                  "speaker": "Player",
                  "text": "I still don't see anything."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Oh, it's moved away. I can see now."
                },
                {
                  "speaker": "Player",
                  "text": "Nothing."
                },
                {
                  "speaker": "Basilisk",
                  "text": "Leave me alone."
                }
              ]
            }
          ]
        }
      ],
      "dialogues": []
    }
  ]
}